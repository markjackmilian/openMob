<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
             xmlns:helpers="clr-namespace:openMob.Helpers"
             x:Class="openMob.Views.Popups.AddProjectSheet"
             x:DataType="vm:AddProjectViewModel"
             Title="New Project"
             Shell.PresentationMode="ModalAnimated"
             BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}">

  <VerticalStackLayout Spacing="0">

    <!-- Handle bar -->
    <BoxView
        WidthRequest="36"
        HeightRequest="4"
        CornerRadius="2"
        Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
        HorizontalOptions="Center"
        Margin="0,8,0,16" />

    <!-- Title -->
    <Label
        Text="New Project"
        FontFamily="InterSemiBold"
        FontSize="{StaticResource FontSizeTitle3}"
        TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}"
        Margin="16,0,16,16" />

    <!-- Form fields -->
    <VerticalStackLayout Spacing="16" Padding="16,0">

      <!-- Project Name -->
      <VerticalStackLayout Spacing="4">
        <Label
            Text="Project Name"
            FontFamily="InterMedium"
            FontSize="{StaticResource FontSizeSubheadline}"
            TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
        <Entry
            Text="{Binding ProjectName, Mode=TwoWay}"
            Placeholder="My Project"
            Style="{StaticResource OutlinedEntry}"
            FontFamily="InterRegular"
            AutomationId="AddProjectNameEntry"
            SemanticProperties.Hint="Enter the project name" />
      </VerticalStackLayout>

      <!-- Project Path -->
      <VerticalStackLayout Spacing="4">
        <Label
            Text="Project Path"
            FontFamily="InterMedium"
            FontSize="{StaticResource FontSizeSubheadline}"
            TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
        <Entry
            Text="{Binding ProjectPath, Mode=TwoWay}"
            Placeholder="/path/to/project"
            Style="{StaticResource OutlinedEntry}"
            FontFamily="InterRegular"
            AutomationId="AddProjectPathEntry"
            SemanticProperties.Hint="Enter the project directory path" />
      </VerticalStackLayout>

      <!-- Buttons -->
      <Grid
          ColumnDefinitions="*,*"
          ColumnSpacing="12"
          Margin="0,8,0,16">
        <Button
            Grid.Column="0"
            Text="Cancel"
            Command="{Binding CancelCommand}"
            Style="{StaticResource SecondaryButton}"
            AutomationId="AddProjectCancelButton" />
        <Button
            Grid.Column="1"
            Text="Add"
            Command="{Binding AddProjectCommand}"
            IsEnabled="{Binding CanAdd}"
            Style="{StaticResource PrimaryButton}"
            AutomationId="AddProjectAddButton" />
      </Grid>

    </VerticalStackLayout>

  </VerticalStackLayout>

</ContentPage>
