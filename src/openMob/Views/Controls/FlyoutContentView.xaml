<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
             xmlns:models="clr-namespace:openMob.Core.Models;assembly=openMob.Core"
             xmlns:helpers="clr-namespace:openMob.Helpers"
             x:Class="openMob.Views.Controls.FlyoutContentView"
             x:DataType="viewmodels:FlyoutViewModel">

  <Grid
      RowDefinitions="Auto,*"
      BackgroundColor="{AppThemeBinding Light={StaticResource ColorBackgroundLight}, Dark={StaticResource ColorBackgroundDark}}">

    <!-- Section header: project name (uppercase) -->
    <Label
        Grid.Row="0"
        Text="{Binding ProjectSectionTitle, FallbackValue='SESSIONS', TargetNullValue='SESSIONS'}"
        FontFamily="InterMedium"
        FontSize="{StaticResource FontSizeCaption1}"
        TextTransform="Uppercase"
        TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
        Margin="16,12,16,8" />

    <!-- No project placeholder -->
    <Label
        Grid.Row="1"
        Text="Select a project to view sessions"
        FontFamily="InterRegular"
        FontSize="{StaticResource FontSizeCallout}"
        HorizontalTextAlignment="Center"
        Margin="{StaticResource SpacingLg}"
        TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
        IsVisible="{Binding HasProject, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}" />

    <!-- Loading indicator -->
    <ActivityIndicator
        Grid.Row="1"
        IsRunning="{Binding IsLoading}"
        IsVisible="{Binding IsLoading}"
        HorizontalOptions="Center"
        VerticalOptions="Start"
        Margin="0,24,0,0" />

    <!-- Session list -->
    <CollectionView
        Grid.Row="1"
        ItemsSource="{Binding Sessions}"
        IsVisible="{Binding HasProject}"
        SelectionMode="None">

      <CollectionView.EmptyView>
        <VerticalStackLayout
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Padding="{StaticResource SpacingLg}">
          <Label
              Text="No sessions yet"
              FontFamily="InterRegular"
              FontSize="{StaticResource FontSizeCallout}"
              HorizontalTextAlignment="Center"
              TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" />
        </VerticalStackLayout>
      </CollectionView.EmptyView>

      <CollectionView.ItemTemplate>
        <DataTemplate x:DataType="models:SessionItem">
          <VerticalStackLayout Spacing="0">
            <SwipeView>
              <SwipeView.RightItems>
                <SwipeItems>
                  <SwipeItem
                      Text="Delete"
                      BackgroundColor="{AppThemeBinding Light={StaticResource ColorErrorLight}, Dark={StaticResource ColorErrorDark}}"
                      Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:FlyoutViewModel}}, Path=DeleteSessionCommand}"
                      CommandParameter="{Binding Id}"
                      AutomationId="DeleteSessionSwipeItem">
                    <SwipeItem.IconImageSource>
                      <FontImageSource
                          FontFamily="MaterialSymbols"
                          Glyph="{x:Static helpers:MaterialIcons.Delete}"
                          Size="22"
                          Color="{AppThemeBinding Light={StaticResource ColorOnErrorLight}, Dark={StaticResource ColorOnErrorDark}}" />
                    </SwipeItem.IconImageSource>
                  </SwipeItem>
                </SwipeItems>
              </SwipeView.RightItems>

              <Grid
                  ColumnDefinitions="*,Auto"
                  Padding="16,12"
                  BackgroundColor="Transparent">
                <Grid.Triggers>
                  <DataTrigger TargetType="Grid" Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryContainerLight}, Dark={StaticResource ColorPrimaryContainerDark}}" />
                  </DataTrigger>
                </Grid.Triggers>
                <Grid.GestureRecognizers>
                  <TapGestureRecognizer
                      Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:FlyoutViewModel}}, Path=SelectSessionCommand}"
                      CommandParameter="{Binding Id}" />
                </Grid.GestureRecognizers>

                <!-- Session title -->
                <Label
                    Grid.Column="0"
                    Text="{Binding Title, FallbackValue='Untitled', TargetNullValue='Untitled'}"
                    FontFamily="InterRegular"
                    FontSize="{StaticResource FontSizeBody}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}"
                    LineBreakMode="TailTruncation"
                    MaxLines="1"
                    VerticalOptions="Center" />

                <!-- Relative timestamp -->
                <Label
                    Grid.Column="1"
                    Text="{Binding UpdatedAt, Converter={StaticResource DateTimeToRelativeStringConverter}}"
                    FontFamily="InterRegular"
                    FontSize="{StaticResource FontSizeCaption1}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                    VerticalOptions="Center"
                    Margin="8,0,0,0" />

              </Grid>
            </SwipeView>

            <!-- Separator between items -->
            <BoxView
                HeightRequest="0.5"
                Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight},
                                        Dark={StaticResource ColorSeparatorDark}}" />
          </VerticalStackLayout>
        </DataTemplate>
      </CollectionView.ItemTemplate>

      <!-- MAUI workaround: empty footer prevents CollectionView from clipping the last item's SwipeView on iOS -->
      <CollectionView.Footer>
        <BoxView HeightRequest="0" />
      </CollectionView.Footer>

    </CollectionView>

  </Grid>

</ContentView>
