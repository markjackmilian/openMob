<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:openMob.Helpers"
             xmlns:vm="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
             x:Class="openMob.Views.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings">

  <ScrollView>
    <VerticalStackLayout
        Padding="{StaticResource SpacingLg}"
        Spacing="0">

      <!-- Section: General -->
      <Label
          Text="GENERAL"
          Style="{StaticResource CaptionLabel}"
          FontFamily="InterMedium"
          Margin="0,16,0,8" />

      <Border Style="{StaticResource CardBorder}">
        <VerticalStackLayout Spacing="0">

          <!-- Appearance -->
          <Grid
              ColumnDefinitions="Auto,*,Auto"
              Padding="0,12"
              ColumnSpacing="{StaticResource SpacingMd}">
            <Grid.GestureRecognizers>
              <TapGestureRecognizer Tapped="OnAppearanceTapped" />
            </Grid.GestureRecognizers>
            <Label
                FontFamily="MaterialSymbols"
                Text="{x:Static helpers:MaterialIcons.Settings}"
                FontSize="22"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                VerticalOptions="Center" />
            <Label
                Grid.Column="1"
                Text="Appearance"
                FontFamily="InterRegular"
                VerticalOptions="Center" />
            <Label
                Grid.Column="2"
                Text="{Binding SelectedThemeLabel}"
                FontFamily="InterRegular"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                VerticalOptions="Center" />
          </Grid>

          <BoxView
              HeightRequest="0.5"
              Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight}, Dark={StaticResource ColorSeparatorDark}}" />

          <!-- Server Connection -->
          <Grid
              ColumnDefinitions="Auto,*,Auto"
              Padding="0,12"
              ColumnSpacing="{StaticResource SpacingMd}">
            <Label
                FontFamily="MaterialSymbols"
                Text="{x:Static helpers:MaterialIcons.Link}"
                FontSize="22"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                VerticalOptions="Center" />
            <Label
                Grid.Column="1"
                Text="Server Connection"
                FontFamily="InterRegular"
                VerticalOptions="Center" />
            <Label
                Grid.Column="2"
                FontFamily="MaterialSymbols"
                Text="{x:Static helpers:MaterialIcons.ChevronRight}"
                FontSize="18"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                VerticalOptions="Center" />
          </Grid>

          <BoxView
              HeightRequest="0.5"
              Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight}, Dark={StaticResource ColorSeparatorDark}}" />

          <!-- Notifications -->
          <Grid
              ColumnDefinitions="Auto,*,Auto"
              Padding="0,12"
              ColumnSpacing="{StaticResource SpacingMd}">
            <Label
                FontFamily="MaterialSymbols"
                Text="{x:Static helpers:MaterialIcons.Notifications}"
                FontSize="22"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                VerticalOptions="Center" />
            <Label
                Grid.Column="1"
                Text="Notifications"
                FontFamily="InterRegular"
                VerticalOptions="Center" />
            <Label
                Grid.Column="2"
                FontFamily="MaterialSymbols"
                Text="{x:Static helpers:MaterialIcons.ChevronRight}"
                FontSize="18"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                VerticalOptions="Center" />
          </Grid>

        </VerticalStackLayout>
      </Border>

      <!-- Section: AI Providers -->
      <Label
          Text="AI PROVIDERS"
          Style="{StaticResource CaptionLabel}"
          FontFamily="InterMedium"
          Margin="0,24,0,8" />

      <Border Style="{StaticResource CardBorder}">
        <VerticalStackLayout Spacing="0">

          <!-- Manage Providers -->
          <Grid
              ColumnDefinitions="Auto,*,Auto"
              Padding="0,12"
              ColumnSpacing="{StaticResource SpacingMd}">
            <Label
                FontFamily="MaterialSymbols"
                Text="{x:Static helpers:MaterialIcons.SmartToy}"
                FontSize="22"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                VerticalOptions="Center" />
            <Label
                Grid.Column="1"
                Text="Manage Providers"
                FontFamily="InterRegular"
                VerticalOptions="Center" />
            <Label
                Grid.Column="2"
                FontFamily="MaterialSymbols"
                Text="{x:Static helpers:MaterialIcons.ChevronRight}"
                FontSize="18"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                VerticalOptions="Center" />
          </Grid>

          <BoxView
              HeightRequest="0.5"
              Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight}, Dark={StaticResource ColorSeparatorDark}}" />

          <!-- API Keys -->
          <Grid
              ColumnDefinitions="Auto,*,Auto"
              Padding="0,12"
              ColumnSpacing="{StaticResource SpacingMd}">
            <Label
                FontFamily="MaterialSymbols"
                Text="{x:Static helpers:MaterialIcons.Key}"
                FontSize="22"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                VerticalOptions="Center" />
            <Label
                Grid.Column="1"
                Text="API Keys"
                FontFamily="InterRegular"
                VerticalOptions="Center" />
            <Label
                Grid.Column="2"
                FontFamily="MaterialSymbols"
                Text="{x:Static helpers:MaterialIcons.ChevronRight}"
                FontSize="18"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                VerticalOptions="Center" />
          </Grid>

        </VerticalStackLayout>
      </Border>

      <!-- Section: About -->
      <Label
          Text="ABOUT"
          Style="{StaticResource CaptionLabel}"
          FontFamily="InterMedium"
          Margin="0,24,0,8" />

      <Border Style="{StaticResource CardBorder}">
        <VerticalStackLayout Spacing="0">

          <!-- Version -->
          <Grid
              ColumnDefinitions="Auto,*,Auto"
              Padding="0,12"
              ColumnSpacing="{StaticResource SpacingMd}">
            <Label
                FontFamily="MaterialSymbols"
                Text="{x:Static helpers:MaterialIcons.Info}"
                FontSize="22"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                VerticalOptions="Center" />
            <Label
                Grid.Column="1"
                Text="Version"
                FontFamily="InterRegular"
                VerticalOptions="Center" />
            <Label
                Grid.Column="2"
                Text="1.0.0"
                FontFamily="InterRegular"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                VerticalOptions="Center" />
          </Grid>

        </VerticalStackLayout>
      </Border>

    </VerticalStackLayout>
  </ScrollView>

</ContentPage>
