<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:openMob.Helpers"
             xmlns:controls="clr-namespace:openMob.Views.Controls"
             xmlns:models="clr-namespace:openMob.Core.Models;assembly=openMob.Core"
             xmlns:viewmodels="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
             x:Class="openMob.Views.Pages.ChatPage"
             x:Name="ChatPageRoot"
             x:DataType="viewmodels:ChatViewModel"
             Shell.NavBarIsVisible="False">

  <!-- xmlns:models is shared for both ChatMessage and ToolCallInfo (same namespace) -->

  <!-- ChatPage uses edge-to-edge layout for the message list (standard chat UI pattern).
       Horizontal padding is applied to the input bar and header, not the message area. -->
  <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto">

    <!-- ═══════════════════════════════════════════════════════════════
         ROW 0 — Header
         Primary-colored bar with white icons and compact title
         ═══════════════════════════════════════════════════════════════ -->
    <Grid Grid.Row="0"
          ColumnDefinitions="Auto,*,Auto"
          HeightRequest="48"
          Padding="4,0"
          BackgroundColor="{AppThemeBinding Light={StaticResource ColorPrimaryContainerLight},
                                            Dark={StaticResource ColorPrimaryContainerDark}}">

      <!-- Hamburger button (left) -->
      <ImageButton Grid.Column="0"
                   x:Name="HamburgerButton"
                   Clicked="OnHamburgerClicked"
                   WidthRequest="40"
                   HeightRequest="40"
                   BackgroundColor="Transparent"
                   AutomationId="ChatHamburgerButton"
                   SemanticProperties.Description="Open navigation menu">
        <ImageButton.Source>
          <FontImageSource FontFamily="TablerIcons"
                           Glyph="{x:Static helpers:IconKeys.Menu}"
                           Size="18"
                           Color="{AppThemeBinding Light={StaticResource ColorPrimaryLight},
                                                    Dark={StaticResource ColorPrimaryDark}}" />
        </ImageButton.Source>
      </ImageButton>

      <!-- Center: Session name (tappable to rename) -->
      <Label Grid.Column="1"
             Text="{Binding SessionName, FallbackValue='New chat'}"
             FontFamily="InterSemiBold"
             FontSize="{StaticResource FontSizeSubheadline}"
             TextColor="{AppThemeBinding Light={StaticResource ColorOnPrimaryContainerLight},
                                          Dark={StaticResource ColorOnPrimaryContainerDark}}"
             HorizontalTextAlignment="Center"
             VerticalTextAlignment="Center"
             HorizontalOptions="Center"
             VerticalOptions="Center"
             LineBreakMode="TailTruncation"
             MaximumWidthRequest="220"
             AutomationId="ChatSessionName">
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding RenameSessionCommand}" />
        </Label.GestureRecognizers>
      </Label>

      <!-- Context icon (right) — opens Context Sheet -->
      <ImageButton Grid.Column="2"
                   Command="{Binding OpenContextSheetCommand}"
                   WidthRequest="40"
                   HeightRequest="40"
                   BackgroundColor="Transparent"
                   AutomationId="ChatContextButton"
                   SemanticProperties.Description="Open context settings">
        <ImageButton.Source>
          <FontImageSource FontFamily="TablerIcons"
                           Glyph="{x:Static helpers:IconKeys.Adjustments}"
                           Size="18"
                           Color="{AppThemeBinding Light={StaticResource ColorPrimaryLight},
                                                    Dark={StaticResource ColorPrimaryDark}}" />
        </ImageButton.Source>
      </ImageButton>

    </Grid>

    <!-- ═══════════════════════════════════════════════════════════════
         ROW 1 — Context Status Bar (REQ-019 through REQ-022)
         ═══════════════════════════════════════════════════════════════ -->
    <controls:ContextStatusBarView Grid.Row="1"
                                    x:Name="ContextStatusBar"
                                    ProjectName="{Binding ProjectName}"
                                    ModelName="{Binding SelectedModelName, TargetNullValue='No model', FallbackValue='No model'}"
                                    ThinkingLevel="{Binding ThinkingLevel}"
                                    TapCommand="{Binding OpenContextSheetCommand}" />

    <!-- ═══════════════════════════════════════════════════════════════
         ROW 2 — Message area (star row) + FAB overlay
         ═══════════════════════════════════════════════════════════════ -->
    <Grid Grid.Row="2"
          RowDefinitions="*,Auto"
          BackgroundColor="{AppThemeBinding Light={StaticResource ColorBackgroundLight},
                                            Dark={StaticResource ColorBackgroundDark}}">

      <!-- Empty State — visible when IsEmpty = true -->
      <controls:EmptyStateView Grid.Row="0"
                               IsVisible="{Binding IsEmpty}"
                               Title="How can I help you?" />

      <!-- Message CollectionView — visible when IsEmpty = false -->
      <CollectionView Grid.Row="0"
                      x:Name="MessagesCollectionView"
                      ItemsSource="{Binding Messages}"
                      ItemsUpdatingScrollMode="KeepLastItemInView"
                      SelectionMode="None"
                      Scrolled="OnMessagesScrolled"
                      IsVisible="{Binding IsEmpty, Converter={StaticResource InvertedBoolConverter}}">
        <CollectionView.ItemTemplate>
          <DataTemplate x:DataType="models:ChatMessage">
            <VerticalStackLayout Spacing="0">

              <!-- ═══════════════════════════════════════════════════════
                   [REQ-029] COMPACTION BANNER
                   Shown instead of normal content when CompactionNotice is not null.
                   Full-width informational banner between messages.
                   ═══════════════════════════════════════════════════════ -->
              <Border IsVisible="{Binding CompactionNotice, Converter={StaticResource NullToVisibilityConverter}}"
                      BackgroundColor="{AppThemeBinding Light={StaticResource ColorPrimaryContainerLight},
                                                       Dark={StaticResource ColorPrimaryContainerDark}}"
                      StrokeThickness="0"
                      StrokeShape="RoundRectangle 8"
                      Padding="{StaticResource SpacingMd}"
                      Margin="8,4">
                <HorizontalStackLayout Spacing="{StaticResource SpacingSm}"
                                       HorizontalOptions="Center">
                  <Label Text="⟳"
                         FontSize="{StaticResource FontSizeFootnote}"
                         TextColor="{AppThemeBinding Light={StaticResource ColorOnPrimaryContainerLight},
                                                     Dark={StaticResource ColorOnPrimaryContainerDark}}"
                         VerticalOptions="Center"
                         SemanticProperties.Description="Context compacted" />
                  <Label Text="{Binding CompactionNotice, FallbackValue='', TargetNullValue=''}"
                         FontFamily="InterRegular"
                         FontSize="{StaticResource FontSizeFootnote}"
                         TextColor="{AppThemeBinding Light={StaticResource ColorOnPrimaryContainerLight},
                                                     Dark={StaticResource ColorOnPrimaryContainerDark}}"
                         VerticalOptions="Center" />
                </HorizontalStackLayout>
              </Border>

              <!-- ═══════════════════════════════════════════════════════
                   Normal message content — hidden when CompactionNotice is set.
                   ═══════════════════════════════════════════════════════ -->
              <VerticalStackLayout IsVisible="{Binding CompactionNotice, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"
                                   Spacing="0">

                <!-- ─────────────────────────────────────────────────────
                     FALLBACK CARD — shown when SenderType == Fallback
                     Hidden by default; DataTrigger makes it visible for
                     unhandled SSE events. All standard sections are hidden
                     via the wrapper VerticalStackLayout below.
                     ───────────────────────────────────────────────────── -->
                <controls:FallbackMessageView
                    RawType="{Binding FallbackRawType, FallbackValue='', TargetNullValue=''}"
                    RawJson="{Binding FallbackRawJson}"
                    IsVisible="False"
                    Margin="0,2,0,0"
                    AutomationId="FallbackMessageCard"
                    SemanticProperties.Description="Unhandled server message">
                  <controls:FallbackMessageView.Triggers>
                    <DataTrigger TargetType="controls:FallbackMessageView"
                                 Binding="{Binding SenderType}"
                                 Value="{x:Static models:SenderType.Fallback}">
                      <Setter Property="IsVisible" Value="True" />
                    </DataTrigger>
                  </controls:FallbackMessageView.Triggers>
                </controls:FallbackMessageView>

                <!-- ─────────────────────────────────────────────────────
                     Standard message content — hidden when SenderType == Fallback.
                     Wraps all existing sections so a single DataTrigger
                     hides them all atomically.
                     ───────────────────────────────────────────────────── -->
                <VerticalStackLayout Spacing="0">
                  <VerticalStackLayout.Triggers>
                    <DataTrigger TargetType="VerticalStackLayout"
                                 Binding="{Binding SenderType}"
                                 Value="{x:Static models:SenderType.Fallback}">
                      <Setter Property="IsVisible" Value="False" />
                    </DataTrigger>
                  </VerticalStackLayout.Triggers>

                  <!-- ─────────────────────────────────────────────────────
                       [REQ-029] SUBTASK CHIPS
                       Shown above the message when SubtaskLabels has items.
                       Uses BindableLayout (not nested CollectionView).
                       ───────────────────────────────────────────────────── -->
                  <FlexLayout IsVisible="{Binding SubtaskLabels.Count, Converter={StaticResource IntToBoolConverter}}"
                              Wrap="Wrap"
                              Direction="Row"
                              JustifyContent="Start"
                              AlignItems="Start"
                              Margin="8,4,8,0">
                    <BindableLayout.ItemsSource>
                      <Binding Path="SubtaskLabels" />
                    </BindableLayout.ItemsSource>
                    <BindableLayout.ItemTemplate>
                      <DataTemplate x:DataType="x:String">
                        <Border StrokeShape="RoundRectangle 12"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight},
                                                                 Dark={StaticResource ColorSurfaceSecondaryDark}}"
                                Padding="8,3"
                                Margin="0,0,4,4">
                          <Label Text="{Binding .}"
                                 FontFamily="InterRegular"
                                 FontSize="{StaticResource FontSizeCaption1}"
                                 TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight},
                                                             Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                                 LineBreakMode="TailTruncation" />
                        </Border>
                      </DataTemplate>
                    </BindableLayout.ItemTemplate>
                  </FlexLayout>

                  <!-- ─────────────────────────────────────────────────────
                       [REQ-023] REASONING BLOCK
                       Shown above the message text when HasReasoning = true.
                       Collapsed by default; toggled by tapping the label.
                       ───────────────────────────────────────────────────── -->
                  <VerticalStackLayout IsVisible="{Binding HasReasoning}"
                                       Margin="8,4,8,0"
                                       Spacing="0">
                    <!-- Toggle label — "Show thinking" / "Hide thinking" -->
                    <Label Text="{Binding IsReasoningExpanded, Converter={StaticResource BoolToReasoningLabelConverter}}"
                           FontFamily="InterMedium"
                           FontSize="{StaticResource FontSizeFootnote}"
                           TextColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight},
                                                       Dark={StaticResource ColorPrimaryDark}}"
                           Margin="4,0"
                           AutomationId="ReasoningToggleLabel"
                           SemanticProperties.Hint="Toggle AI reasoning visibility">
                      <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleReasoningCommand}" />
                      </Label.GestureRecognizers>
                    </Label>
                    <!-- Reasoning text — shown when IsReasoningExpanded = true -->
                    <Border IsVisible="{Binding IsReasoningExpanded}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight},
                                                             Dark={StaticResource ColorSurfaceSecondaryDark}}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 6"
                            Padding="{StaticResource SpacingSm}"
                            Margin="0,4,0,0">
                      <Label Text="{Binding ReasoningText, FallbackValue='', TargetNullValue=''}"
                             FontFamily="InterRegular"
                             FontSize="{StaticResource FontSizeFootnote}"
                             FontAttributes="Italic"
                             TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                                         Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                             LineBreakMode="WordWrap" />
                    </Border>
                  </VerticalStackLayout>

                  <!-- ─────────────────────────────────────────────────────
                       EXISTING MESSAGE BLOCK (unchanged)
                       Hidden when MessageKind == QuestionRequest so the
                       question card below takes over the rendering slot.
                       ───────────────────────────────────────────────────── -->
                  <controls:MessageBlockView
                      TextContent="{Binding TextContent}"
                      IsFromUser="{Binding IsFromUser}"
                      Timestamp="{Binding Timestamp}"
                      DeliveryStatus="{Binding DeliveryStatus}"
                      IsFirstInGroup="{Binding IsFirstInGroup}"
                      IsLastInGroup="{Binding IsLastInGroup}"
                      IsStreaming="{Binding IsStreaming}"
                      SenderType="{Binding SenderType}"
                      SenderName="{Binding SenderName}"
                      MessageKind="{Binding MessageKind}"
                      PermissionType="{Binding PermissionType}"
                      PermissionPatterns="{Binding PermissionPatterns}"
                      RequestId="{Binding RequestId}"
                      PermissionStatus="{Binding PermissionStatus}"
                      ResolvedReply="{Binding ResolvedReply}"
                      ResolvedReplyLabel="{Binding ResolvedReplyLabel}">
                    <controls:MessageBlockView.Triggers>
                      <DataTrigger TargetType="controls:MessageBlockView"
                                   Binding="{Binding MessageKind}"
                                   Value="{x:Static models:MessageKind.QuestionRequest}">
                        <Setter Property="IsVisible" Value="False" />
                      </DataTrigger>
                    </controls:MessageBlockView.Triggers>
                  </controls:MessageBlockView>

                  <!-- ─────────────────────────────────────────────────────
                       [REQ-016] QUESTION CARD — Compact inline row
                       Shown when MessageKind == QuestionRequest.
                       Single-line row with icon, truncated text, and Open button.
                       Full interaction (option chips, free-text) is in the
                       QuestionSheet bottom sheet popup.
                       Hidden by default; DataTrigger makes it visible.
                       ───────────────────────────────────────────────────── -->
                  <Border IsVisible="False"
                          StrokeShape="RoundRectangle 12"
                          StrokeThickness="1"
                          Stroke="{AppThemeBinding Light={StaticResource ColorPrimaryLight},
                                                    Dark={StaticResource ColorPrimaryDark}}"
                          BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight},
                                                            Dark={StaticResource ColorSurfaceSecondaryDark}}"
                          Padding="12,10"
                          Margin="8,4"
                          AutomationId="QuestionCard"
                          SemanticProperties.Description="Question from AI assistant">
                    <Border.Triggers>
                      <DataTrigger TargetType="Border"
                                   Binding="{Binding MessageKind}"
                                   Value="{x:Static models:MessageKind.QuestionRequest}">
                        <Setter Property="IsVisible" Value="True" />
                      </DataTrigger>
                    </Border.Triggers>

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="{StaticResource SpacingSm}">

                      <!-- Question icon -->
                      <Label Grid.Column="0"
                             Text="{x:Static helpers:IconKeys.QuestionMark}"
                             FontFamily="{StaticResource TablerIconsFont}"
                             FontSize="18"
                             TextColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight},
                                                         Dark={StaticResource ColorPrimaryDark}}"
                             VerticalOptions="Center"
                             SemanticProperties.Description="Question icon" />

                      <!-- Question text (truncated) + resolved answer -->
                      <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <!-- Pending state: truncated question text -->
                        <Label Text="{Binding QuestionText, FallbackValue='', TargetNullValue=''}"
                               FontFamily="InterMedium"
                               FontSize="{StaticResource FontSizeSubheadline}"
                               TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight},
                                                           Dark={StaticResource ColorOnBackgroundDark}}"
                               LineBreakMode="TailTruncation"
                               MaxLines="1">
                          <Label.Triggers>
                            <DataTrigger TargetType="Label"
                                         Binding="{Binding QuestionStatus}"
                                         Value="{x:Static models:QuestionStatus.Resolved}">
                              <Setter Property="IsVisible" Value="False" />
                            </DataTrigger>
                          </Label.Triggers>
                        </Label>
                        <!-- Resolved state: show answer -->
                        <Label Text="{Binding ResolvedAnswer, StringFormat='&#x2713; {0}', FallbackValue='', TargetNullValue=''}"
                               FontFamily="InterMedium"
                               FontSize="{StaticResource FontSizeSubheadline}"
                               TextColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight},
                                                           Dark={StaticResource ColorPrimaryDark}}"
                               LineBreakMode="TailTruncation"
                               MaxLines="1"
                               IsVisible="False"
                               AutomationId="QuestionResolvedLabel"
                               SemanticProperties.Description="Resolved answer">
                          <Label.Triggers>
                            <DataTrigger TargetType="Label"
                                         Binding="{Binding QuestionStatus}"
                                         Value="{x:Static models:QuestionStatus.Resolved}">
                              <Setter Property="IsVisible" Value="True" />
                            </DataTrigger>
                          </Label.Triggers>
                        </Label>
                      </VerticalStackLayout>

                      <!-- Open button (pending) — opens the question bottom sheet -->
                      <Button Grid.Column="2"
                              Text="Open"
                              FontFamily="InterSemiBold"
                              FontSize="{StaticResource FontSizeCaption1}"
                              TextColor="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight},
                                                           Dark={StaticResource ColorOnPrimaryDark}}"
                              BackgroundColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight},
                                                                 Dark={StaticResource ColorPrimaryDark}}"
                              CornerRadius="14"
                              Padding="12,6"
                              MinimumHeightRequest="32"
                              VerticalOptions="Center"
                              Command="{Binding BindingContext.OpenQuestionSheetCommand, Source={x:Reference ChatPageRoot}}"
                              CommandParameter="{Binding QuestionId}"
                              AutomationId="QuestionOpenButton"
                              SemanticProperties.Description="Open question sheet">
                        <Button.Triggers>
                          <DataTrigger TargetType="Button"
                                       Binding="{Binding QuestionStatus}"
                                       Value="{x:Static models:QuestionStatus.Resolved}">
                            <Setter Property="IsVisible" Value="False" />
                          </DataTrigger>
                        </Button.Triggers>
                      </Button>

                    </Grid>
                  </Border>

                  <!-- ─────────────────────────────────────────────────────
                       [REQ-019] TOOL CALL CARDS
                       Shown below the message bubble when HasToolCalls = true.
                       Uses BindableLayout (not nested CollectionView).
                       ───────────────────────────────────────────────────── -->
                  <VerticalStackLayout IsVisible="{Binding HasToolCalls}"
                                       Margin="8,4,8,0"
                                       Spacing="4">
                    <BindableLayout.ItemsSource>
                      <Binding Path="ToolCalls" />
                    </BindableLayout.ItemsSource>
                    <BindableLayout.ItemTemplate>
                      <DataTemplate x:DataType="models:ToolCallInfo">
                        <Border StrokeShape="RoundRectangle 6"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource ColorOutlineLight},
                                                        Dark={StaticResource ColorOutlineDark}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight},
                                                                 Dark={StaticResource ColorSurfaceSecondaryDark}}"
                                Padding="8,6"
                                IsVisible="{Binding IsHidden, Converter={StaticResource InvertedBoolConverter}}">
                          <Grid ColumnDefinitions="20,*,Auto"
                                ColumnSpacing="8">

                            <!-- Status indicator column — only one of these three is visible at a time -->
                            <ActivityIndicator Grid.Column="0"
                                               IsRunning="True"
                                               IsVisible="{Binding Status, Converter={StaticResource ToolCallStatusToLoadingConverter}}"
                                               WidthRequest="16"
                                               HeightRequest="16"
                                               Color="{AppThemeBinding Light={StaticResource ColorPrimaryLight},
                                                                      Dark={StaticResource ColorPrimaryDark}}"
                                               VerticalOptions="Center"
                                               SemanticProperties.Description="Tool call in progress" />
                            <Label Grid.Column="0"
                                   IsVisible="{Binding Status, Converter={StaticResource ToolCallStatusToCompletedConverter}}"
                                   Text="✓"
                                   FontSize="{StaticResource FontSizeFootnote}"
                                   TextColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight},
                                                              Dark={StaticResource ColorPrimaryDark}}"
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center"
                                   SemanticProperties.Description="Tool call completed" />
                            <Label Grid.Column="0"
                                   IsVisible="{Binding Status, Converter={StaticResource ToolCallStatusToErrorConverter}}"
                                   Text="✕"
                                   FontSize="{StaticResource FontSizeFootnote}"
                                   TextColor="{AppThemeBinding Light={StaticResource ColorErrorLight},
                                                              Dark={StaticResource ColorErrorDark}}"
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center"
                                   SemanticProperties.Description="Tool call failed" />

                            <!-- Tool name + title + output + error -->
                            <VerticalStackLayout Grid.Column="1"
                                                Spacing="2">
                              <Label Text="{Binding ToolName, FallbackValue='', TargetNullValue=''}"
                                     FontFamily="InterSemiBold"
                                     FontSize="{StaticResource FontSizeCaption1}"
                                     TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight},
                                                                Dark={StaticResource ColorOnBackgroundDark}}"
                                     LineBreakMode="TailTruncation" />
                              <Label Text="{Binding Title, FallbackValue='', TargetNullValue=''}"
                                     IsVisible="{Binding Title, Converter={StaticResource NullToVisibilityConverter}}"
                                     FontFamily="InterRegular"
                                     FontSize="{StaticResource FontSizeCaption1}"
                                     TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight},
                                                                Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                                     LineBreakMode="TailTruncation" />
                              <Label Text="{Binding Output, FallbackValue='', TargetNullValue=''}"
                                     IsVisible="{Binding Output, Converter={StaticResource NullToVisibilityConverter}}"
                                     FontFamily="InterRegular"
                                     FontSize="{StaticResource FontSizeCaption1}"
                                     TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight},
                                                                Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                                     LineBreakMode="WordWrap"
                                     MaxLines="3" />
                              <Label Text="{Binding ErrorText, FallbackValue='', TargetNullValue=''}"
                                     IsVisible="{Binding ErrorText, Converter={StaticResource NullToVisibilityConverter}}"
                                     FontFamily="InterRegular"
                                     FontSize="{StaticResource FontSizeCaption1}"
                                     TextColor="{AppThemeBinding Light={StaticResource ColorErrorLight},
                                                                Dark={StaticResource ColorErrorDark}}"
                                     LineBreakMode="WordWrap" />
                            </VerticalStackLayout>

                            <!-- Duration (ms) — shown only when available -->
                            <Label Grid.Column="2"
                                   IsVisible="{Binding DurationMs, Converter={StaticResource NullToVisibilityConverter}}"
                                   Text="{Binding DurationMs, StringFormat='{0}ms', FallbackValue='', TargetNullValue=''}"
                                   FontFamily="InterRegular"
                                   FontSize="{StaticResource FontSizeCaption1}"
                                   TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                                              Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                                   VerticalOptions="Start" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </BindableLayout.ItemTemplate>
                  </VerticalStackLayout>

                  <!-- ─────────────────────────────────────────────────────
                       [REQ-026] STEP INDICATOR
                       Shown below the message bubble when StepCount > 0.
                       Displays step count and optional last-step cost.
                       ───────────────────────────────────────────────────── -->
                  <HorizontalStackLayout IsVisible="{Binding StepCount, Converter={StaticResource IntToBoolConverter}}"
                                         Spacing="4"
                                         Margin="12,2,8,4">
                    <Label FontFamily="InterRegular"
                           FontSize="{StaticResource FontSizeCaption1}"
                           TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                                       Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                           Text="{Binding StepCount, StringFormat='{0} steps'}" />
                     <Label FontFamily="InterRegular"
                            FontSize="{StaticResource FontSizeCaption1}"
                            TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                                        Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                            IsVisible="{Binding LastStepCost, Converter={StaticResource NullToVisibilityConverter}}"
                            Text="·" />
                    <Label FontFamily="InterRegular"
                           FontSize="{StaticResource FontSizeCaption1}"
                           TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                                       Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                           IsVisible="{Binding LastStepCost, Converter={StaticResource NullToVisibilityConverter}}"
                           Text="{Binding LastStepCost, StringFormat='${0:F4}', FallbackValue='', TargetNullValue=''}" />
                  </HorizontalStackLayout>

                </VerticalStackLayout>
                <!-- End standard message content -->

              </VerticalStackLayout>
              <!-- End normal message content -->

            </VerticalStackLayout>
          </DataTemplate>
        </CollectionView.ItemTemplate>
      </CollectionView>

      <!-- ─────────────────────────────────────────────────────────────
           Row 1: Typing Indicator — visible when IsAiResponding = true
           Positioned below the last message, left-aligned like an AI bubble.
           ───────────────────────────────────────────────────────────── -->
      <Grid Grid.Row="1"
            x:Name="TypingIndicatorRow"
            IsVisible="{Binding IsAiResponding}"
            ColumnDefinitions="Auto,Auto"
            ColumnSpacing="{StaticResource SpacingSm}"
            HorizontalOptions="Start"
            Padding="{StaticResource SpacingSm}"
            AutomationId="TypingIndicator"
            SemanticProperties.Description="AI assistant is typing">

        <!-- Avatar (matches MessageBlockView avatar size) -->
        <Border Grid.Column="0"
                WidthRequest="{StaticResource SizeAvatarSmall}"
                HeightRequest="{StaticResource SizeAvatarSmall}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight},
                                                 Dark={StaticResource ColorSurfaceSecondaryDark}}"
                VerticalOptions="End"
                Padding="0">
          <Label Text="{x:Static helpers:IconKeys.Robot}"
                 FontFamily="{StaticResource TablerIconsFont}"
                 FontSize="{StaticResource FontSizeCallout}"
                 TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight},
                                             Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                 HorizontalOptions="Center"
                 VerticalOptions="Center"
                 SemanticProperties.Description="AI assistant" />
        </Border>

        <!-- Bubble with three pulsing dots -->
        <Border Grid.Column="1"
                Style="{StaticResource MessageBubbleReceivedBorder}"
                VerticalOptions="End">
          <HorizontalStackLayout Spacing="{StaticResource SpacingXs}"
                                 Padding="0,2,0,2">
            <Ellipse x:Name="TypingDot1"
                     WidthRequest="6"
                     HeightRequest="6"
                     Fill="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                           Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                     Opacity="0.3" />
            <Ellipse x:Name="TypingDot2"
                     WidthRequest="6"
                     HeightRequest="6"
                     Fill="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                           Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                     Opacity="0.3" />
            <Ellipse x:Name="TypingDot3"
                     WidthRequest="6"
                     HeightRequest="6"
                     Fill="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                           Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                     Opacity="0.3" />
          </HorizontalStackLayout>
        </Border>

      </Grid>

      <!-- ═══════════════════════════════════════════════════════════
           FAB — Floating Action Button overlay [REQ-001, REQ-002, REQ-003]
           Overlays the message area, bottom-right. Always visible and
           tappable, even during streaming [REQ-005].
           ═══════════════════════════════════════════════════════════ -->
      <Border Grid.RowSpan="2"
              ZIndex="1"
              WidthRequest="56"
              HeightRequest="56"
              StrokeThickness="0"
              BackgroundColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight},
                                                Dark={StaticResource ColorPrimaryDark}}"
              HorizontalOptions="End"
              VerticalOptions="End"
              Margin="0,0,16,16"
              AutomationId="ComposerFabButton"
              SemanticProperties.Description="Open message composer">
        <Border.StrokeShape>
          <RoundRectangle CornerRadius="28" />
        </Border.StrokeShape>
        <Border.Shadow>
          <Shadow Brush="Black"
                  Opacity="0.3"
                  Offset="0,4"
                  Radius="8" />
        </Border.Shadow>
        <Border.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding OpenMessageComposerCommand}" />
        </Border.GestureRecognizers>
        <Image HorizontalOptions="Center"
               VerticalOptions="Center"
               WidthRequest="24"
               HeightRequest="24">
          <Image.Source>
            <FontImageSource FontFamily="TablerIcons"
                             Glyph="{x:Static helpers:IconKeys.Robot}"
                             Size="{StaticResource FontSizeIconXl}"
                             Color="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight},
                                                      Dark={StaticResource ColorOnPrimaryDark}}" />
          </Image.Source>
        </Image>
      </Border>

    </Grid>

    <!-- ═══════════════════════════════════════════════════════════════
         ROW 3 — Subagent indicator (REQ-032)
         ═══════════════════════════════════════════════════════════════ -->
    <controls:SubagentIndicatorView Grid.Row="3"
                                    SubagentName="{Binding SubagentName}"
                                    IsActive="{Binding IsSubagentActive}"
                                    StatusText="Working..."
                                    IsVisible="{Binding IsSubagentActive}" />

    <!-- ═══════════════════════════════════════════════════════════════
         ROW 4 — Error banner + Suggestion chips
         ═══════════════════════════════════════════════════════════════ -->
    <VerticalStackLayout Grid.Row="4" Spacing="0">

      <!-- Pending Permissions Indicator — visible when HasPendingPermissions = true -->
      <Border IsVisible="{Binding HasPendingPermissions}"
              BackgroundColor="{AppThemeBinding Light={StaticResource ColorPrimaryContainerLight},
                                               Dark={StaticResource ColorPrimaryContainerDark}}"
              StrokeThickness="0"
              StrokeShape="RoundRectangle 0"
              Padding="{StaticResource SpacingMd}">
        <Label Text="Permission request pending — chat remains available"
               FontFamily="InterRegular"
               FontSize="{StaticResource FontSizeFootnote}"
               TextColor="{AppThemeBinding Light={StaticResource ColorOnPrimaryContainerLight},
                                           Dark={StaticResource ColorOnPrimaryContainerDark}}" />
      </Border>

      <!-- Error Banner — visible when HasError = true -->
      <Border IsVisible="{Binding HasError}"
              BackgroundColor="{AppThemeBinding Light={StaticResource ColorErrorContainerLight},
                                               Dark={StaticResource ColorErrorContainerDark}}"
              StrokeThickness="0"
              StrokeShape="RoundRectangle 0"
              Padding="{StaticResource SpacingMd}">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource SpacingSm}">
          <Label Grid.Column="0"
                 Text="{Binding ErrorMessage, FallbackValue='', TargetNullValue=''}"
                 FontFamily="InterRegular"
                 FontSize="{StaticResource FontSizeFootnote}"
                 TextColor="{AppThemeBinding Light={StaticResource ColorOnErrorContainerLight},
                                             Dark={StaticResource ColorOnErrorContainerDark}}"
                 VerticalOptions="Center"
                 LineBreakMode="WordWrap" />
          <ImageButton Grid.Column="1"
                       Command="{Binding DismissErrorCommand}"
                       WidthRequest="{StaticResource MinTouchTarget}"
                       HeightRequest="{StaticResource MinTouchTarget}"
                       BackgroundColor="Transparent"
                       AutomationId="DismissErrorButton"
                       SemanticProperties.Description="Dismiss error">
            <ImageButton.Source>
              <FontImageSource FontFamily="TablerIcons"
                               Glyph="{x:Static helpers:IconKeys.X}"
                               Size="{StaticResource FontSizeIconXl}"
                               Color="{AppThemeBinding Light={StaticResource ColorOnErrorContainerLight},
                                                        Dark={StaticResource ColorOnErrorContainerDark}}" />
            </ImageButton.Source>
          </ImageButton>
        </Grid>
      </Border>

    </VerticalStackLayout>

    <!-- ═══════════════════════════════════════════════════════════════
         ROW 5 — Connection Footer (REQ-004, REQ-013)
         Always-visible footer: active server name + traffic-light dot.
         ═══════════════════════════════════════════════════════════════ -->
    <controls:ConnectionFooterView Grid.Row="5" />

  </Grid>

</ContentPage>
