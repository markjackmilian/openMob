<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
             x:Class="openMob.Views.Pages.SplashPage"
             x:DataType="vm:SplashViewModel"
             Shell.NavBarIsVisible="False"
              Shell.FlyoutBehavior="Disabled"
              BackgroundColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}">

  <VerticalStackLayout
      VerticalOptions="Center"
      HorizontalOptions="Center"
      Spacing="{StaticResource SpacingXl}">

    <!-- App logo placeholder -->
    <Border
        WidthRequest="80"
        HeightRequest="80"
        StrokeShape="RoundRectangle 16"
        StrokeThickness="0"
        BackgroundColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}"
        Padding="0"
        HorizontalOptions="Center">
      <Label
          Text="oM"
          FontFamily="InterBold"
          FontSize="{StaticResource FontSizeTitle1}"
          TextColor="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight}, Dark={StaticResource ColorOnPrimaryDark}}"
          HorizontalOptions="Center"
          VerticalOptions="Center" />
    </Border>

    <!-- App name -->
    <Label
        Text="openMob"
        FontFamily="InterBold"
        FontSize="{StaticResource FontSizeTitle1}"
        TextColor="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight}, Dark={StaticResource ColorOnPrimaryDark}}"
        HorizontalTextAlignment="Center" />

    <!-- Loading indicator -->
    <ActivityIndicator
        IsRunning="{Binding IsLoading}"
        IsVisible="{Binding IsLoading}"
        Color="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight}, Dark={StaticResource ColorOnPrimaryDark}}"
        HorizontalOptions="Center"
        AutomationId="SplashLoadingIndicator" />

    <!-- Status message — visible only when StatusMessage is non-empty (REQ-012) -->
    <Label
        Text="{Binding StatusMessage, FallbackValue='', TargetNullValue=''}"
        FontFamily="InterRegular"
        FontSize="{StaticResource FontSizeFootnote}"
        TextColor="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight},
                                    Dark={StaticResource ColorOnPrimaryDark}}"
        HorizontalTextAlignment="Center"
        AutomationId="SplashStatusMessage">
      <Label.Triggers>
        <DataTrigger TargetType="Label"
                     Binding="{Binding StatusMessage}"
                     Value="">
          <Setter Property="IsVisible" Value="False" />
        </DataTrigger>
      </Label.Triggers>
    </Label>

  </VerticalStackLayout>

</ContentPage>
