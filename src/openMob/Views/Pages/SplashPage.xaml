<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
             x:Class="openMob.Views.Pages.SplashPage"
             x:DataType="vm:SplashViewModel"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled">

  <VerticalStackLayout
      VerticalOptions="Center"
      HorizontalOptions="Center"
      Spacing="{StaticResource SpacingXl}">

    <!-- App logo placeholder -->
    <Border
        WidthRequest="80"
        HeightRequest="80"
        StrokeShape="RoundRectangle 16"
        StrokeThickness="0"
        BackgroundColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}"
        Padding="0"
        HorizontalOptions="Center">
      <Label
          Text="oM"
          FontFamily="InterBold"
          FontSize="{StaticResource FontSizeTitle1}"
          TextColor="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight}, Dark={StaticResource ColorOnPrimaryDark}}"
          HorizontalOptions="Center"
          VerticalOptions="Center" />
    </Border>

    <!-- App name -->
    <Label
        Text="openMob"
        FontFamily="InterBold"
        FontSize="{StaticResource FontSizeTitle1}"
        TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}"
        HorizontalTextAlignment="Center" />

    <!-- Loading indicator -->
    <ActivityIndicator
        IsRunning="{Binding IsLoading}"
        IsVisible="{Binding IsLoading}"
        HorizontalOptions="Center"
        AutomationId="SplashLoadingIndicator" />

  </VerticalStackLayout>

</ContentPage>
