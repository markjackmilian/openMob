<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:openMob.Converters"
             xmlns:uxd="clr-namespace:UXDivers.Popups.Maui.Controls;assembly=UXDivers.Popups.Maui"
             x:Class="openMob.App">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
        <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
        <uxd:DarkTheme />
        <uxd:PopupStyles />
      </ResourceDictionary.MergedDictionaries>

      <!-- Global value converters -->
      <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
      <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
      <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
      <converters:StepToVisibilityConverter x:Key="StepToVisibilityConverter" />
      <converters:DateTimeToRelativeStringConverter x:Key="DateTimeToRelativeStringConverter" />
      <converters:MessageStatusToIconConverter x:Key="MessageStatusToIconConverter" />
      <converters:IntToBoolConverter x:Key="IntToBoolConverter" />
      <converters:BoolToReasoningLabelConverter x:Key="BoolToReasoningLabelConverter" />
      <converters:ToolCallStatusToLoadingConverter x:Key="ToolCallStatusToLoadingConverter" />
      <converters:ToolCallStatusToCompletedConverter x:Key="ToolCallStatusToCompletedConverter" />
      <converters:ToolCallStatusToErrorConverter x:Key="ToolCallStatusToErrorConverter" />
    </ResourceDictionary>
  </Application.Resources>
</Application>
