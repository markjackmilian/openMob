<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:openMob.Views.Controls"
             x:Class="openMob.Views.Controls.SuggestionChipView"
             x:Name="this"
             x:DataType="controls:SuggestionChipView">

  <Border Style="{StaticResource SuggestionChipBorder}"
          MinimumWidthRequest="200"
          MaximumWidthRequest="280">
    <Border.GestureRecognizers>
      <TapGestureRecognizer Command="{Binding TapCommand, Source={x:Reference this}}"
                            CommandParameter="{Binding CommandParameter, Source={x:Reference this}}" />
    </Border.GestureRecognizers>

    <VerticalStackLayout Spacing="{StaticResource SpacingXs}">

      <!-- Title -->
      <Label Text="{Binding Title, Source={x:Reference this}, FallbackValue=''}"
             FontFamily="InterSemiBold"
             FontSize="{StaticResource FontSizeCallout}"
             TextColor="{AppThemeBinding Light={StaticResource ColorOnSurfaceLight},
                                         Dark={StaticResource ColorOnSurfaceDark}}"
             LineBreakMode="TailTruncation"
             MaxLines="1" />

      <!-- Subtitle -->
      <Label Text="{Binding Subtitle, Source={x:Reference this}, FallbackValue=''}"
             FontFamily="InterRegular"
             FontSize="{StaticResource FontSizeCallout}"
             TextColor="{AppThemeBinding Light={StaticResource ColorOnSurfaceSecondaryLight},
                                         Dark={StaticResource ColorOnSurfaceSecondaryDark}}"
             LineBreakMode="TailTruncation"
             MaxLines="1" />

    </VerticalStackLayout>
  </Border>

</ContentView>
