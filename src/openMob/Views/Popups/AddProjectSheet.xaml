<?xml version="1.0" encoding="utf-8" ?>
<uxd:PopupPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:uxd="clr-namespace:UXDivers.Popups.Maui;assembly=UXDivers.Popups.Maui"
               xmlns:vm="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
               xmlns:helpers="clr-namespace:openMob.Helpers"
               x:Class="openMob.Views.Popups.AddProjectSheet"
               x:DataType="vm:AddProjectViewModel"
               BackgroundColor="{DynamicResource PopupBackdropColor}"
               CloseWhenBackgroundIsClicked="True"
               AppearingAnimation="{uxd:FadeInPopupAnimation Duration=300}"
               DisappearingAnimation="{uxd:FadeOutPopupAnimation Duration=300}">

  <VerticalStackLayout Spacing="0">

    <!-- Handle bar -->
    <BoxView
        Style="{StaticResource SheetHandleBar}"
        Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" />

    <!-- Header with title and close button -->
    <Grid ColumnDefinitions="*,Auto"
          Padding="16,0,16,16">
      <Label
          Grid.Column="0"
          Text="New Project"
          Style="{StaticResource Title3Label}"
          VerticalOptions="Center" />
      <ImageButton
          Grid.Column="1"
          Clicked="OnCloseButtonTapped"
          MinimumHeightRequest="{StaticResource MinTouchTarget}"
          MinimumWidthRequest="{StaticResource MinTouchTarget}"
          BackgroundColor="Transparent"
          AutomationId="AddProjectCloseButton"
          SemanticProperties.Description="Close add project sheet">
        <ImageButton.Source>
          <FontImageSource FontFamily="TablerIcons"
                           Glyph="{x:Static helpers:IconKeys.X}"
                           Size="{StaticResource FontSizeIconXl}"
                           Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight},
                                                    Dark={StaticResource ColorOnBackgroundDark}}" />
        </ImageButton.Source>
      </ImageButton>
    </Grid>

    <!-- Form fields -->
    <VerticalStackLayout Spacing="{StaticResource SpacingLg}" Padding="16,0">

      <!-- Project Name -->
      <VerticalStackLayout Spacing="{StaticResource SpacingXs}">
        <Label
            Text="Project Name"
            FontFamily="InterMedium"
            FontSize="{StaticResource FontSizeSubheadline}"
            TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
        <Entry
            Text="{Binding ProjectName, Mode=TwoWay}"
            Placeholder="My Project"
            Style="{StaticResource OutlinedEntry}"
            FontFamily="InterRegular"
            AutomationId="AddProjectNameEntry"
            SemanticProperties.Hint="Enter the project name" />
      </VerticalStackLayout>

      <!-- Project Path -->
      <VerticalStackLayout Spacing="{StaticResource SpacingXs}">
        <Label
            Text="Project Path"
            FontFamily="InterMedium"
            FontSize="{StaticResource FontSizeSubheadline}"
            TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
        <Entry
            Text="{Binding ProjectPath, Mode=TwoWay}"
            Placeholder="/path/to/project"
            Style="{StaticResource OutlinedEntry}"
            FontFamily="InterRegular"
            AutomationId="AddProjectPathEntry"
            SemanticProperties.Hint="Enter the project directory path" />
      </VerticalStackLayout>

      <!-- Buttons -->
      <Grid
          ColumnDefinitions="*,*"
          ColumnSpacing="{StaticResource SpacingMd}"
          Margin="0,8,0,16">
        <Button
            Grid.Column="0"
            Text="Cancel"
            Command="{Binding CancelCommand}"
            Style="{StaticResource SecondaryButton}"
            AutomationId="AddProjectCancelButton" />
        <Button
            Grid.Column="1"
            Text="Add"
            Command="{Binding AddProjectCommand}"
            IsEnabled="{Binding CanAdd}"
            Style="{StaticResource PrimaryButton}"
            AutomationId="AddProjectAddButton" />
      </Grid>

    </VerticalStackLayout>

  </VerticalStackLayout>

</uxd:PopupPage>
