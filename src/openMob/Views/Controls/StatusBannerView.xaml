<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:openMob.Views.Controls"
             x:Class="openMob.Views.Controls.StatusBannerView"
             x:Name="ThisView"
             x:DataType="controls:StatusBannerView">

  <Border
      x:Name="BannerContainer"
      StrokeThickness="0"
      StrokeShape="RoundRectangle 0"
      Padding="{StaticResource SpacingMd}">
    <Grid ColumnDefinitions="*,Auto">

      <Label
          Grid.Column="0"
          Text="{Binding Message, Source={x:Reference ThisView}, FallbackValue='', TargetNullValue=''}"
          FontSize="{StaticResource FontSizeFootnote}"
          VerticalOptions="Center"
          TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" />

      <Button
          Grid.Column="1"
          Text="{Binding ActionLabel, Source={x:Reference ThisView}, FallbackValue='', TargetNullValue=''}"
          Command="{Binding ActionCommand, Source={x:Reference ThisView}}"
          IsVisible="{Binding ActionLabel, Source={x:Reference ThisView}, Converter={StaticResource NullToVisibilityConverter}}"
          Style="{StaticResource TertiaryButton}"
          FontSize="{StaticResource FontSizeFootnote}"
          Padding="8,0"
          MinimumHeightRequest="32"
          VerticalOptions="Center" />

    </Grid>
  </Border>

</ContentView>
