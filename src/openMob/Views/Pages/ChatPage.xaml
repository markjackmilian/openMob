<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:openMob.Helpers"
             xmlns:controls="clr-namespace:openMob.Views.Controls"
             xmlns:models="clr-namespace:openMob.Core.Models;assembly=openMob.Core"
             xmlns:viewmodels="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
             x:Class="openMob.Views.Pages.ChatPage"
             x:Name="ChatPageRoot"
             x:DataType="viewmodels:ChatViewModel"
             Shell.NavBarIsVisible="False">

  <!-- ChatPage uses edge-to-edge layout for the message list (standard chat UI pattern).
       Horizontal padding is applied to the input bar and header, not the message area. -->
  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto">

    <!-- ═══════════════════════════════════════════════════════════════
         ROW 0 — Header
         Primary-colored bar with white icons and compact title
         ═══════════════════════════════════════════════════════════════ -->
    <Grid Grid.Row="0"
          ColumnDefinitions="Auto,*,Auto"
          HeightRequest="48"
          Padding="4,0"
          BackgroundColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight},
                                            Dark={StaticResource ColorPrimaryDark}}">

      <!-- Hamburger button (left) -->
      <ImageButton Grid.Column="0"
                   x:Name="HamburgerButton"
                   Clicked="OnHamburgerClicked"
                   WidthRequest="40"
                   HeightRequest="40"
                   BackgroundColor="Transparent"
                   AutomationId="ChatHamburgerButton"
                   SemanticProperties.Description="Open navigation menu">
        <ImageButton.Source>
          <FontImageSource FontFamily="TablerIcons"
                           Glyph="{x:Static helpers:IconKeys.Menu}"
                           Size="20"
                           Color="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight},
                                                    Dark={StaticResource ColorOnPrimaryDark}}" />
        </ImageButton.Source>
      </ImageButton>

      <!-- Center: Session name (tappable to rename) -->
      <Label Grid.Column="1"
             Text="{Binding SessionName, FallbackValue='New chat'}"
             FontFamily="InterSemiBold"
             FontSize="{StaticResource FontSizeSubheadline}"
             TextColor="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight},
                                          Dark={StaticResource ColorOnPrimaryDark}}"
             HorizontalTextAlignment="Center"
             VerticalTextAlignment="Center"
             HorizontalOptions="Center"
             VerticalOptions="Center"
             LineBreakMode="TailTruncation"
             MaximumWidthRequest="220"
             AutomationId="ChatSessionName">
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding RenameSessionCommand}" />
        </Label.GestureRecognizers>
      </Label>

      <!-- Context icon (right) — opens Context Sheet -->
      <ImageButton Grid.Column="2"
                   Command="{Binding OpenContextSheetCommand}"
                   WidthRequest="40"
                   HeightRequest="40"
                   BackgroundColor="Transparent"
                   AutomationId="ChatContextButton"
                   SemanticProperties.Description="Open context settings">
        <ImageButton.Source>
          <FontImageSource FontFamily="TablerIcons"
                           Glyph="{x:Static helpers:IconKeys.Adjustments}"
                           Size="20"
                           Color="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight},
                                                    Dark={StaticResource ColorOnPrimaryDark}}" />
        </ImageButton.Source>
      </ImageButton>

    </Grid>

    <!-- ═══════════════════════════════════════════════════════════════
         ROW 1 — Context Status Bar (REQ-019 through REQ-022)
         ═══════════════════════════════════════════════════════════════ -->
    <controls:ContextStatusBarView Grid.Row="1"
                                    x:Name="ContextStatusBar"
                                    ProjectName="{Binding ProjectName}"
                                    ModelName="{Binding SelectedModelName, TargetNullValue='No model', FallbackValue='No model'}"
                                    ThinkingLevel="{Binding ThinkingLevel}"
                                    TapCommand="{Binding OpenContextSheetCommand}" />

    <!-- ═══════════════════════════════════════════════════════════════
         ROW 2 — Status Banner (existing, unchanged)
         ═══════════════════════════════════════════════════════════════ -->
    <controls:StatusBannerView Grid.Row="2"
                               IsVisible="{Binding StatusBanner, Converter={StaticResource NullToVisibilityConverter}}"
                               Message="{Binding StatusBanner.Message, FallbackValue='', TargetNullValue=''}"
                               ActionLabel="{Binding StatusBanner.ActionLabel, FallbackValue='', TargetNullValue=''}"
                               ActionCommand="{Binding NavigateToServerManagementCommand}"
                               BannerType="{Binding StatusBanner.Type, FallbackValue=None}" />

    <!-- ═══════════════════════════════════════════════════════════════
         ROW 3 — Message area (star row) + FAB overlay
         ═══════════════════════════════════════════════════════════════ -->
    <Grid Grid.Row="3"
          RowDefinitions="*,Auto"
          BackgroundColor="{AppThemeBinding Light={StaticResource ColorBackgroundLight},
                                            Dark={StaticResource ColorBackgroundDark}}">

      <!-- Empty State — visible when IsEmpty = true -->
      <controls:EmptyStateView Grid.Row="0"
                               IsVisible="{Binding IsEmpty}"
                               Title="How can I help you?" />

      <!-- Message CollectionView — visible when IsEmpty = false -->
      <CollectionView Grid.Row="0"
                      x:Name="MessagesCollectionView"
                      ItemsSource="{Binding Messages}"
                      ItemsUpdatingScrollMode="KeepLastItemInView"
                      SelectionMode="None"
                      Scrolled="OnMessagesScrolled"
                      IsVisible="{Binding IsEmpty, Converter={StaticResource InvertedBoolConverter}}">
        <CollectionView.ItemTemplate>
           <DataTemplate x:DataType="models:ChatMessage">
              <controls:MessageBlockView
                  TextContent="{Binding TextContent}"
                  IsFromUser="{Binding IsFromUser}"
                  Timestamp="{Binding Timestamp}"
                  DeliveryStatus="{Binding DeliveryStatus}"
                  IsFirstInGroup="{Binding IsFirstInGroup}"
                  IsLastInGroup="{Binding IsLastInGroup}"
                  IsStreaming="{Binding IsStreaming}"
                  SenderType="{Binding SenderType}"
                  SenderName="{Binding SenderName}"
                  MessageKind="{Binding MessageKind}"
                  PermissionType="{Binding PermissionType}"
                  PermissionPatterns="{Binding PermissionPatterns}"
                  RequestId="{Binding RequestId}"
                  PermissionStatus="{Binding PermissionStatus}"
                  ResolvedReply="{Binding ResolvedReply}"
                  ResolvedReplyLabel="{Binding ResolvedReplyLabel}" />
           </DataTemplate>
        </CollectionView.ItemTemplate>
      </CollectionView>

      <!-- ─────────────────────────────────────────────────────────────
           Row 1: Typing Indicator — visible when IsAiResponding = true
           Positioned below the last message, left-aligned like an AI bubble.
           ───────────────────────────────────────────────────────────── -->
      <Grid Grid.Row="1"
            x:Name="TypingIndicatorRow"
            IsVisible="{Binding IsAiResponding}"
            ColumnDefinitions="Auto,Auto"
            ColumnSpacing="{StaticResource SpacingSm}"
            HorizontalOptions="Start"
            Padding="{StaticResource SpacingSm}"
            AutomationId="TypingIndicator"
            SemanticProperties.Description="AI assistant is typing">

        <!-- Avatar (matches MessageBlockView avatar size) -->
        <Border Grid.Column="0"
                WidthRequest="{StaticResource SizeAvatarSmall}"
                HeightRequest="{StaticResource SizeAvatarSmall}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight},
                                                 Dark={StaticResource ColorSurfaceSecondaryDark}}"
                VerticalOptions="End"
                Padding="0">
          <Label Text="{x:Static helpers:IconKeys.Robot}"
                 FontFamily="{StaticResource TablerIconsFont}"
                 FontSize="{StaticResource FontSizeCallout}"
                 TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight},
                                             Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                 HorizontalOptions="Center"
                 VerticalOptions="Center"
                 SemanticProperties.Description="AI assistant" />
        </Border>

        <!-- Bubble with three pulsing dots -->
        <Border Grid.Column="1"
                Style="{StaticResource MessageBubbleReceivedBorder}"
                VerticalOptions="End">
          <HorizontalStackLayout Spacing="{StaticResource SpacingXs}"
                                 Padding="0,2,0,2">
            <Ellipse x:Name="TypingDot1"
                     WidthRequest="6"
                     HeightRequest="6"
                     Fill="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                           Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                     Opacity="0.3" />
            <Ellipse x:Name="TypingDot2"
                     WidthRequest="6"
                     HeightRequest="6"
                     Fill="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                           Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                     Opacity="0.3" />
            <Ellipse x:Name="TypingDot3"
                     WidthRequest="6"
                     HeightRequest="6"
                     Fill="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                           Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                     Opacity="0.3" />
          </HorizontalStackLayout>
        </Border>

      </Grid>

      <!-- ═══════════════════════════════════════════════════════════
           FAB — Floating Action Button overlay [REQ-001, REQ-002, REQ-003]
           Overlays the message area, bottom-right. Always visible and
           tappable, even during streaming [REQ-005].
           ═══════════════════════════════════════════════════════════ -->
      <Border Grid.RowSpan="2"
              ZIndex="1"
              WidthRequest="56"
              HeightRequest="56"
              StrokeThickness="0"
              BackgroundColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight},
                                                Dark={StaticResource ColorPrimaryDark}}"
              HorizontalOptions="End"
              VerticalOptions="End"
              Margin="0,0,16,16"
              AutomationId="ComposerFabButton"
              SemanticProperties.Description="Open message composer">
        <Border.StrokeShape>
          <RoundRectangle CornerRadius="28" />
        </Border.StrokeShape>
        <Border.Shadow>
          <Shadow Brush="Black"
                  Opacity="0.3"
                  Offset="0,4"
                  Radius="8" />
        </Border.Shadow>
        <Border.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding OpenMessageComposerCommand}" />
        </Border.GestureRecognizers>
        <Image HorizontalOptions="Center"
               VerticalOptions="Center"
               WidthRequest="24"
               HeightRequest="24">
          <Image.Source>
            <FontImageSource FontFamily="TablerIcons"
                             Glyph="{x:Static helpers:IconKeys.Robot}"
                             Size="{StaticResource FontSizeIconXl}"
                             Color="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight},
                                                      Dark={StaticResource ColorOnPrimaryDark}}" />
          </Image.Source>
        </Image>
      </Border>

    </Grid>

    <!-- ═══════════════════════════════════════════════════════════════
         ROW 4 — Subagent indicator (REQ-032)
         ═══════════════════════════════════════════════════════════════ -->
    <controls:SubagentIndicatorView Grid.Row="4"
                                    SubagentName="{Binding SubagentName}"
                                    IsActive="{Binding IsSubagentActive}"
                                    StatusText="Working..."
                                    IsVisible="{Binding IsSubagentActive}" />

    <!-- ═══════════════════════════════════════════════════════════════
         ROW 5 — Error banner + Suggestion chips (existing, unchanged)
         ═══════════════════════════════════════════════════════════════ -->
    <VerticalStackLayout Grid.Row="5" Spacing="0">

      <!-- Pending Permissions Indicator — visible when HasPendingPermissions = true -->
      <Border IsVisible="{Binding HasPendingPermissions}"
              BackgroundColor="{AppThemeBinding Light={StaticResource ColorPrimaryContainerLight},
                                               Dark={StaticResource ColorPrimaryContainerDark}}"
              StrokeThickness="0"
              StrokeShape="RoundRectangle 0"
              Padding="{StaticResource SpacingMd}">
        <Label Text="Permission request pending — chat remains available"
               FontFamily="InterRegular"
               FontSize="{StaticResource FontSizeFootnote}"
               TextColor="{AppThemeBinding Light={StaticResource ColorOnPrimaryContainerLight},
                                           Dark={StaticResource ColorOnPrimaryContainerDark}}" />
      </Border>

      <!-- Error Banner — visible when HasError = true -->
      <Border IsVisible="{Binding HasError}"
              BackgroundColor="{AppThemeBinding Light={StaticResource ColorErrorContainerLight},
                                               Dark={StaticResource ColorErrorContainerDark}}"
              StrokeThickness="0"
              StrokeShape="RoundRectangle 0"
              Padding="{StaticResource SpacingMd}">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource SpacingSm}">
          <Label Grid.Column="0"
                 Text="{Binding ErrorMessage, FallbackValue='', TargetNullValue=''}"
                 FontFamily="InterRegular"
                 FontSize="{StaticResource FontSizeFootnote}"
                 TextColor="{AppThemeBinding Light={StaticResource ColorOnErrorContainerLight},
                                             Dark={StaticResource ColorOnErrorContainerDark}}"
                 VerticalOptions="Center"
                 LineBreakMode="WordWrap" />
          <ImageButton Grid.Column="1"
                       Command="{Binding DismissErrorCommand}"
                       WidthRequest="{StaticResource MinTouchTarget}"
                       HeightRequest="{StaticResource MinTouchTarget}"
                       BackgroundColor="Transparent"
                       AutomationId="DismissErrorButton"
                       SemanticProperties.Description="Dismiss error">
            <ImageButton.Source>
              <FontImageSource FontFamily="TablerIcons"
                               Glyph="{x:Static helpers:IconKeys.X}"
                               Size="{StaticResource FontSizeIconXl}"
                               Color="{AppThemeBinding Light={StaticResource ColorOnErrorContainerLight},
                                                        Dark={StaticResource ColorOnErrorContainerDark}}" />
            </ImageButton.Source>
          </ImageButton>
        </Grid>
      </Border>



    </VerticalStackLayout>

  </Grid>

</ContentPage>
