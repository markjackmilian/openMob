<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:openMob.Helpers"
             xmlns:controls="clr-namespace:openMob.Views.Controls"
             xmlns:models="clr-namespace:openMob.Core.Models;assembly=openMob.Core"
             xmlns:viewmodels="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
             x:Class="openMob.Views.Pages.ChatPage"
             x:DataType="viewmodels:ChatViewModel"
             Shell.NavBarIsVisible="False">

  <Grid RowDefinitions="Auto,Auto,*">

    <!-- ═══════════════════════════════════════════════════════════════
         ROW 0 — Custom Topbar (56dp, background, bottom separator)
         ═══════════════════════════════════════════════════════════════ -->
    <Grid Grid.Row="0"
          ColumnDefinitions="Auto,*,Auto,Auto"
          HeightRequest="56"
           Padding="8,0"
          BackgroundColor="{AppThemeBinding Light={StaticResource ColorBackgroundLight},
                                            Dark={StaticResource ColorBackgroundDark}}">

      <!-- Hamburger button (left) -->
      <ImageButton Grid.Column="0"
                   x:Name="HamburgerButton"
                   Clicked="OnHamburgerClicked"
                   WidthRequest="{StaticResource MinTouchTarget}"
                   HeightRequest="{StaticResource MinTouchTarget}"
                   BackgroundColor="Transparent"
                   AutomationId="ChatHamburgerButton"
                   SemanticProperties.Description="Open navigation menu">
        <ImageButton.Source>
          <FontImageSource FontFamily="MaterialSymbols"
                           Glyph="{x:Static helpers:MaterialIcons.Menu}"
                           Size="24"
                           Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight},
                                                    Dark={StaticResource ColorOnBackgroundDark}}" />
        </ImageButton.Source>
      </ImageButton>

      <!-- Center: "openMob Sonnet >" — tappable model/title indicator -->
      <HorizontalStackLayout Grid.Column="1"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="{StaticResource SpacingXs}">
        <HorizontalStackLayout.GestureRecognizers>
          <!-- Placeholder: will open ModelPickerSheet when command is available -->
          <TapGestureRecognizer Command="{Binding ShowMoreMenuCommand}" />
        </HorizontalStackLayout.GestureRecognizers>

        <Label Text="openMob"
               FontFamily="InterSemiBold"
               FontSize="{StaticResource FontSizeHeadline}"
               TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight},
                                            Dark={StaticResource ColorOnBackgroundDark}}"
               VerticalOptions="Center" />

        <!-- Model name — bound to SelectedModelName -->
        <Label Text="{Binding SelectedModelName, TargetNullValue='Seleziona modello', FallbackValue='Seleziona modello'}"
               FontFamily="InterSemiBold"
               FontSize="{StaticResource FontSizeHeadline}"
               TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight},
                                             Dark={StaticResource ColorOnBackgroundDark}}"
               VerticalOptions="Center" />

        <!-- Chevron right disclosure indicator -->
        <Label Text="{x:Static helpers:MaterialIcons.ChevronRight}"
               FontFamily="MaterialSymbols"
               FontSize="18"
               TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight},
                                            Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
               VerticalOptions="Center" />
      </HorizontalStackLayout>

      <!-- New Chat button -->
      <ImageButton Grid.Column="2"
                   Command="{Binding NewChatCommand}"
                   WidthRequest="{StaticResource MinTouchTarget}"
                   HeightRequest="{StaticResource MinTouchTarget}"
                   BackgroundColor="Transparent"
                   AutomationId="ChatNewChatButton"
                   SemanticProperties.Description="Start a new chat">
        <ImageButton.Source>
          <FontImageSource FontFamily="MaterialSymbols"
                           Glyph="{x:Static helpers:MaterialIcons.Edit}"
                           Size="24"
                           Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight},
                                                    Dark={StaticResource ColorOnBackgroundDark}}" />
        </ImageButton.Source>
      </ImageButton>

      <!-- More Menu button -->
      <ImageButton Grid.Column="3"
                   Command="{Binding ShowMoreMenuCommand}"
                   WidthRequest="{StaticResource MinTouchTarget}"
                   HeightRequest="{StaticResource MinTouchTarget}"
                   BackgroundColor="Transparent"
                   AutomationId="ChatMoreMenuButton"
                   SemanticProperties.Description="More options">
        <ImageButton.Source>
          <FontImageSource FontFamily="MaterialSymbols"
                           Glyph="{x:Static helpers:MaterialIcons.MoreVert}"
                           Size="24"
                           Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight},
                                                    Dark={StaticResource ColorOnBackgroundDark}}" />
        </ImageButton.Source>
      </ImageButton>

    </Grid>

    <!-- Topbar bottom separator -->
    <BoxView Grid.Row="0"
             HeightRequest="0.5"
             VerticalOptions="End"
             Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight},
                                      Dark={StaticResource ColorSeparatorDark}}" />

    <!-- ═══════════════════════════════════════════════════════════════
         ROW 1 — Status Banner (visible only when StatusBanner != null)
         ═══════════════════════════════════════════════════════════════ -->
    <controls:StatusBannerView Grid.Row="1"
                               IsVisible="{Binding StatusBanner, Converter={StaticResource NullToVisibilityConverter}}"
                               Message="{Binding StatusBanner.Message, FallbackValue='', TargetNullValue=''}"
                               ActionLabel="{Binding StatusBanner.ActionLabel, FallbackValue='', TargetNullValue=''}"
                               BannerType="{Binding StatusBanner.Type, FallbackValue=None}" />

    <!-- ═══════════════════════════════════════════════════════════════
         ROW 2 — Body (message area + suggestion chips + input bar)
         ═══════════════════════════════════════════════════════════════ -->
    <Grid Grid.Row="2"
          RowDefinitions="*,Auto,Auto,Auto"
          BackgroundColor="{AppThemeBinding Light={StaticResource ColorBackgroundLight},
                                            Dark={StaticResource ColorBackgroundDark}}">

      <!-- ─────────────────────────────────────────────────────────────
           Row 0: Empty State — visible when IsEmpty = true
           ───────────────────────────────────────────────────────────── -->
      <controls:EmptyStateView Grid.Row="0"
                               IsVisible="{Binding IsEmpty}"
                               Title="How can I help you?" />

      <!-- ─────────────────────────────────────────────────────────────
           Row 0: Message CollectionView — visible when IsEmpty = false
           ───────────────────────────────────────────────────────────── -->
      <CollectionView Grid.Row="0"
                      x:Name="MessagesCollectionView"
                      ItemsSource="{Binding Messages}"
                      ItemsUpdatingScrollMode="KeepLastItemInView"
                      SelectionMode="None"
                      IsVisible="{Binding IsEmpty, Converter={StaticResource InvertedBoolConverter}}">
        <CollectionView.ItemTemplate>
          <DataTemplate x:DataType="models:ChatMessage">
            <controls:MessageBubbleView
                TextContent="{Binding TextContent}"
                IsFromUser="{Binding IsFromUser}"
                Timestamp="{Binding Timestamp}"
                DeliveryStatus="{Binding DeliveryStatus}"
                IsFirstInGroup="{Binding IsFirstInGroup}"
                IsLastInGroup="{Binding IsLastInGroup}"
                IsStreaming="{Binding IsStreaming}" />
          </DataTemplate>
        </CollectionView.ItemTemplate>
      </CollectionView>

      <!-- ─────────────────────────────────────────────────────────────
           Row 1: Error Banner — visible when HasError = true
           ───────────────────────────────────────────────────────────── -->
      <Border Grid.Row="1"
              IsVisible="{Binding HasError}"
              BackgroundColor="{AppThemeBinding Light={StaticResource ColorErrorContainerLight},
                                               Dark={StaticResource ColorErrorContainerDark}}"
              StrokeThickness="0"
              StrokeShape="RoundRectangle 0"
              Padding="{StaticResource SpacingMd}">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource SpacingSm}">
          <Label Grid.Column="0"
                 Text="{Binding ErrorMessage, FallbackValue='', TargetNullValue=''}"
                 FontFamily="InterRegular"
                 FontSize="{StaticResource FontSizeFootnote}"
                 TextColor="{AppThemeBinding Light={StaticResource ColorOnErrorContainerLight},
                                             Dark={StaticResource ColorOnErrorContainerDark}}"
                 VerticalOptions="Center"
                 LineBreakMode="WordWrap" />
          <ImageButton Grid.Column="1"
                       Command="{Binding DismissErrorCommand}"
                       WidthRequest="{StaticResource MinTouchTarget}"
                       HeightRequest="{StaticResource MinTouchTarget}"
                       BackgroundColor="Transparent"
                       AutomationId="DismissErrorButton"
                       SemanticProperties.Description="Dismiss error">
            <ImageButton.Source>
              <FontImageSource FontFamily="MaterialSymbols"
                               Glyph="{x:Static helpers:MaterialIcons.Close}"
                               Size="18"
                               Color="{AppThemeBinding Light={StaticResource ColorOnErrorContainerLight},
                                                        Dark={StaticResource ColorOnErrorContainerDark}}" />
            </ImageButton.Source>
          </ImageButton>
        </Grid>
      </Border>

      <!-- ─────────────────────────────────────────────────────────────
           Row 2: Suggestion Chips — visible when IsEmpty = true
           ───────────────────────────────────────────────────────────── -->
      <CollectionView Grid.Row="2"
                      ItemsSource="{Binding SuggestionChips}"
                      SelectionMode="None"
                      IsVisible="{Binding IsEmpty}"
                      HeightRequest="80"
                      Margin="{StaticResource SpacingSm}">
        <CollectionView.ItemsLayout>
          <LinearItemsLayout Orientation="Horizontal"
                             ItemSpacing="{StaticResource SpacingSm}" />
        </CollectionView.ItemsLayout>
        <CollectionView.ItemTemplate>
          <DataTemplate x:DataType="models:SuggestionChip">
            <controls:SuggestionChipView
                Title="{Binding Title}"
                Subtitle="{Binding Subtitle}"
                TapCommand="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ChatViewModel}}, Path=SelectSuggestionChipCommand}"
                CommandParameter="{Binding .}" />
          </DataTemplate>
        </CollectionView.ItemTemplate>
      </CollectionView>

      <!-- ─────────────────────────────────────────────────────────────
           Row 3: Input Bar — fixed at bottom
           ───────────────────────────────────────────────────────────── -->
      <controls:InputBarView Grid.Row="3"
                             Text="{Binding InputText, Mode=TwoWay}"
                             SendCommand="{Binding SendMessageCommand}"
                             IsEnabled="{Binding IsAiResponding, Converter={StaticResource InvertedBoolConverter}}"
                             Placeholder="Message..." />

    </Grid>

  </Grid>

</ContentPage>
