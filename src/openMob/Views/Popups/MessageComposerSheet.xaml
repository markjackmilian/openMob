<?xml version="1.0" encoding="utf-8" ?>
<uxd:PopupPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:uxd="clr-namespace:UXDivers.Popups.Maui;assembly=UXDivers.Popups.Maui"
               xmlns:vm="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
               xmlns:models="clr-namespace:openMob.Core.Models;assembly=openMob.Core"
               xmlns:helpers="clr-namespace:openMob.Helpers"
               x:Class="openMob.Views.Popups.MessageComposerSheet"
               x:DataType="vm:MessageComposerViewModel"
               BackgroundColor="{DynamicResource PopupBackdropColor}"
               CloseWhenBackgroundIsClicked="False"
               AppearingAnimation="{uxd:MoveInPopupAnimation MoveDirection=Bottom, Duration=300, Easing=CubicOut}"
               DisappearingAnimation="{uxd:MoveOutPopupAnimation MoveDirection=Bottom, Duration=250, Easing=CubicIn}">

  <!-- Bottom-sheet panel: anchored to bottom, rounded top corners, solid background -->
  <Border VerticalOptions="End"
          HorizontalOptions="Fill"
          StrokeThickness="0"
          Padding="0"
          BackgroundColor="{AppThemeBinding Light={StaticResource ColorBackgroundLight},
                                            Dark={StaticResource ColorBackgroundDark}}">
    <Border.StrokeShape>
      <RoundRectangle CornerRadius="20,20,0,0" />
    </Border.StrokeShape>
    <Border.Shadow>
      <Shadow Brush="Black" Opacity="0.15" Offset="0,-2" Radius="16" />
    </Border.Shadow>

    <VerticalStackLayout Spacing="0" Padding="0">

      <!-- Handle bar -->
      <BoxView Style="{StaticResource SheetHandleBar}"
               Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                        Dark={StaticResource ColorOnBackgroundTertiaryDark}}" />

      <!-- Header -->
      <Grid ColumnDefinitions="*,Auto"
            Padding="16,0"
            HeightRequest="{StaticResource MinTouchTarget}">
        <Label Grid.Column="0"
               Text="Compose Message"
               Style="{StaticResource Title3Label}"
               VerticalOptions="Center" />
        <ImageButton Grid.Column="1"
                     Clicked="OnCloseButtonTapped"
                     MinimumHeightRequest="{StaticResource MinTouchTarget}"
                     MinimumWidthRequest="{StaticResource MinTouchTarget}"
                     BackgroundColor="Transparent"
                     AutomationId="ComposerCloseButton"
                     SemanticProperties.Description="Close message composer">
          <ImageButton.Source>
            <FontImageSource FontFamily="TablerIcons"
                             Glyph="{x:Static helpers:IconKeys.X}"
                             Size="20"
                             Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight},
                                                      Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
          </ImageButton.Source>
        </ImageButton>
      </Grid>

      <!-- Divider -->
      <BoxView HeightRequest="0.5"
               Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight},
                                        Dark={StaticResource ColorSeparatorDark}}" />

      <!-- Session chips row — compact inline pills -->
      <HorizontalStackLayout Spacing="6" Padding="16,8">

        <!-- Agent chip -->
        <Border StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight}, Dark={StaticResource ColorSurfaceSecondaryDark}}"
                Padding="8,3" HeightRequest="26">
          <Border.StrokeShape><RoundRectangle CornerRadius="13" /></Border.StrokeShape>
          <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding SelectAgentCommand}" /></Border.GestureRecognizers>
          <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
            <Label Text="{x:Static helpers:IconKeys.Robot}" FontFamily="TablerIcons" FontSize="11"
                   TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" VerticalOptions="Center" />
            <Label Text="{Binding SessionAgentDisplayName, FallbackValue='Default'}" FontFamily="InterMedium" FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" VerticalOptions="Center"
                   LineBreakMode="TailTruncation" MaximumWidthRequest="90" />
          </HorizontalStackLayout>
        </Border>

        <!-- Think level chip -->
        <Border StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight}, Dark={StaticResource ColorSurfaceSecondaryDark}}"
                Padding="8,3" HeightRequest="26">
          <Border.StrokeShape><RoundRectangle CornerRadius="13" /></Border.StrokeShape>
          <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding ToggleThinkLevelExpandedCommand}" /></Border.GestureRecognizers>
          <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
            <Label Text="{x:Static helpers:IconKeys.Brain}" FontFamily="TablerIcons" FontSize="11"
                   TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" VerticalOptions="Center" />
            <Label Text="{Binding SessionThinkingLevel, FallbackValue='Medium'}" FontFamily="InterMedium" FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" VerticalOptions="Center" />
            <Label Text="{x:Static helpers:IconKeys.ChevronDown}" FontFamily="TablerIcons" FontSize="10"
                   TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" VerticalOptions="Center"
                   IsVisible="{Binding IsThinkLevelExpanded, Converter={StaticResource InvertedBoolConverter}}" />
            <Label Text="{x:Static helpers:IconKeys.ChevronUp}" FontFamily="TablerIcons" FontSize="10"
                   TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" VerticalOptions="Center"
                   IsVisible="{Binding IsThinkLevelExpanded}" />
          </HorizontalStackLayout>
        </Border>

        <!-- Auto-accept chip -->
        <Border StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight}, Dark={StaticResource ColorSurfaceSecondaryDark}}"
                Padding="8,3" HeightRequest="26">
          <Border.StrokeShape><RoundRectangle CornerRadius="13" /></Border.StrokeShape>
          <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding ToggleAutoAcceptCommand}" /></Border.GestureRecognizers>
          <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
            <Label Text="{x:Static helpers:IconKeys.AutoAwesome}" FontFamily="TablerIcons" FontSize="11" VerticalOptions="Center">
              <Label.TextColor>
                <AppThemeBinding Light="{StaticResource ColorOnBackgroundSecondaryLight}" Dark="{StaticResource ColorOnBackgroundSecondaryDark}" />
              </Label.TextColor>
              <Label.Triggers>
                <DataTrigger TargetType="Label" Binding="{Binding SessionAutoAccept}" Value="True">
                  <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
                </DataTrigger>
              </Label.Triggers>
            </Label>
            <Label Text="Auto" FontFamily="InterMedium" FontSize="12" VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" />
          </HorizontalStackLayout>
        </Border>

      </HorizontalStackLayout>

      <!-- Think level segmented (conditional) -->
      <HorizontalStackLayout Spacing="4" Padding="16,0,16,8" IsVisible="{Binding IsThinkLevelExpanded}">
        <Button Text="Low" FontFamily="InterMedium" FontSize="12" Padding="12,6" MinimumHeightRequest="28" MinimumWidthRequest="0" CornerRadius="6"
                Command="{Binding SetThinkingLevelCommand}" CommandParameter="{x:Static models:ThinkingLevel.Low}"
                BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight}, Dark={StaticResource ColorSurfaceSecondaryDark}}"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}">
          <Button.Triggers>
            <DataTrigger TargetType="Button" Binding="{Binding SessionThinkingLevel}" Value="{x:Static models:ThinkingLevel.Low}">
              <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
              <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight}, Dark={StaticResource ColorOnPrimaryDark}}" />
            </DataTrigger>
          </Button.Triggers>
        </Button>
        <Button Text="Medium" FontFamily="InterMedium" FontSize="12" Padding="12,6" MinimumHeightRequest="28" MinimumWidthRequest="0" CornerRadius="6"
                Command="{Binding SetThinkingLevelCommand}" CommandParameter="{x:Static models:ThinkingLevel.Medium}"
                BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight}, Dark={StaticResource ColorSurfaceSecondaryDark}}"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}">
          <Button.Triggers>
            <DataTrigger TargetType="Button" Binding="{Binding SessionThinkingLevel}" Value="{x:Static models:ThinkingLevel.Medium}">
              <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
              <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight}, Dark={StaticResource ColorOnPrimaryDark}}" />
            </DataTrigger>
          </Button.Triggers>
        </Button>
        <Button Text="High" FontFamily="InterMedium" FontSize="12" Padding="12,6" MinimumHeightRequest="28" MinimumWidthRequest="0" CornerRadius="6"
                Command="{Binding SetThinkingLevelCommand}" CommandParameter="{x:Static models:ThinkingLevel.High}"
                BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight}, Dark={StaticResource ColorSurfaceSecondaryDark}}"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}">
          <Button.Triggers>
            <DataTrigger TargetType="Button" Binding="{Binding SessionThinkingLevel}" Value="{x:Static models:ThinkingLevel.High}">
              <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
              <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight}, Dark={StaticResource ColorOnPrimaryDark}}" />
            </DataTrigger>
          </Button.Triggers>
        </Button>
      </HorizontalStackLayout>

      <!-- Editor -->
      <Editor Text="{Binding MessageText, Mode=TwoWay}"
              Placeholder="Scrivi un messaggio..."
              AutoSize="TextChanges"
              MinimumHeightRequest="60"
              MaximumHeightRequest="140"
              Margin="16,6,16,6"
              Style="{StaticResource InputBarEditor}"
              AutomationId="ComposerEditor"
              SemanticProperties.Hint="Type your message here" />

      <!-- Divider -->
      <BoxView HeightRequest="0.5"
               Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight},
                                        Dark={StaticResource ColorSeparatorDark}}" />

      <!-- Picker toolbar + Send row combined -->
      <Grid ColumnDefinitions="*,*,*,Auto" Padding="8,4,12,4" ColumnSpacing="0">

        <VerticalStackLayout Grid.Column="0" Spacing="1" HorizontalOptions="Center" Padding="4,6">
          <VerticalStackLayout.GestureRecognizers><TapGestureRecognizer Command="{Binding InsertSubagentCommand}" /></VerticalStackLayout.GestureRecognizers>
          <Label Text="{x:Static helpers:IconKeys.At}" FontFamily="TablerIcons" FontSize="18" HorizontalTextAlignment="Center"
                 TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
          <Label Text="Subagent" FontFamily="InterRegular" FontSize="10" HorizontalTextAlignment="Center"
                 TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" />
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Column="1" Spacing="1" HorizontalOptions="Center" Padding="4,6">
          <VerticalStackLayout.GestureRecognizers><TapGestureRecognizer Command="{Binding InsertCommandCommand}" /></VerticalStackLayout.GestureRecognizers>
          <Label Text="{x:Static helpers:IconKeys.Terminal}" FontFamily="TablerIcons" FontSize="18" HorizontalTextAlignment="Center"
                 TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
          <Label Text="Command" FontFamily="InterRegular" FontSize="10" HorizontalTextAlignment="Center"
                 TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" />
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Column="2" Spacing="1" HorizontalOptions="Center" Padding="4,6">
          <VerticalStackLayout.GestureRecognizers><TapGestureRecognizer Command="{Binding InsertFileCommand}" /></VerticalStackLayout.GestureRecognizers>
          <Label Text="{x:Static helpers:IconKeys.File}" FontFamily="TablerIcons" FontSize="18" HorizontalTextAlignment="Center"
                 TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
          <Label Text="File" FontFamily="InterRegular" FontSize="10" HorizontalTextAlignment="Center"
                 TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" />
        </VerticalStackLayout>

        <!-- Send button integrated in the toolbar row -->
        <Button Grid.Column="3"
                Text="{Binding SendButtonText, FallbackValue='Invia'}"
                Command="{Binding SendCommand}"
                Style="{StaticResource PrimaryButton}"
                FontFamily="InterSemiBold"
                FontSize="15"
                MinimumWidthRequest="72"
                HeightRequest="40"
                Padding="16,0"
                VerticalOptions="Center"
                AutomationId="ComposerSendButton"
                SemanticProperties.Description="Send message" />
      </Grid>

      <!-- Bottom safe area padding for Android gesture nav bar -->
      <BoxView HeightRequest="48" Color="Transparent" />

    </VerticalStackLayout>
  </Border>

</uxd:PopupPage>
