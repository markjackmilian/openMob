<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:openMob.Views.Controls"
             xmlns:markdown="clr-namespace:openMob.Views.Controls.Markdown"
             xmlns:helpers="clr-namespace:openMob.Helpers"
             xmlns:models="clr-namespace:openMob.Core.Models;assembly=openMob.Core"
             xmlns:viewmodels="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
             x:Class="openMob.Views.Controls.MessageBlockView"
             x:Name="this"
             x:DataType="controls:MessageBlockView">

  <Grid Padding="{StaticResource SpacingXs}"
        ColumnDefinitions="Auto,*"
        ColumnSpacing="0">

    <!-- ═══════════════════════════════════════════════════════════════
         Column 0: Left color bar (3pt wide, full height)
         Color determined by SenderType via DataTriggers
         ═══════════════════════════════════════════════════════════════ -->
    <BoxView x:Name="LeftBar"
             Grid.Column="0"
             WidthRequest="{StaticResource SizeMessageBarWidth}"
             VerticalOptions="Fill"
             Color="{AppThemeBinding Light={StaticResource ColorPrimaryLight},
                                     Dark={StaticResource ColorPrimaryDark}}">
      <BoxView.Triggers>
        <DataTrigger TargetType="BoxView"
                     Binding="{Binding SenderType, Source={x:Reference this}}"
                     Value="{x:Static models:SenderType.User}">
          <Setter Property="Color"
                  Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight},
                                          Dark={StaticResource ColorPrimaryDark}}" />
        </DataTrigger>
        <DataTrigger TargetType="BoxView"
                     Binding="{Binding SenderType, Source={x:Reference this}}"
                     Value="{x:Static models:SenderType.Agent}">
          <Setter Property="Color"
                  Value="{AppThemeBinding Light={StaticResource ColorAgentAccentLight},
                                          Dark={StaticResource ColorAgentAccentDark}}" />
        </DataTrigger>
        <DataTrigger TargetType="BoxView"
                     Binding="{Binding SenderType, Source={x:Reference this}}"
                     Value="{x:Static models:SenderType.Subagent}">
          <Setter Property="Color"
                  Value="{AppThemeBinding Light={StaticResource ColorSubagentAccentLight},
                                          Dark={StaticResource ColorSubagentAccentDark}}" />
        </DataTrigger>
      </BoxView.Triggers>
    </BoxView>

    <!-- ═══════════════════════════════════════════════════════════════
         Column 1: Message content area
         ═══════════════════════════════════════════════════════════════ -->
      <VerticalStackLayout x:Name="StandardMessageLayout"
                           Grid.Column="1"
                           Spacing="{StaticResource SpacingXs}"
                           Padding="8,4,12,4">
        <VerticalStackLayout.Triggers>
          <DataTrigger TargetType="VerticalStackLayout"
                       Binding="{Binding MessageKind, Source={x:Reference this}}"
                       Value="{x:Static models:MessageKind.PermissionRequest}">
            <Setter Property="IsVisible" Value="False" />
          </DataTrigger>
        </VerticalStackLayout.Triggers>

      <!-- Sender label — visible only when IsFirstInGroup=true (REQ-006) -->
      <Label x:Name="SenderLabel"
             Text="{Binding SenderName, Source={x:Reference this}, FallbackValue=''}"
             Style="{StaticResource SenderLabel}"
             IsVisible="{Binding IsFirstInGroup, Source={x:Reference this}}"
             TextColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight},
                                         Dark={StaticResource ColorPrimaryDark}}"
             SemanticProperties.Description="Message sender">
        <Label.Triggers>
          <DataTrigger TargetType="Label"
                       Binding="{Binding SenderType, Source={x:Reference this}}"
                       Value="{x:Static models:SenderType.User}">
            <Setter Property="TextColor"
                    Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight},
                                            Dark={StaticResource ColorPrimaryDark}}" />
          </DataTrigger>
          <DataTrigger TargetType="Label"
                       Binding="{Binding SenderType, Source={x:Reference this}}"
                       Value="{x:Static models:SenderType.Agent}">
            <Setter Property="TextColor"
                    Value="{AppThemeBinding Light={StaticResource ColorAgentAccentLight},
                                            Dark={StaticResource ColorAgentAccentDark}}" />
          </DataTrigger>
          <DataTrigger TargetType="Label"
                       Binding="{Binding SenderType, Source={x:Reference this}}"
                       Value="{x:Static models:SenderType.Subagent}">
            <Setter Property="TextColor"
                    Value="{AppThemeBinding Light={StaticResource ColorSubagentAccentLight},
                                            Dark={StaticResource ColorSubagentAccentDark}}" />
          </DataTrigger>
        </Label.Triggers>
      </Label>

      <!-- Content area: User messages use plain Label, AI messages use MarkdownView -->

      <!-- User message text (REQ-004) -->
      <Border IsVisible="{Binding IsFromUser, Source={x:Reference this}}"
              BackgroundColor="{AppThemeBinding Light={StaticResource ColorMessageUserBackgroundLight},
                                                Dark={StaticResource ColorMessageUserBackgroundDark}}"
              StrokeThickness="0"
              StrokeShape="RoundRectangle 8"
              Padding="{StaticResource SpacingSm}">
        <Label Text="{Binding TextContent, Source={x:Reference this}, FallbackValue=''}"
               Style="{StaticResource MessageBodyLabel}" />
      </Border>

      <!-- AI message content (REQ-005) — rendered via MarkdownView -->
      <markdown:MarkdownView
          IsVisible="{Binding IsFromUser, Source={x:Reference this}, Converter={StaticResource InvertedBoolConverter}}"
          MarkdownText="{Binding TextContent, Source={x:Reference this}, FallbackValue=''}" />

      <!-- Streaming indicator (pulsing dots) -->
      <HorizontalStackLayout x:Name="StreamingDots"
                             Spacing="{StaticResource SpacingXs}"
                             IsVisible="{Binding IsStreaming, Source={x:Reference this}}"
                             Padding="0,4,0,0">
        <Ellipse x:Name="Dot1"
                 WidthRequest="6"
                 HeightRequest="6"
                 Fill="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                       Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                 Opacity="0.3" />
        <Ellipse x:Name="Dot2"
                 WidthRequest="6"
                 HeightRequest="6"
                 Fill="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                       Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                 Opacity="0.3" />
        <Ellipse x:Name="Dot3"
                 WidthRequest="6"
                 HeightRequest="6"
                 Fill="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                       Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                 Opacity="0.3" />
      </HorizontalStackLayout>

      <!-- Timestamp (REQ-007) — right-aligned, hidden during streaming -->
      <Label Text="{Binding Timestamp, Source={x:Reference this}, Converter={StaticResource DateTimeToRelativeStringConverter}, FallbackValue=''}"
             Style="{StaticResource TimestampLabel}"
             TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                         Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
             IsVisible="{Binding IsStreaming, Source={x:Reference this}, Converter={StaticResource InvertedBoolConverter}}"
             HorizontalOptions="End" />

      </VerticalStackLayout>

      <Border x:Name="PermissionCard"
              Grid.Column="1"
              IsVisible="False"
              StrokeThickness="1"
              Stroke="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}"
              BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight}, Dark={StaticResource ColorSurfaceSecondaryDark}}"
              StrokeShape="RoundRectangle 16"
              Padding="12,10">
        <Border.Triggers>
          <DataTrigger TargetType="Border"
                       Binding="{Binding MessageKind, Source={x:Reference this}}"
                       Value="{x:Static models:MessageKind.PermissionRequest}">
            <Setter Property="IsVisible" Value="True" />
          </DataTrigger>
        </Border.Triggers>

        <VerticalStackLayout Spacing="10">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <VerticalStackLayout Spacing="2">
              <Label Text="{Binding PermissionType, Source={x:Reference this}, FallbackValue='Permission request'}"
                     Style="{StaticResource Title3Label}" />
              <Label Text="Pending approval"
                     FontFamily="InterRegular"
                     FontSize="{StaticResource FontSizeCaption1}"
                     TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}">
                <Label.Triggers>
                  <DataTrigger TargetType="Label"
                               Binding="{Binding PermissionStatus, Source={x:Reference this}}"
                               Value="{x:Static models:PermissionStatus.Resolved}">
                    <Setter Property="IsVisible" Value="False" />
                  </DataTrigger>
                </Label.Triggers>
              </Label>
              <Label Text="{Binding ResolvedReplyLabel, Source={x:Reference this}, StringFormat='Resolved: {0}'}"
                     FontFamily="InterRegular"
                     FontSize="{StaticResource FontSizeCaption1}"
                     TextColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}"
                     IsVisible="False">
                <Label.Triggers>
                  <DataTrigger TargetType="Label"
                               Binding="{Binding PermissionStatus, Source={x:Reference this}}"
                               Value="{x:Static models:PermissionStatus.Resolved}">
                    <Setter Property="IsVisible" Value="True" />
                  </DataTrigger>
                </Label.Triggers>
              </Label>
            </VerticalStackLayout>

            <Border Grid.Column="1"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource ColorPrimaryContainerLight}, Dark={StaticResource ColorPrimaryContainerDark}}"
                    Padding="10,4"
                    StrokeShape="RoundRectangle 999"
                    VerticalOptions="Start">
              <Label Text="Permission"
                     FontFamily="InterSemiBold"
                     FontSize="{StaticResource FontSizeCaption2}"
                     TextColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
            </Border>
          </Grid>

          <HorizontalStackLayout Spacing="8"
                                 BindableLayout.ItemsSource="{Binding PermissionPatterns, Source={x:Reference this}}">
            <BindableLayout.ItemTemplate>
              <DataTemplate x:DataType="x:String">
                <Border StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}"
                        Padding="8,4"
                        StrokeShape="RoundRectangle 999">
                  <Label Text="{Binding .}"
                         FontFamily="InterRegular"
                         FontSize="{StaticResource FontSizeCaption1}"
                         LineBreakMode="TailTruncation"
                         TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
                </Border>
              </DataTemplate>
            </BindableLayout.ItemTemplate>
          </HorizontalStackLayout>

          <HorizontalStackLayout Spacing="8" HorizontalOptions="Fill">
            <Button Text="Always"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ChatViewModel}}, Path=ReplyToPermissionAlwaysCommand}"
                    CommandParameter="{Binding RequestId, Source={x:Reference this}}">
              <Button.Triggers>
                <DataTrigger TargetType="Button"
                             Binding="{Binding PermissionStatus, Source={x:Reference this}}"
                             Value="{x:Static models:PermissionStatus.Resolved}">
                  <Setter Property="IsEnabled" Value="False" />
                  <Setter Property="Opacity" Value="0.5" />
                </DataTrigger>
              </Button.Triggers>
            </Button>
            <Button Text="Once"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ChatViewModel}}, Path=ReplyToPermissionOnceCommand}"
                    CommandParameter="{Binding RequestId, Source={x:Reference this}}">
              <Button.Triggers>
                <DataTrigger TargetType="Button"
                             Binding="{Binding PermissionStatus, Source={x:Reference this}}"
                             Value="{x:Static models:PermissionStatus.Resolved}">
                  <Setter Property="IsEnabled" Value="False" />
                  <Setter Property="Opacity" Value="0.5" />
                </DataTrigger>
              </Button.Triggers>
            </Button>
            <Button Text="Deny"
                    Style="{StaticResource DestructiveOutlinedButton}"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ChatViewModel}}, Path=ReplyToPermissionDenyCommand}"
                    CommandParameter="{Binding RequestId, Source={x:Reference this}}">
              <Button.Triggers>
                <DataTrigger TargetType="Button"
                             Binding="{Binding PermissionStatus, Source={x:Reference this}}"
                             Value="{x:Static models:PermissionStatus.Resolved}">
                  <Setter Property="IsEnabled" Value="False" />
                  <Setter Property="Opacity" Value="0.5" />
                </DataTrigger>
              </Button.Triggers>
            </Button>
          </HorizontalStackLayout>
        </VerticalStackLayout>
      </Border>

    </Grid>

</ContentView>
