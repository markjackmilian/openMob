<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:openMob.Views.Controls"
             xmlns:helpers="clr-namespace:openMob.Helpers"
             x:Class="openMob.Views.Controls.EmptyStateView"
             x:Name="this"
             x:DataType="controls:EmptyStateView">

  <Grid RowDefinitions="0.4*,Auto,0.6*">

    <!-- Positioned at ~40% from top -->
    <VerticalStackLayout Grid.Row="1"
                         HorizontalOptions="Center"
                         Spacing="{StaticResource SpacingSm}">

      <!-- App icon -->
      <Label Text="{x:Static helpers:IconKeys.Robot}"
             FontFamily="{StaticResource TablerIconsFont}"
             FontSize="{StaticResource FontSizeIconHero}"
             TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                         Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
             HorizontalOptions="Center"
             SemanticProperties.Description="AI assistant icon" />

      <!-- Title -->
      <Label Text="{Binding Title, Source={x:Reference this}, FallbackValue='How can I help you?'}"
             Style="{StaticResource Title2Label}"
             HorizontalTextAlignment="Center"
             HorizontalOptions="Center" />

      <!-- Subtitle -->
      <Label Text="{Binding Subtitle, Source={x:Reference this}, FallbackValue=''}"
             Style="{StaticResource SubtitleLabel}"
             HorizontalTextAlignment="Center"
             HorizontalOptions="Center"
             IsVisible="{Binding Subtitle, Source={x:Reference this}, Converter={StaticResource NullToVisibilityConverter}}" />

    </VerticalStackLayout>

  </Grid>

</ContentView>
