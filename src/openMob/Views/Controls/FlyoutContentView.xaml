<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
             xmlns:models="clr-namespace:openMob.Core.Models;assembly=openMob.Core"
             xmlns:helpers="clr-namespace:openMob.Helpers"
             x:Class="openMob.Views.Controls.FlyoutContentView"
             x:DataType="viewmodels:FlyoutViewModel">

  <Grid
      RowDefinitions="Auto,Auto,Auto,*"
      BackgroundColor="{AppThemeBinding Light={StaticResource ColorBackgroundLight}, Dark={StaticResource ColorBackgroundDark}}">

    <!-- Row 0: Section header: project name (uppercase)
         Margin="16,12,16,8" = composite of SpacingLg, SpacingMd, SpacingLg, SpacingSm -->
    <Label
        Grid.Row="0"
        Text="{Binding ProjectSectionTitle, FallbackValue='SESSIONS', TargetNullValue='SESSIONS'}"
        FontFamily="InterMedium"
        FontSize="{StaticResource FontSizeCaption1}"
        TextTransform="Uppercase"
        TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
        Margin="16,12,16,8" />

    <!-- Row 1: New Session button — always visible -->
    <Border
        Grid.Row="1"
        AutomationId="NewSessionButton"
        BackgroundColor="{AppThemeBinding Light={StaticResource ColorPrimaryContainerLight}, Dark={StaticResource ColorPrimaryContainerDark}}"
        StrokeThickness="0"
        StrokeShape="RoundRectangle 8"
        Margin="16,8,16,4"
        Padding="0"
        IsEnabled="{Binding IsCreatingSession, Converter={StaticResource InvertedBoolConverter}}"
        SemanticProperties.Description="Start a new session">
      <Border.GestureRecognizers>
        <TapGestureRecognizer Command="{Binding NewSessionCommand}" />
      </Border.GestureRecognizers>

      <Grid>
        <!-- Normal state: icon + label -->
        <HorizontalStackLayout
            Spacing="{StaticResource SpacingSm}"
            HorizontalOptions="Center"
            Padding="{StaticResource SpacingSm}"
            IsVisible="{Binding IsCreatingSession, Converter={StaticResource InvertedBoolConverter}}">
          <Image>
            <Image.Source>
              <FontImageSource
                  FontFamily="TablerIcons"
                  Glyph="{x:Static helpers:IconKeys.Add}"
                  Size="{StaticResource FontSizeTitle3}"
                  Color="{AppThemeBinding Light={StaticResource ColorOnPrimaryContainerLight}, Dark={StaticResource ColorOnPrimaryContainerDark}}" />
            </Image.Source>
          </Image>
          <Label
              Text="New Session"
              FontFamily="InterMedium"
              FontSize="{StaticResource FontSizeCallout}"
              TextColor="{AppThemeBinding Light={StaticResource ColorOnPrimaryContainerLight}, Dark={StaticResource ColorOnPrimaryContainerDark}}"
              VerticalOptions="Center" />
        </HorizontalStackLayout>

        <!-- Loading state: activity indicator -->
        <ActivityIndicator
            IsVisible="{Binding IsCreatingSession}"
            IsRunning="{Binding IsCreatingSession}"
            HeightRequest="20"
            WidthRequest="20"
            HorizontalOptions="Center"
            Margin="{StaticResource SpacingSm}" />
      </Grid>
    </Border>

    <!-- Row 2: Inline creation error label — hidden when CreationError is null -->
    <Border
        Grid.Row="2"
        BackgroundColor="{AppThemeBinding Light={StaticResource ColorErrorContainerLight}, Dark={StaticResource ColorErrorContainerDark}}"
        StrokeThickness="0"
        StrokeShape="RoundRectangle 8"
        Margin="16,0,16,4"
        Padding="{StaticResource SpacingMd}"
        IsVisible="{Binding CreationError, Converter={StaticResource NullToVisibilityConverter}}">
      <Label
          Text="{Binding CreationError, FallbackValue='', TargetNullValue=''}"
          FontFamily="InterRegular"
          FontSize="{StaticResource FontSizeFootnote}"
          TextColor="{AppThemeBinding Light={StaticResource ColorOnErrorContainerLight}, Dark={StaticResource ColorOnErrorContainerDark}}"
          LineBreakMode="WordWrap" />
    </Border>

    <!-- Row 3 (was Row 1): No project placeholder -->
    <Label
        Grid.Row="3"
        Text="Select a project to view sessions"
        FontFamily="InterRegular"
        FontSize="{StaticResource FontSizeCallout}"
        HorizontalTextAlignment="Center"
        Margin="{StaticResource SpacingLg}"
        TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
        IsVisible="{Binding HasProject, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}" />

    <!-- Row 3 (was Row 1): Loading indicator -->
    <ActivityIndicator
        Grid.Row="3"
        IsRunning="{Binding IsLoading}"
        IsVisible="{Binding IsLoading}"
        HorizontalOptions="Center"
        VerticalOptions="Start"
        Margin="0,24,0,0" />

    <!-- Row 3 (was Row 1): Session list -->
    <CollectionView
        Grid.Row="3"
        ItemsSource="{Binding Sessions}"
        IsVisible="{Binding HasProject}"
        SelectionMode="None">

      <CollectionView.EmptyView>
        <VerticalStackLayout
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Padding="{StaticResource SpacingLg}">
          <Label
              Text="No sessions yet"
              FontFamily="InterRegular"
              FontSize="{StaticResource FontSizeCallout}"
              HorizontalTextAlignment="Center"
              TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" />
        </VerticalStackLayout>
      </CollectionView.EmptyView>

      <CollectionView.ItemTemplate>
        <DataTemplate x:DataType="models:SessionItem">
          <VerticalStackLayout Spacing="0">
            <Grid
                ColumnDefinitions="*"
                Padding="16,12"
                BackgroundColor="Transparent">
              <Grid.Triggers>
                <DataTrigger TargetType="Grid" Binding="{Binding IsSelected}" Value="True">
                  <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryContainerLight}, Dark={StaticResource ColorPrimaryContainerDark}}" />
                </DataTrigger>
              </Grid.Triggers>
              <Grid.GestureRecognizers>
                <TapGestureRecognizer
                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:FlyoutViewModel}}, Path=SelectSessionCommand}"
                    CommandParameter="{Binding Id}" />
              </Grid.GestureRecognizers>

              <!-- Session title only -->
              <Label
                  Grid.Column="0"
                  Text="{Binding Title, FallbackValue='Untitled', TargetNullValue='Untitled'}"
                  FontFamily="InterRegular"
                  FontSize="{StaticResource FontSizeBody}"
                  TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}"
                  LineBreakMode="TailTruncation"
                  MaxLines="1"
                  VerticalOptions="Center" />
            </Grid>

            <!-- Separator between items -->
            <Line
                X1="0"
                X2="1"
                StrokeThickness="0.5"
                Stroke="{AppThemeBinding Light={StaticResource ColorSeparatorLight},
                                         Dark={StaticResource ColorSeparatorDark}}"
                Aspect="Fill" />
          </VerticalStackLayout>
        </DataTemplate>
      </CollectionView.ItemTemplate>

    </CollectionView>

  </Grid>

</ContentView>
