<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:openMob.Helpers"
             xmlns:controls="clr-namespace:openMob.Views.Controls"
             xmlns:viewmodels="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
             x:Class="openMob.Views.Pages.ChatPage"
             x:DataType="viewmodels:ChatViewModel"
             Shell.NavBarIsVisible="False">

  <Grid RowDefinitions="Auto,Auto,*">

    <!-- ═══════════════════════════════════════════════════════════════
         ROW 0 — Custom Topbar (56dp, background, bottom separator)
         REQ-012, REQ-013, REQ-014
         ═══════════════════════════════════════════════════════════════ -->
    <Grid Grid.Row="0"
          ColumnDefinitions="Auto,*,Auto,Auto"
          HeightRequest="56"
           Padding="8,0"
          BackgroundColor="{AppThemeBinding Light={StaticResource ColorBackgroundLight},
                                            Dark={StaticResource ColorBackgroundDark}}">

      <!-- Hamburger button (left) -->
      <ImageButton Grid.Column="0"
                   x:Name="HamburgerButton"
                   Clicked="OnHamburgerClicked"
                   WidthRequest="{StaticResource MinTouchTarget}"
                   HeightRequest="{StaticResource MinTouchTarget}"
                   BackgroundColor="Transparent"
                   AutomationId="ChatHamburgerButton"
                   SemanticProperties.Description="Open navigation menu">
        <ImageButton.Source>
          <FontImageSource FontFamily="MaterialSymbols"
                           Glyph="{x:Static helpers:MaterialIcons.Menu}"
                           Size="24"
                           Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight},
                                                    Dark={StaticResource ColorOnBackgroundDark}}" />
        </ImageButton.Source>
      </ImageButton>

      <!-- Center: "openMob Sonnet >" — tappable model/title indicator -->
      <HorizontalStackLayout Grid.Column="1"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="{StaticResource SpacingXs}">
        <HorizontalStackLayout.GestureRecognizers>
          <!-- Placeholder: will open ModelPickerSheet when command is available -->
          <TapGestureRecognizer Command="{Binding ShowMoreMenuCommand}" />
        </HorizontalStackLayout.GestureRecognizers>

        <Label Text="openMob"
               FontFamily="InterSemiBold"
               FontSize="{StaticResource FontSizeHeadline}"
               TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight},
                                            Dark={StaticResource ColorOnBackgroundDark}}"
               VerticalOptions="Center" />

        <!-- Hardcoded model name placeholder — will bind to SelectedModelName in future -->
        <Label Text="Sonnet"
               FontFamily="InterSemiBold"
               FontSize="{StaticResource FontSizeHeadline}"
               TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight},
                                            Dark={StaticResource ColorOnBackgroundDark}}"
               VerticalOptions="Center" />

        <!-- Chevron right disclosure indicator -->
        <Label Text="{x:Static helpers:MaterialIcons.ChevronRight}"
               FontFamily="MaterialSymbols"
               FontSize="18"
               TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight},
                                            Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
               VerticalOptions="Center" />
      </HorizontalStackLayout>

      <!-- New Chat button -->
      <ImageButton Grid.Column="2"
                   Command="{Binding NewChatCommand}"
                   WidthRequest="{StaticResource MinTouchTarget}"
                   HeightRequest="{StaticResource MinTouchTarget}"
                   BackgroundColor="Transparent"
                   AutomationId="ChatNewChatButton"
                   SemanticProperties.Description="Start a new chat">
        <ImageButton.Source>
          <FontImageSource FontFamily="MaterialSymbols"
                           Glyph="{x:Static helpers:MaterialIcons.Edit}"
                           Size="24"
                           Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight},
                                                    Dark={StaticResource ColorOnBackgroundDark}}" />
        </ImageButton.Source>
      </ImageButton>

      <!-- More Menu button -->
      <ImageButton Grid.Column="3"
                   Command="{Binding ShowMoreMenuCommand}"
                   WidthRequest="{StaticResource MinTouchTarget}"
                   HeightRequest="{StaticResource MinTouchTarget}"
                   BackgroundColor="Transparent"
                   AutomationId="ChatMoreMenuButton"
                   SemanticProperties.Description="More options">
        <ImageButton.Source>
          <FontImageSource FontFamily="MaterialSymbols"
                           Glyph="{x:Static helpers:MaterialIcons.MoreVert}"
                           Size="24"
                           Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight},
                                                    Dark={StaticResource ColorOnBackgroundDark}}" />
        </ImageButton.Source>
      </ImageButton>

    </Grid>

    <!-- Topbar bottom separator -->
    <BoxView Grid.Row="0"
             HeightRequest="0.5"
             VerticalOptions="End"
             Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight},
                                      Dark={StaticResource ColorSeparatorDark}}" />

    <!-- ═══════════════════════════════════════════════════════════════
         ROW 1 — Status Banner (visible only when StatusBanner != null)
         ═══════════════════════════════════════════════════════════════ -->
    <controls:StatusBannerView Grid.Row="1"
                               IsVisible="{Binding StatusBanner, Converter={StaticResource NullToVisibilityConverter}}"
                               Message="{Binding StatusBanner.Message, FallbackValue='', TargetNullValue=''}"
                               ActionLabel="{Binding StatusBanner.ActionLabel, FallbackValue='', TargetNullValue=''}"
                               BannerType="{Binding StatusBanner.Type, FallbackValue=None}" />

    <!-- ═══════════════════════════════════════════════════════════════
         ROW 2 — Body (message area + input bar)
         ═══════════════════════════════════════════════════════════════ -->
    <Grid Grid.Row="2"
          RowDefinitions="*,Auto"
          BackgroundColor="{AppThemeBinding Light={StaticResource ColorBackgroundLight},
                                            Dark={StaticResource ColorBackgroundDark}}">

      <!-- ─────────────────────────────────────────────────────────────
           Message Area — Empty state placeholder
           REQ-015 through REQ-019
           ───────────────────────────────────────────────────────────── -->
      <VerticalStackLayout Grid.Row="0"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Spacing="{StaticResource SpacingSm}"
                           Padding="{StaticResource SpacingXxl}">

        <Label Text="{x:Static helpers:MaterialIcons.Chat}"
               FontFamily="MaterialSymbols"
               FontSize="48"
               TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                            Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
               HorizontalOptions="Center"
               SemanticProperties.Description="Chat icon" />

        <Label Text="Start a conversation"
               Style="{StaticResource HeadlineLabel}"
               HorizontalTextAlignment="Center"
               HorizontalOptions="Center" />

        <Label Text="Type a message below to begin"
               Style="{StaticResource SubtitleLabel}"
               HorizontalTextAlignment="Center"
               HorizontalOptions="Center" />

      </VerticalStackLayout>

      <!--
          Future: CollectionView bound to Messages collection
          ═══════════════════════════════════════════════════════════════

          <CollectionView ItemsSource="{Binding Messages}"
                          ItemsUpdatingScrollMode="KeepLastItemInView"
                          SelectionMode="None">
              <CollectionView.ItemTemplate>
                  <DataTemplate x:DataType="viewmodels:ChatMessageViewModel">

                      User bubble: right-aligned, primary accent background, on-primary text
                      <Border BackgroundColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight},
                                                                 Dark={StaticResource ColorPrimaryDark}}"
                              StrokeShape="RoundRectangle 16,16,4,16"
                              HorizontalOptions="End"
                              Margin="64,4,16,4"
                              Padding="12,8">
                          <Label Text="{Binding Text}"
                                 TextColor="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight},
                                                              Dark={StaticResource ColorOnPrimaryDark}}" />
                      </Border>

                      Assistant bubble: left-aligned, surface secondary background, on-surface text
                      <Border BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight},
                                                                 Dark={StaticResource ColorSurfaceSecondaryDark}}"
                              StrokeShape="RoundRectangle 16,16,16,4"
                              HorizontalOptions="Start"
                              Margin="16,4,64,4"
                              Padding="12,8">
                          <Label Text="{Binding Text}"
                                 TextColor="{AppThemeBinding Light={StaticResource ColorOnSurfaceLight},
                                                              Dark={StaticResource ColorOnSurfaceDark}}" />
                      </Border>

                  </DataTemplate>
              </CollectionView.ItemTemplate>

              <CollectionView.EmptyView>
                  (empty state shown above)
              </CollectionView.EmptyView>
          </CollectionView>

          ═══════════════════════════════════════════════════════════════
      -->

      <!-- ─────────────────────────────────────────────────────────────
           Input Bar — fixed at bottom
           REQ-020 through REQ-025
           ───────────────────────────────────────────────────────────── -->
      <Grid Grid.Row="1">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Input bar top separator -->
        <BoxView Grid.Row="0"
                 HeightRequest="0.5"
                 VerticalOptions="Start"
                 Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight},
                                          Dark={StaticResource ColorSeparatorDark}}" />

        <!-- Input bar layout -->
        <Grid Grid.Row="1"
              ColumnDefinitions="Auto,*,Auto"
              Padding="{StaticResource SpacingSm}"
              ColumnSpacing="{StaticResource SpacingSm}"
              BackgroundColor="{AppThemeBinding Light={StaticResource ColorBackgroundLight},
                                                Dark={StaticResource ColorBackgroundDark}}">

          <!-- + button (attachment placeholder, not connected) -->
          <Border Grid.Column="0"
                  WidthRequest="36"
                  HeightRequest="36"
                  StrokeShape="RoundRectangle 18"
                  Stroke="{AppThemeBinding Light={StaticResource ColorOutlineLight},
                                            Dark={StaticResource ColorOutlineDark}}"
                  StrokeThickness="1.5"
                  BackgroundColor="Transparent"
                  VerticalOptions="End"
                  Padding="0"
                  SemanticProperties.Description="Attach file">
            <Label Text="{x:Static helpers:MaterialIcons.Add}"
                   FontFamily="MaterialSymbols"
                   FontSize="22"
                   TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight},
                                                Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
          </Border>

          <!-- Pill-shaped text field with mic overlay -->
          <Border Grid.Column="1"
                  StrokeShape="RoundRectangle 22"
                  Stroke="Transparent"
                  StrokeThickness="0"
                  BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight},
                                                    Dark={StaticResource ColorSurfaceSecondaryDark}}"
                  Padding="0"
                  VerticalOptions="End">
            <Grid ColumnDefinitions="*,Auto">

              <Editor x:Name="MessageEditor"
                      Grid.Column="0"
                      Placeholder="Message"
                      PlaceholderColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                                          Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                      FontFamily="InterRegular"
                      FontSize="{StaticResource FontSizeBody}"
                      TextColor="{AppThemeBinding Light={StaticResource ColorOnSurfaceLight},
                                                    Dark={StaticResource ColorOnSurfaceDark}}"
                      BackgroundColor="Transparent"
                      AutoSize="TextChanges"
                      MinimumHeightRequest="{StaticResource MinTouchTarget}"
                      MaximumHeightRequest="120"
                      Margin="16,8,0,8"
                      TextChanged="OnMessageEditorTextChanged"
                      AutomationId="ChatMessageEditor"
                      SemanticProperties.Hint="Type your message here" />

              <!-- Mic icon — visible when Editor is empty, hidden when typing -->
              <Label x:Name="MicIcon"
                     Grid.Column="1"
                     Text="{x:Static helpers:MaterialIcons.Mic}"
                     FontFamily="MaterialSymbols"
                     FontSize="22"
                     TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight},
                                                  Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                     VerticalOptions="Center"
                     Margin="0,0,12,0"
                     IsVisible="True"
                     SemanticProperties.Description="Voice input" />

            </Grid>
          </Border>

          <!-- Send button — green when text present, gray when empty -->
          <Border x:Name="SendButton"
                  Grid.Column="2"
                  WidthRequest="36"
                  HeightRequest="36"
                  StrokeShape="RoundRectangle 18"
                  Stroke="Transparent"
                  StrokeThickness="0"
                  BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight},
                                                    Dark={StaticResource ColorSurfaceSecondaryDark}}"
                  VerticalOptions="End"
                  Padding="0"
                  SemanticProperties.Description="Send message"
                  AutomationId="ChatSendButton">
            <Label x:Name="SendIcon"
                   Text="{x:Static helpers:MaterialIcons.ArrowUpward}"
                   FontFamily="MaterialSymbols"
                   FontSize="22"
                   TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                                Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
          </Border>

        </Grid>
      </Grid>

    </Grid>

  </Grid>

</ContentPage>
