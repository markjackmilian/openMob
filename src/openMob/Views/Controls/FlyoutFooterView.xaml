<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="openMob.Views.Controls.FlyoutFooterView">

  <VerticalStackLayout
      BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}"
      Padding="0,8">

    <!-- Separator -->
    <BoxView
        HeightRequest="1"
        Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight}, Dark={StaticResource ColorSeparatorDark}}"
        Margin="0,0,0,8" />

    <!-- Projects -->
    <Grid
        ColumnDefinitions="Auto,*"
        Padding="16,12"
        BackgroundColor="Transparent">
      <Grid.GestureRecognizers>
        <TapGestureRecognizer Tapped="OnProjectsTapped" />
      </Grid.GestureRecognizers>
      <Label
          Grid.Column="0"
          Text="&#x1F4C1;"
          FontSize="{StaticResource FontSizeBody}"
          VerticalOptions="Center"
          Margin="0,0,12,0" />
      <Label
          Grid.Column="1"
          Text="Projects"
          Style="{StaticResource BodyLabel}"
          VerticalOptions="Center" />
    </Grid>

    <!-- Settings -->
    <Grid
        ColumnDefinitions="Auto,*"
        Padding="16,12"
        BackgroundColor="Transparent">
      <Grid.GestureRecognizers>
        <TapGestureRecognizer Tapped="OnSettingsTapped" />
      </Grid.GestureRecognizers>
      <Label
          Grid.Column="0"
          Text="&#x2699;"
          FontSize="{StaticResource FontSizeBody}"
          VerticalOptions="Center"
          Margin="0,0,12,0" />
      <Label
          Grid.Column="1"
          Text="Settings"
          Style="{StaticResource BodyLabel}"
          VerticalOptions="Center" />
    </Grid>

    <!-- Version (dynamic from AppInfo) -->
    <Label
        x:Name="VersionLabel"
        Style="{StaticResource Caption2Label}"
        TextColor="{AppThemeBinding Light={StaticResource ColorOnSurfaceTertiaryLight}, Dark={StaticResource ColorOnSurfaceTertiaryDark}}"
        HorizontalTextAlignment="Center"
        Margin="0,8,0,8" />

  </VerticalStackLayout>

</ContentView>
