<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
             x:Class="openMob.Views.Controls.OnboardingConnectServerView"
             x:DataType="vm:OnboardingViewModel">

  <VerticalStackLayout
      Spacing="{StaticResource SpacingLg}"
      Padding="{StaticResource SpacingXl}">

    <!-- Title -->
    <Label
        Text="Connect your server"
        Style="{StaticResource Title2Label}"
        FontFamily="InterBold" />

    <!-- Subtitle -->
    <Label
        Text="Enter the URL and access token for your opencode server."
        Style="{StaticResource CalloutLabel}"
        FontFamily="InterRegular"
        Margin="0,0,0,8" />

    <!-- Server URL -->
    <VerticalStackLayout Spacing="{StaticResource SpacingXs}">
      <Label
          Text="Server URL"
          Style="{StaticResource SubtitleLabel}"
          FontFamily="InterRegular" />
      <Entry
          Text="{Binding ServerUrl, Mode=TwoWay}"
          Placeholder="https://your-server.example.com"
          Keyboard="Url"
          Style="{StaticResource OutlinedEntry}"
          AutomationId="OnboardingServerUrlEntry"
          SemanticProperties.Hint="Enter the URL of your opencode server" />
    </VerticalStackLayout>

    <!-- Server Token -->
    <VerticalStackLayout Spacing="{StaticResource SpacingXs}">
      <Label
          Text="Access Token"
          Style="{StaticResource SubtitleLabel}"
          FontFamily="InterRegular" />
      <Entry
          Text="{Binding ServerToken, Mode=TwoWay}"
          Placeholder="sk-..."
          IsPassword="True"
          Style="{StaticResource OutlinedEntry}"
          AutomationId="OnboardingServerTokenEntry"
          SemanticProperties.Hint="Enter your server access token" />
    </VerticalStackLayout>

    <!-- Test Connection Button -->
    <Button
        Text="Test Connection"
        Command="{Binding TestConnectionCommand}"
        Style="{StaticResource SecondaryButton}"
        IsEnabled="{Binding IsTestingConnection, Converter={StaticResource InvertedBoolConverter}}"
        AutomationId="OnboardingTestConnectionButton"
        HorizontalOptions="Start" />

    <!-- Connection Status -->
    <HorizontalStackLayout
        Spacing="{StaticResource SpacingSm}"
        IsVisible="{Binding IsConnectionTested}">

      <!-- Status indicator -->
      <Border
          WidthRequest="12"
          HeightRequest="12"
          StrokeShape="RoundRectangle 6"
          StrokeThickness="0"
          BackgroundColor="{AppThemeBinding Light={StaticResource ColorOnSurfaceTertiaryLight}, Dark={StaticResource ColorOnSurfaceTertiaryDark}}"
          VerticalOptions="Center">
        <Border.Triggers>
          <DataTrigger TargetType="Border"
                       Binding="{Binding IsConnectionSuccessful}"
                       Value="True">
            <Setter Property="BackgroundColor"
                    Value="{AppThemeBinding Light={StaticResource ColorSuccessLight}, Dark={StaticResource ColorSuccessDark}}" />
          </DataTrigger>
          <DataTrigger TargetType="Border"
                       Binding="{Binding IsConnectionSuccessful}"
                       Value="False">
            <Setter Property="BackgroundColor"
                    Value="{AppThemeBinding Light={StaticResource ColorErrorLight}, Dark={StaticResource ColorErrorDark}}" />
          </DataTrigger>
        </Border.Triggers>
      </Border>

      <Label
          Text="{Binding ConnectionStatusMessage, FallbackValue='', TargetNullValue=''}"
          Style="{StaticResource SubtitleLabel}" />
    </HorizontalStackLayout>

    <!-- Loading indicator -->
    <ActivityIndicator
        IsRunning="{Binding IsTestingConnection}"
        IsVisible="{Binding IsTestingConnection}"
        HorizontalOptions="Center" />

  </VerticalStackLayout>

</ContentView>
