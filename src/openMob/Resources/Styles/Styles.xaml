<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         TYPOGRAPHY SCALE — Apple HIG text style sizes
         Reference these tokens; never hardcode font sizes in UI XAML.
         ═══════════════════════════════════════════════════════════════ -->
    <x:Double x:Key="FontSizeLargeTitle">34</x:Double>
    <x:Double x:Key="FontSizeTitle1">28</x:Double>
    <x:Double x:Key="FontSizeTitle2">22</x:Double>
    <x:Double x:Key="FontSizeTitle3">20</x:Double>
    <x:Double x:Key="FontSizeHeadline">17</x:Double>
    <x:Double x:Key="FontSizeBody">17</x:Double>
    <x:Double x:Key="FontSizeCallout">16</x:Double>
    <x:Double x:Key="FontSizeSubheadline">15</x:Double>
    <x:Double x:Key="FontSizeFootnote">13</x:Double>
    <x:Double x:Key="FontSizeCaption1">12</x:Double>
    <x:Double x:Key="FontSizeCaption2">11</x:Double>

    <!-- Extended icon sizes — for decorative/hero icons beyond the text scale -->
    <x:Double x:Key="FontSizeIconXl">24</x:Double>
    <x:Double x:Key="FontSizeIconXxl">48</x:Double>
    <x:Double x:Key="FontSizeIconHero">64</x:Double>

    <!-- ═══════════════════════════════════════════════════════════════
         SPACING SCALE — all values are multiples of 4pt
         Reference these tokens; never hardcode spacing in UI XAML.
         ═══════════════════════════════════════════════════════════════ -->
    <x:Double x:Key="SpacingXxs">2</x:Double>
    <x:Double x:Key="SpacingXs">4</x:Double>
    <x:Double x:Key="SpacingSm">8</x:Double>
    <x:Double x:Key="SpacingMd">12</x:Double>
    <x:Double x:Key="SpacingLg">16</x:Double>
    <x:Double x:Key="SpacingXl">24</x:Double>
    <x:Double x:Key="SpacingXxl">32</x:Double>
    <x:Double x:Key="SpacingXxxl">48</x:Double>

    <!-- ═══════════════════════════════════════════════════════════════
         BORDER RADIUS SCALE
         ═══════════════════════════════════════════════════════════════ -->
    <x:Double x:Key="RadiusXs">4</x:Double>
    <x:Double x:Key="RadiusSm">8</x:Double>
    <x:Double x:Key="RadiusMd">12</x:Double>
    <x:Double x:Key="RadiusLg">16</x:Double>
    <x:Double x:Key="RadiusXl">24</x:Double>
    <x:Double x:Key="RadiusFull">999</x:Double>

    <!-- ═══════════════════════════════════════════════════════════════
         MINIMUM TOUCH TARGET — WCAG / Apple HIG 44pt minimum
         ═══════════════════════════════════════════════════════════════ -->
    <x:Double x:Key="MinTouchTarget">44</x:Double>

    <!-- ═══════════════════════════════════════════════════════════════
         CHAT PAGE REDESIGN SIZING TOKENS
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Message block left color bar width (pt) -->
    <x:Double x:Key="SizeMessageBarWidth">3</x:Double>

    <!-- Context status bar height (pt) -->
    <x:Double x:Key="SizeContextBarHeight">28</x:Double>

    <!-- Bottom sheet handle width (pt) -->
    <x:Double x:Key="SizeSheetHandleWidth">36</x:Double>

    <!-- Bottom sheet handle height (pt) -->
    <x:Double x:Key="SizeSheetHandleHeight">4</x:Double>

    <!-- Context sheet row height (pt) -->
    <x:Double x:Key="SizeSheetRowHeight">56</x:Double>

    <!-- ═══════════════════════════════════════════════════════════════
         IMPLICIT STYLES
         Applied automatically to all matching controls in the app.
         No x:Key — these are the default appearance for each control.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ActivityIndicator -->
    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
    </Style>

    <!-- Label — body text defaults -->
    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" />
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- Button — primary accent, semibold, 44pt minimum touch target -->
    <Style TargetType="Button">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight}, Dark={StaticResource ColorOnPrimaryDark}}" />
        <Setter Property="FontFamily" Value="InterBold" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTouchTarget}" />
        <Setter Property="MinimumWidthRequest" Value="{StaticResource MinTouchTarget}" />
        <Setter Property="CharacterSpacing" Value="0.2" />
    </Style>

    <!-- Entry — surface background, outline border, comfortable padding -->
    <Style TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnSurfaceLight}, Dark={StaticResource ColorOnSurfaceDark}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource ColorOnSurfaceTertiaryLight}, Dark={StaticResource ColorOnSurfaceTertiaryDark}}" />
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTouchTarget}" />
    </Style>

    <!-- Editor — multiline text input -->
    <Style TargetType="Editor">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnSurfaceLight}, Dark={StaticResource ColorOnSurfaceDark}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource ColorOnSurfaceTertiaryLight}, Dark={StaticResource ColorOnSurfaceTertiaryDark}}" />
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTouchTarget}" />
    </Style>

    <!-- Border — card/panel container -->
    <Style TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource ColorOutlineLight}, Dark={StaticResource ColorOutlineDark}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="Padding" Value="{StaticResource SpacingLg}" />
    </Style>

    <!-- Frame — legacy card container (kept for compatibility) -->
    <Style TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}" />
        <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource ColorOutlineLight}, Dark={StaticResource ColorOutlineDark}}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="{StaticResource SpacingLg}" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <!-- SearchBar — secondary surface, no visible border -->
    <Style TargetType="SearchBar">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight}, Dark={StaticResource ColorSurfaceSecondaryDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnSurfaceLight}, Dark={StaticResource ColorOnSurfaceDark}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource ColorOnSurfaceTertiaryLight}, Dark={StaticResource ColorOnSurfaceTertiaryDark}}" />
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTouchTarget}" />
    </Style>

    <!-- Switch — accent track color -->
    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
        <Setter Property="ThumbColor" Value="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight}, Dark={StaticResource ColorOnPrimaryDark}}" />
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTouchTarget}" />
    </Style>

    <!-- Slider — accent track and thumb -->
    <Style TargetType="Slider">
        <Setter Property="MinimumTrackColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
        <Setter Property="MaximumTrackColor" Value="{AppThemeBinding Light={StaticResource ColorOutlineLight}, Dark={StaticResource ColorOutlineDark}}" />
        <Setter Property="ThumbColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTouchTarget}" />
    </Style>

    <!-- CheckBox -->
    <Style TargetType="CheckBox">
        <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTouchTarget}" />
        <Setter Property="MinimumWidthRequest" Value="{StaticResource MinTouchTarget}" />
    </Style>

    <!-- Picker -->
    <Style TargetType="Picker">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnSurfaceLight}, Dark={StaticResource ColorOnSurfaceDark}}" />
        <Setter Property="TitleColor" Value="{AppThemeBinding Light={StaticResource ColorOnSurfaceTertiaryLight}, Dark={StaticResource ColorOnSurfaceTertiaryDark}}" />
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTouchTarget}" />
    </Style>

    <!-- DatePicker -->
    <Style TargetType="DatePicker">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnSurfaceLight}, Dark={StaticResource ColorOnSurfaceDark}}" />
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTouchTarget}" />
    </Style>

    <!-- TimePicker -->
    <Style TargetType="TimePicker">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnSurfaceLight}, Dark={StaticResource ColorOnSurfaceDark}}" />
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTouchTarget}" />
    </Style>

    <!-- Page — background color for all pages -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorBackgroundLight}, Dark={StaticResource ColorBackgroundDark}}" />
    </Style>

    <!-- Shell — navigation chrome colors -->
    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorNavigationBarLight}, Dark={StaticResource ColorNavigationBarDark}}" />
        <Setter Property="Shell.ForegroundColor" Value="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" />
        <Setter Property="Shell.TitleColor" Value="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" />
        <Setter Property="Shell.DisabledColor" Value="{AppThemeBinding Light={StaticResource ColorDisabledLight}, Dark={StaticResource ColorDisabledDark}}" />
        <Setter Property="Shell.UnselectedColor" Value="{AppThemeBinding Light={StaticResource ColorTabBarUnselectedLight}, Dark={StaticResource ColorTabBarUnselectedDark}}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorTabBarLight}, Dark={StaticResource ColorTabBarDark}}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{AppThemeBinding Light={StaticResource ColorTabBarSelectedLight}, Dark={StaticResource ColorTabBarSelectedDark}}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{AppThemeBinding Light={StaticResource ColorTabBarSelectedLight}, Dark={StaticResource ColorTabBarSelectedDark}}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{AppThemeBinding Light={StaticResource ColorTabBarUnselectedLight}, Dark={StaticResource ColorTabBarUnselectedDark}}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         ICON LABEL STYLES — for Tabler Icons font glyphs
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Standard icon label (17pt, matches Headline size) -->
    <!-- NOTE: OnPlatform as a standalone ResourceDictionary entry crashes on iOS with MAUI 10.
         FontFamily is set inline per-platform inside each Style using OnPlatform.
         The 52 Label elements across the app use FontFamily="{StaticResource TablerIconsFont}"
         which is registered in App.xaml.cs code-behind after InitializeComponent(). -->
    <Style x:Key="IconLabel" TargetType="Label">
        <Setter Property="FontFamily">
            <Setter.Value>
                <OnPlatform x:TypeArguments="x:String">
                    <On Platform="Android" Value="tabler-icons.ttf#tabler-icons" />
                    <On Platform="iOS" Value="TablerIcons" />
                </OnPlatform>
            </Setter.Value>
        </Setter>
        <Setter Property="FontSize" Value="{StaticResource FontSizeHeadline}" />
        <Setter Property="LineBreakMode" Value="NoWrap" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
    </Style>

    <!-- Large icon label (20pt, matches Title3 size) — for larger touch-target icons -->
    <Style x:Key="IconLabelLg" TargetType="Label">
        <Setter Property="FontFamily">
            <Setter.Value>
                <OnPlatform x:TypeArguments="x:String">
                    <On Platform="Android" Value="tabler-icons.ttf#tabler-icons" />
                    <On Platform="iOS" Value="TablerIcons" />
                </OnPlatform>
            </Setter.Value>
        </Setter>
        <Setter Property="FontSize" Value="{StaticResource FontSizeTitle3}" />
        <Setter Property="LineBreakMode" Value="NoWrap" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         EXPLICIT LABEL STYLES — typography hierarchy
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Large display title (e.g. onboarding hero, empty state headline) -->
    <Style x:Key="LargeTitleLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="InterBold" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeLargeTitle}" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- Screen / section title -->
    <Style x:Key="Title1Label" TargetType="Label">
        <Setter Property="FontFamily" Value="InterBold" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeTitle1}" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="Title2Label" TargetType="Label">
        <Setter Property="FontFamily" Value="InterBold" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeTitle2}" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="Title3Label" TargetType="Label">
        <Setter Property="FontFamily" Value="InterBold" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeTitle3}" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- Headline — semibold body-size, for list item titles, card headers -->
    <Style x:Key="HeadlineLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="InterSemiBold" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeHeadline}" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- Body — default readable text -->
    <Style x:Key="BodyLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- Callout — slightly smaller body, for supporting text -->
    <Style x:Key="CalloutLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="InterMedium" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeCallout}" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- Subtitle — secondary text below a headline -->
    <Style x:Key="SubtitleLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSubheadline}" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- Footnote — small supporting text, timestamps, hints -->
    <Style x:Key="FootnoteLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeFootnote}" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- Caption — smallest readable text, metadata, badges -->
    <Style x:Key="CaptionLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption1}" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- Caption2 — ultra-small, use sparingly -->
    <Style x:Key="Caption2Label" TargetType="Label">
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption2}" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- Accent / link text -->
    <Style x:Key="LinkLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="InterMedium" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- Error / destructive text -->
    <Style x:Key="ErrorLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeFootnote}" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorErrorLight}, Dark={StaticResource ColorErrorDark}}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         EXPLICIT BUTTON STYLES
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Primary — accent fill, white label (inherits implicit Button style) -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="FontFamily" Value="InterSemiBold" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight}, Dark={StaticResource ColorOnPrimaryDark}}" />
    </Style>

    <!-- Secondary — outlined, no fill -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="FontFamily" Value="InterSemiBold" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
        <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
        <Setter Property="BorderWidth" Value="1.5" />
    </Style>

    <!-- Tertiary / Ghost — no fill, no border, accent text -->
    <Style x:Key="TertiaryButton" TargetType="Button">
        <Setter Property="FontFamily" Value="InterSemiBold" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <!-- Destructive — error red fill -->
    <Style x:Key="DestructiveButton" TargetType="Button">
        <Setter Property="FontFamily" Value="InterSemiBold" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorErrorLight}, Dark={StaticResource ColorErrorDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnErrorLight}, Dark={StaticResource ColorOnErrorDark}}" />
    </Style>

    <!-- Destructive Outlined — error red border, no fill -->
    <Style x:Key="DestructiveOutlinedButton" TargetType="Button">
        <Setter Property="FontFamily" Value="InterSemiBold" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorErrorLight}, Dark={StaticResource ColorErrorDark}}" />
        <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource ColorErrorLight}, Dark={StaticResource ColorErrorDark}}" />
        <Setter Property="BorderWidth" Value="1.5" />
    </Style>

    <!-- Disabled — muted surface, no interaction -->
    <Style x:Key="DisabledButton" TargetType="Button">
        <Setter Property="FontFamily" Value="InterSemiBold" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorDisabledSurfaceLight}, Dark={StaticResource ColorDisabledSurfaceDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorDisabledLight}, Dark={StaticResource ColorDisabledDark}}" />
        <Setter Property="IsEnabled" Value="False" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         EXPLICIT CARD / CONTAINER STYLES
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Standard card — surface background, subtle border, standard radius -->
    <Style x:Key="CardFrame" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}" />
        <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource ColorOutlineLight}, Dark={StaticResource ColorOutlineDark}}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="{StaticResource SpacingLg}" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <!-- Elevated card — surface with shadow (iOS) / elevation (Android) -->
    <Style x:Key="ElevatedCardFrame" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}" />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="{StaticResource SpacingLg}" />
        <Setter Property="HasShadow" Value="True" />
    </Style>

    <!-- Tinted card — accent-tinted background for highlighted content -->
    <Style x:Key="TintedCardFrame" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryContainerLight}, Dark={StaticResource ColorPrimaryContainerDark}}" />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="{StaticResource SpacingLg}" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <!-- Standard Border card (preferred over Frame for new code) -->
    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource ColorOutlineLight}, Dark={StaticResource ColorOutlineDark}}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="Padding" Value="{StaticResource SpacingLg}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         EXPLICIT ENTRY / EDITOR STYLES
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Outlined input — visible border, surface background -->
    <Style x:Key="OutlinedEntry" TargetType="Entry">
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnSurfaceLight}, Dark={StaticResource ColorOnSurfaceDark}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource ColorOnSurfaceTertiaryLight}, Dark={StaticResource ColorOnSurfaceTertiaryDark}}" />
    </Style>

    <!-- Filled input — secondary surface background, no border -->
    <Style x:Key="FilledEntry" TargetType="Entry">
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight}, Dark={StaticResource ColorSurfaceSecondaryDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnSurfaceLight}, Dark={StaticResource ColorOnSurfaceDark}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource ColorOnSurfaceTertiaryLight}, Dark={StaticResource ColorOnSurfaceTertiaryDark}}" />
    </Style>

    <!-- Outlined editor — multiline, visible border -->
    <Style x:Key="OutlinedEditor" TargetType="Editor">
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnSurfaceLight}, Dark={StaticResource ColorOnSurfaceDark}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource ColorOnSurfaceTertiaryLight}, Dark={StaticResource ColorOnSurfaceTertiaryDark}}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         CHAT COMPONENT STYLES
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Chat Bubble — sent (user) message border -->
    <Style x:Key="MessageBubbleSentBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorBubbleSentLight}, Dark={StaticResource ColorBubbleSentDark}}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="{StaticResource SpacingMd}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16,16,4,16" />
    </Style>

    <!-- Chat Bubble — received (AI) message border -->
    <Style x:Key="MessageBubbleReceivedBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorBubbleReceivedLight}, Dark={StaticResource ColorBubbleReceivedDark}}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="{StaticResource SpacingMd}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16,16,16,4" />
    </Style>

    <!-- Chat Input Bar — editor field -->
    <Style x:Key="InputBarEditor" TargetType="Editor">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorInputFieldBackgroundLight}, Dark={StaticResource ColorInputFieldBackgroundDark}}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" />
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnSurfaceLight}, Dark={StaticResource ColorOnSurfaceDark}}" />
    </Style>

    <!-- Suggestion Chip — tappable card border -->
    <Style x:Key="SuggestionChipBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource ColorOutlineLight}, Dark={StaticResource ColorOutlineDark}}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="Padding" Value="{StaticResource SpacingMd}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         CHAT PAGE REDESIGN COMPONENT STYLES
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Message block container (replaces bubble styles) -->
    <Style x:Key="MessageBlockBorder" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="{StaticResource SpacingSm}" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="0" />
        </Setter>
    </Style>

    <!-- Context status bar style -->
    <Style x:Key="ContextStatusBarLabel" TargetType="Label">
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption1}" />
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
    </Style>

    <!-- Sheet handle bar style -->
    <Style x:Key="SheetHandleBar" TargetType="BoxView">
        <Setter Property="WidthRequest" Value="{StaticResource SizeSheetHandleWidth}" />
        <Setter Property="HeightRequest" Value="{StaticResource SizeSheetHandleHeight}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusFull}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="Margin" Value="0,8,0,12" />
    </Style>

    <!-- Sheet tappable row style -->
    <Style x:Key="SheetRowGrid" TargetType="Grid">
        <Setter Property="HeightRequest" Value="{StaticResource SizeSheetRowHeight}" />
        <Setter Property="Padding" Value="{StaticResource SpacingLg}" />
    </Style>

    <!-- Code block container style -->
    <Style x:Key="CodeBlockBorder" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="{StaticResource SpacingMd}" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="{StaticResource RadiusMd}" />
        </Setter>
    </Style>

    <!-- Blockquote container style -->
    <Style x:Key="BlockquoteBorder" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="{StaticResource SpacingMd}" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="{StaticResource RadiusSm}" />
        </Setter>
    </Style>

    <!-- Sender label style -->
    <Style x:Key="SenderLabel" TargetType="Label">
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption1}" />
        <Setter Property="FontFamily" Value="InterSemiBold" />
    </Style>

    <!-- Timestamp label style -->
    <Style x:Key="TimestampLabel" TargetType="Label">
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption2}" />
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="HorizontalTextAlignment" Value="End" />
    </Style>

    <!-- Message body label style — used in MessageBlockView for user message text -->
    <Style x:Key="MessageBodyLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" />
    </Style>

    <!-- Command palette search field style -->
    <Style x:Key="CommandPaletteSearchBar" TargetType="SearchBar">
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="FontFamily" Value="InterRegular" />
        <Setter Property="Placeholder" Value="Search commands..." />
    </Style>

</ResourceDictionary>
