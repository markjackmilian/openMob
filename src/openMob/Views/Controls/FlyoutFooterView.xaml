<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
              xmlns:helpers="clr-namespace:openMob.Helpers"
              xmlns:controls="clr-namespace:openMob.Views.Controls"
              x:Class="openMob.Views.Controls.FlyoutFooterView"
              x:DataType="controls:FlyoutFooterView">

  <VerticalStackLayout
      BackgroundColor="{AppThemeBinding Light={StaticResource ColorBackgroundLight}, Dark={StaticResource ColorBackgroundDark}}"
      Padding="0,8">

    <!-- Separator -->
    <BoxView
        HeightRequest="0.5"
        Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight}, Dark={StaticResource ColorSeparatorDark}}"
        Margin="0,0,0,8" />

    <!-- Projects -->
    <Grid
        ColumnDefinitions="Auto,*"
        Padding="16,12"
        BackgroundColor="Transparent"
        MinimumHeightRequest="{StaticResource MinTouchTarget}">
      <Grid.GestureRecognizers>
        <TapGestureRecognizer Tapped="OnProjectsTapped" />
      </Grid.GestureRecognizers>
      <Label
          Grid.Column="0"
          FontFamily="TablerIcons"
          Text="{x:Static helpers:IconKeys.Folder}"
          FontSize="{StaticResource FontSizeTitle2}"
          TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
          VerticalOptions="Center"
          Margin="0,0,12,0"
          SemanticProperties.Description="Projects folder icon" />
      <Label
          Grid.Column="1"
          Text="Projects"
          FontFamily="InterMedium"
          FontSize="{StaticResource FontSizeCallout}"
          TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
          VerticalOptions="Center" />
    </Grid>

    <!-- Settings -->
    <Grid
        ColumnDefinitions="Auto,*"
        Padding="16,12"
        BackgroundColor="Transparent"
        MinimumHeightRequest="{StaticResource MinTouchTarget}">
      <Grid.GestureRecognizers>
        <TapGestureRecognizer Tapped="OnSettingsTapped" />
      </Grid.GestureRecognizers>
      <Label
          Grid.Column="0"
          FontFamily="TablerIcons"
          Text="{x:Static helpers:IconKeys.Settings}"
          FontSize="{StaticResource FontSizeTitle2}"
          TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
          VerticalOptions="Center"
          Margin="0,0,12,0"
          SemanticProperties.Description="Settings gear icon" />
      <Label
          Grid.Column="1"
          Text="Settings"
          FontFamily="InterMedium"
          FontSize="{StaticResource FontSizeCallout}"
          TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
          VerticalOptions="Center" />
    </Grid>

    <!-- Version (dynamic from AppInfo) -->
    <Label
        x:Name="VersionLabel"
        FontFamily="InterRegular"
        FontSize="{StaticResource FontSizeCaption2}"
        TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
        HorizontalTextAlignment="Center"
        Margin="0,8,0,8" />

  </VerticalStackLayout>

</ContentView>
