<?xml version="1.0" encoding="utf-8" ?>
<uxd:PopupPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:uxd="clr-namespace:UXDivers.Popups.Maui;assembly=UXDivers.Popups.Maui"
               xmlns:vm="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
               xmlns:models="clr-namespace:openMob.Core.Models;assembly=openMob.Core"
               xmlns:helpers="clr-namespace:openMob.Helpers"
               x:Class="openMob.Views.Popups.ModelPickerSheet"
               x:DataType="vm:ModelPickerViewModel"
               BackgroundColor="{DynamicResource PopupBackdropColor}"
               CloseWhenBackgroundIsClicked="True"
               AppearingAnimation="{uxd:MoveInPopupAnimation MoveDirection=Bottom, Duration=300, Easing=CubicOut}"
               DisappearingAnimation="{uxd:MoveOutPopupAnimation MoveDirection=Bottom, Duration=250, Easing=CubicIn}">

  <Border VerticalOptions="End"
          HorizontalOptions="Fill"
          StrokeThickness="0"
          Padding="0"
          HeightRequest="460"
          BackgroundColor="{AppThemeBinding Light={StaticResource ColorBackgroundLight},
                                            Dark={StaticResource ColorBackgroundDark}}">
    <Border.StrokeShape>
      <RoundRectangle CornerRadius="20,20,0,0" />
    </Border.StrokeShape>
    <Border.Shadow>
      <Shadow Brush="Black" Opacity="0.15" Offset="0,-2" Radius="16" />
    </Border.Shadow>

  <Grid RowDefinitions="Auto,Auto,Auto,*">

    <!-- Handle bar -->
    <BoxView
        Grid.Row="0"
        Style="{StaticResource SheetHandleBar}"
        Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" />

    <!-- Header with title and close button -->
    <Grid Grid.Row="1"
          ColumnDefinitions="*,Auto"
          Padding="16,0,16,16">
      <Label
          Grid.Column="0"
          Text="Select Model"
          Style="{StaticResource Title3Label}"
          VerticalOptions="Center" />
      <ImageButton
          Grid.Column="1"
          Clicked="OnCloseButtonTapped"
          MinimumHeightRequest="{StaticResource MinTouchTarget}"
          MinimumWidthRequest="{StaticResource MinTouchTarget}"
          BackgroundColor="Transparent"
          AutomationId="ModelPickerCloseButton"
          SemanticProperties.Description="Close model picker">
        <ImageButton.Source>
          <FontImageSource FontFamily="TablerIcons"
                           Glyph="{x:Static helpers:IconKeys.X}"
                           Size="{StaticResource FontSizeIconXl}"
                           Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight},
                                                    Dark={StaticResource ColorOnBackgroundDark}}" />
        </ImageButton.Source>
      </ImageButton>
    </Grid>

    <!-- ═══════════════════════════════════════════════════════════════
         Loading state (REQ-002)
         ═══════════════════════════════════════════════════════════════ -->
    <ActivityIndicator
        Grid.Row="2"
        IsRunning="{Binding IsLoading}"
        IsVisible="{Binding IsLoading}"
        HorizontalOptions="Center"
        Margin="0,32"
        SemanticProperties.Description="Loading models" />

    <!-- ═══════════════════════════════════════════════════════════════
         Empty state (REQ-003) — visible when IsEmpty and not loading
         ═══════════════════════════════════════════════════════════════ -->
    <VerticalStackLayout
        Grid.Row="3"
        IsVisible="False"
        Spacing="{StaticResource SpacingSm}"
        HorizontalOptions="Center"
        Padding="{StaticResource SpacingXxl}">
      <VerticalStackLayout.Triggers>
        <MultiTrigger TargetType="VerticalStackLayout">
          <MultiTrigger.Conditions>
            <BindingCondition Binding="{Binding IsEmpty}" Value="True" />
            <BindingCondition Binding="{Binding IsLoading}" Value="False" />
          </MultiTrigger.Conditions>
          <Setter Property="IsVisible" Value="True" />
        </MultiTrigger>
      </VerticalStackLayout.Triggers>

      <Label
          Text="{x:Static helpers:IconKeys.Robot}"
          FontFamily="TablerIcons"
          FontSize="{StaticResource FontSizeIconXxl}"
          TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
          HorizontalOptions="Center"
          SemanticProperties.Description="No models icon" />

      <Label
          Text="No models available"
          Style="{StaticResource HeadlineLabel}"
          HorizontalTextAlignment="Center"
          HorizontalOptions="Center" />

      <Label
          Text="Configure a provider to view available models."
          Style="{StaticResource SubtitleLabel}"
          HorizontalTextAlignment="Center"
          HorizontalOptions="Center" />

      <Button
          Text="Configure Provider"
          Style="{StaticResource SecondaryButton}"
          Command="{Binding ConfigureProvidersCommand}"
          HorizontalOptions="Center"
          Margin="0,8,0,0"
          AutomationId="ConfigureProvidersButton"
          SemanticProperties.Description="Navigate to provider settings" />
    </VerticalStackLayout>

    <!-- ═══════════════════════════════════════════════════════════════
         Model list — flat, virtualised (REQ-001)
         Replaces the previous BindableLayout approach that created all
         elements eagerly and blocked the main thread with large lists.
         ═══════════════════════════════════════════════════════════════ -->
    <CollectionView
        Grid.Row="3"
        ItemsSource="{Binding Models}"
        SelectionMode="None"
        IsVisible="False">
      <CollectionView.Triggers>
        <MultiTrigger TargetType="CollectionView">
          <MultiTrigger.Conditions>
            <BindingCondition Binding="{Binding IsEmpty}" Value="False" />
            <BindingCondition Binding="{Binding IsLoading}" Value="False" />
          </MultiTrigger.Conditions>
          <Setter Property="IsVisible" Value="True" />
        </MultiTrigger>
      </CollectionView.Triggers>

      <CollectionView.ItemTemplate>
        <DataTemplate x:DataType="models:ModelItem">
          <VerticalStackLayout Spacing="0" Padding="16,0">
            <Grid
                ColumnDefinitions="*,Auto"
                Padding="0,14"
                ColumnSpacing="{StaticResource SpacingMd}"
                MinimumHeightRequest="{StaticResource MinTouchTarget}">
              <Grid.GestureRecognizers>
                <TapGestureRecognizer
                    Command="{Binding SelectModelCommand, Source={RelativeSource AncestorType={x:Type vm:ModelPickerViewModel}}}"
                    CommandParameter="{Binding Id}" />
              </Grid.GestureRecognizers>

              <!-- Model name, context size, and provider name -->
              <VerticalStackLayout
                  Grid.Column="0"
                  Spacing="{StaticResource SpacingXxs}"
                  VerticalOptions="Center">
                <Label
                    Text="{Binding Name, FallbackValue='Model'}"
                    FontFamily="InterMedium"
                    FontSize="{StaticResource FontSizeBody}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}"
                    LineBreakMode="TailTruncation"
                    MaxLines="1" />
                <Label
                    Text="{Binding ContextSize, FallbackValue='', TargetNullValue=''}"
                    FontFamily="InterRegular"
                    FontSize="{StaticResource FontSizeCaption1}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                    IsVisible="{Binding ContextSize, Converter={StaticResource NullToVisibilityConverter}}" />
                <Label
                    Text="{Binding ProviderName, FallbackValue='Provider'}"
                    FontFamily="InterRegular"
                    FontSize="{StaticResource FontSizeCaption1}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" />
              </VerticalStackLayout>

              <!-- Selection indicator: checkmark when selected -->
              <Label
                  Grid.Column="1"
                  FontFamily="TablerIcons"
                  Text="{x:Static helpers:IconKeys.Check}"
                  FontSize="{StaticResource FontSizeIconXl}"
                  TextColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}"
                  IsVisible="{Binding IsSelected}"
                  VerticalOptions="Center"
                  SemanticProperties.Description="Selected model" />
            </Grid>

            <!-- Separator -->
            <BoxView
                HeightRequest="0.5"
                Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight}, Dark={StaticResource ColorSeparatorDark}}" />
          </VerticalStackLayout>
        </DataTemplate>
      </CollectionView.ItemTemplate>
    </CollectionView>

  </Grid>
  </Border>

</uxd:PopupPage>
