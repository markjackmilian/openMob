<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:openMob.Core.Models;assembly=openMob.Core"
             x:Class="openMob.Views.Controls.FlyoutContentView">

  <VerticalStackLayout
      BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}">

    <!-- Section header: project name -->
    <Label
        x:Name="ProjectNameLabel"
        Text="SESSIONS"
        Style="{StaticResource CaptionLabel}"
        TextTransform="Uppercase"
        TextColor="{AppThemeBinding Light={StaticResource ColorOnSurfaceTertiaryLight}, Dark={StaticResource ColorOnSurfaceTertiaryDark}}"
        Margin="{StaticResource SpacingLg},12,{StaticResource SpacingLg},{StaticResource SpacingSm}" />

    <!-- Session list placeholder -->
    <Label
        Text="Select a project to view sessions"
        Style="{StaticResource CalloutLabel}"
        HorizontalTextAlignment="Center"
        Margin="{StaticResource SpacingLg}"
        TextColor="{AppThemeBinding Light={StaticResource ColorOnSurfaceTertiaryLight}, Dark={StaticResource ColorOnSurfaceTertiaryDark}}" />

  </VerticalStackLayout>

</ContentView>
