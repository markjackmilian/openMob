<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
             xmlns:models="clr-namespace:openMob.Core.Models;assembly=openMob.Core"
             xmlns:helpers="clr-namespace:openMob.Helpers"
             x:Class="openMob.Views.Popups.AgentPickerSheet"
             x:DataType="vm:AgentPickerViewModel"
             Title="Select Agent"
             Shell.PresentationMode="ModalAnimated"
             BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}">

  <VerticalStackLayout Spacing="0">

    <!-- Handle bar -->
    <BoxView
        WidthRequest="36"
        HeightRequest="4"
        CornerRadius="{StaticResource SpacingXxs}"
        Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
        HorizontalOptions="Center"
        Margin="0,8,0,16" />

    <!-- Header with title and close button -->
    <Grid ColumnDefinitions="*,Auto"
          Padding="16,0,16,16">
      <Label
          Grid.Column="0"
          Text="{Binding SheetTitle, FallbackValue='Select Agent'}"
          Style="{StaticResource Title3Label}"
          VerticalOptions="Center" />
      <ImageButton
          Grid.Column="1"
          Clicked="OnCloseButtonTapped"
          MinimumHeightRequest="{StaticResource MinTouchTarget}"
          MinimumWidthRequest="{StaticResource MinTouchTarget}"
          BackgroundColor="Transparent"
          AutomationId="AgentPickerCloseButton"
          SemanticProperties.Description="Close agent picker">
        <ImageButton.Source>
          <FontImageSource FontFamily="TablerIcons"
                           Glyph="{x:Static helpers:IconKeys.X}"
                           Size="24"
                           Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight},
                                                    Dark={StaticResource ColorOnBackgroundDark}}" />
        </ImageButton.Source>
      </ImageButton>
    </Grid>

    <!-- Loading indicator -->
    <ActivityIndicator
        IsRunning="{Binding IsLoading}"
        IsVisible="{Binding IsLoading}"
        HorizontalOptions="Center"
        Margin="0,16" />

    <!-- Agent list -->
    <CollectionView
        ItemsSource="{Binding Agents}"
        SelectionMode="None"
        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
      <CollectionView.ItemTemplate>
        <DataTemplate x:DataType="models:AgentItem">
          <VerticalStackLayout Spacing="0" Padding="16,0">
            <Grid
                ColumnDefinitions="Auto,*,Auto"
                Padding="0,14"
                ColumnSpacing="{StaticResource SpacingMd}"
                MinimumHeightRequest="{StaticResource MinTouchTarget}">
              <Grid.GestureRecognizers>
                <TapGestureRecognizer
                    Command="{Binding SelectAgentCommand, Source={RelativeSource AncestorType={x:Type vm:AgentPickerViewModel}}}"
                    CommandParameter="{Binding Name}" />
              </Grid.GestureRecognizers>

              <!-- Agent icon -->
              <Label
                  Grid.Column="0"
                  FontFamily="TablerIcons"
                  Text="{x:Static helpers:IconKeys.Robot}"
                  FontSize="{StaticResource FontSizeIconXl}"
                  TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                  VerticalOptions="Center"
                  SemanticProperties.Description="Agent icon" />

              <VerticalStackLayout
                  Grid.Column="1"
                  Spacing="{StaticResource SpacingXxs}"
                  VerticalOptions="Center">
                <Label
                    Text="{Binding Name, FallbackValue='build'}"
                    FontFamily="InterMedium"
                    FontSize="{StaticResource FontSizeBody}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" />
                <Label
                    Text="{Binding Description, FallbackValue='', TargetNullValue=''}"
                    FontFamily="InterRegular"
                    FontSize="{StaticResource FontSizeCaption1}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                    IsVisible="{Binding Description, Converter={StaticResource NullToVisibilityConverter}}" />
              </VerticalStackLayout>

              <!-- Checkmark for selected agent -->
              <Label
                  Grid.Column="2"
                  FontFamily="TablerIcons"
                  Text="{x:Static helpers:IconKeys.Check}"
                  FontSize="{StaticResource FontSizeIconXl}"
                  TextColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}"
                  IsVisible="{Binding IsSelected}"
                  VerticalOptions="Center"
                  SemanticProperties.Description="Selected" />
            </Grid>

            <BoxView
                HeightRequest="0.5"
                Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight}, Dark={StaticResource ColorSeparatorDark}}" />
          </VerticalStackLayout>
        </DataTemplate>
      </CollectionView.ItemTemplate>
      <CollectionView.EmptyView>
        <Label
            Text="No agents available"
            FontFamily="InterRegular"
            FontSize="{StaticResource FontSizeCallout}"
            TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
            HorizontalTextAlignment="Center"
            Margin="0,16" />
      </CollectionView.EmptyView>
    </CollectionView>

  </VerticalStackLayout>

</ContentPage>
