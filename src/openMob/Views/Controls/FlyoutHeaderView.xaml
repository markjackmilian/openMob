<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:openMob.Helpers"
             x:Class="openMob.Views.Controls.FlyoutHeaderView">

  <Grid
      ColumnDefinitions="*,Auto"
      Padding="{StaticResource SpacingLg}"
      BackgroundColor="{AppThemeBinding Light={StaticResource ColorBackgroundLight}, Dark={StaticResource ColorBackgroundDark}}">

    <!-- App name -->
    <Label
        Grid.Column="0"
        Text="openMob"
        FontFamily="InterBold"
        FontSize="{StaticResource FontSizeTitle2}"
        TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}"
        VerticalOptions="Center" />

    <!-- New chat button -->
    <ImageButton
        Grid.Column="1"
        BackgroundColor="Transparent"
        MinimumHeightRequest="{StaticResource MinTouchTarget}"
        MinimumWidthRequest="{StaticResource MinTouchTarget}"
        Clicked="OnNewChatTapped"
        AutomationId="NewChatButton"
        SemanticProperties.Description="Start a new chat session">
      <ImageButton.Source>
        <FontImageSource
            FontFamily="MaterialSymbols"
            Glyph="{x:Static helpers:MaterialIcons.Edit}"
            Size="24"
            Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" />
      </ImageButton.Source>
    </ImageButton>

  </Grid>

</ContentView>
