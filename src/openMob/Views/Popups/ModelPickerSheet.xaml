<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
             xmlns:helpers="clr-namespace:openMob.Helpers"
             x:Class="openMob.Views.Popups.ModelPickerSheet"
             x:DataType="vm:ModelPickerViewModel"
             Title="Select Model"
             Shell.PresentationMode="ModalAnimated"
             BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}">

  <VerticalStackLayout Spacing="0">

    <!-- Handle bar -->
    <BoxView
        WidthRequest="36"
        HeightRequest="4"
        CornerRadius="2"
        Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
        HorizontalOptions="Center"
        Margin="0,8,0,16" />

    <!-- Title -->
    <Label
        Text="Select Model"
        FontFamily="InterSemiBold"
        FontSize="{StaticResource FontSizeTitle3}"
        TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}"
        Margin="16,0,16,16" />

    <!-- Static model list (REQ-034: placeholder with 3 Claude models) -->
    <VerticalStackLayout Spacing="0" Padding="16,0">

      <!-- Claude Haiku -->
      <Grid
          ColumnDefinitions="*,Auto"
          Padding="0,14"
          ColumnSpacing="12"
          MinimumHeightRequest="{StaticResource MinTouchTarget}">
        <VerticalStackLayout
            Grid.Column="0"
            Spacing="2"
            VerticalOptions="Center">
          <Label
              Text="Claude Haiku"
              FontFamily="InterMedium"
              FontSize="{StaticResource FontSizeBody}"
              TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" />
          <Label
              Text="Fast and lightweight"
              FontFamily="InterRegular"
              FontSize="{StaticResource FontSizeCaption1}"
              TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
        </VerticalStackLayout>
        <Label
            Grid.Column="1"
            FontFamily="MaterialSymbols"
            Text="{x:Static helpers:MaterialIcons.RadioButtonUnchecked}"
            FontSize="24"
            TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
            VerticalOptions="Center"
            SemanticProperties.Description="Not selected" />
      </Grid>

      <BoxView
          HeightRequest="0.5"
          Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight}, Dark={StaticResource ColorSeparatorDark}}" />

      <!-- Claude Sonnet (selected) -->
      <Grid
          ColumnDefinitions="*,Auto"
          Padding="0,14"
          ColumnSpacing="12"
          MinimumHeightRequest="{StaticResource MinTouchTarget}">
        <VerticalStackLayout
            Grid.Column="0"
            Spacing="2"
            VerticalOptions="Center">
          <Label
              Text="Claude Sonnet"
              FontFamily="InterMedium"
              FontSize="{StaticResource FontSizeBody}"
              TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" />
          <Label
              Text="Balanced performance"
              FontFamily="InterRegular"
              FontSize="{StaticResource FontSizeCaption1}"
              TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
        </VerticalStackLayout>
        <Label
            Grid.Column="1"
            FontFamily="MaterialSymbols"
            Text="{x:Static helpers:MaterialIcons.Check}"
            FontSize="24"
            TextColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}"
            VerticalOptions="Center"
            SemanticProperties.Description="Selected" />
      </Grid>

      <BoxView
          HeightRequest="0.5"
          Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight}, Dark={StaticResource ColorSeparatorDark}}" />

      <!-- Claude Opus -->
      <Grid
          ColumnDefinitions="*,Auto"
          Padding="0,14"
          ColumnSpacing="12"
          MinimumHeightRequest="{StaticResource MinTouchTarget}">
        <VerticalStackLayout
            Grid.Column="0"
            Spacing="2"
            VerticalOptions="Center">
          <Label
              Text="Claude Opus"
              FontFamily="InterMedium"
              FontSize="{StaticResource FontSizeBody}"
              TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" />
          <Label
              Text="Most capable"
              FontFamily="InterRegular"
              FontSize="{StaticResource FontSizeCaption1}"
              TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
        </VerticalStackLayout>
        <Label
            Grid.Column="1"
            FontFamily="MaterialSymbols"
            Text="{x:Static helpers:MaterialIcons.RadioButtonUnchecked}"
            FontSize="24"
            TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
            VerticalOptions="Center"
            SemanticProperties.Description="Not selected" />
      </Grid>

    </VerticalStackLayout>

  </VerticalStackLayout>

</ContentPage>
