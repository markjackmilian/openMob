<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         RAW PALETTE — do not reference these directly in UI XAML.
         Use the semantic tokens below instead.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Neutral / Slate scale (cool grays, Apple-adjacent) -->
    <Color x:Key="Slate50">#F8FAFC</Color>
    <Color x:Key="Slate100">#F1F5F9</Color>
    <Color x:Key="Slate200">#E2E8F0</Color>
    <Color x:Key="Slate300">#CBD5E1</Color>
    <Color x:Key="Slate400">#94A3B8</Color>
    <Color x:Key="Slate500">#64748B</Color>
    <Color x:Key="Slate600">#475569</Color>
    <Color x:Key="Slate700">#334155</Color>
    <Color x:Key="Slate800">#1E293B</Color>
    <Color x:Key="Slate900">#0F172A</Color>
    <Color x:Key="Slate950">#020617</Color>

    <!-- True neutrals (for surfaces and text) -->
    <Color x:Key="Neutral0">#FFFFFF</Color>
    <Color x:Key="Neutral50">#F9F9F9</Color>
    <Color x:Key="Neutral100">#F2F2F7</Color>
    <Color x:Key="Neutral200">#E5E5EA</Color>
    <Color x:Key="Neutral300">#D1D1D6</Color>
    <Color x:Key="Neutral400">#C7C7CC</Color>
    <Color x:Key="Neutral500">#AEAEB2</Color>
    <Color x:Key="Neutral600">#8E8E93</Color>
    <Color x:Key="Neutral700">#636366</Color>
    <Color x:Key="Neutral800">#3A3A3C</Color>
    <Color x:Key="Neutral850">#2C2C2E</Color>
    <Color x:Key="Neutral900">#1C1C1E</Color>
    <Color x:Key="Neutral950">#000000</Color>

    <!-- Blue / Accent scale (Apple HIG blue) -->
    <Color x:Key="Blue50">#EAF3FF</Color>
    <Color x:Key="Blue100">#CCE4FF</Color>
    <Color x:Key="Blue200">#99C9FF</Color>
    <Color x:Key="Blue300">#66AEFF</Color>
    <Color x:Key="Blue400">#3393FF</Color>
    <Color x:Key="Blue500">#007AFF</Color>
    <Color x:Key="Blue600">#0062CC</Color>
    <Color x:Key="Blue700">#004999</Color>
    <Color x:Key="Blue800">#003166</Color>
    <Color x:Key="Blue900">#001833</Color>

    <!-- Dark-mode accent (slightly lighter for contrast on dark surfaces) -->
    <Color x:Key="BlueDark400">#0A84FF</Color>
    <Color x:Key="BlueDark50">#1C3A5A</Color>

    <!-- Teal / Secondary accent -->
    <Color x:Key="Teal400">#32ADE6</Color>
    <Color x:Key="Teal500">#5AC8FA</Color>
    <Color x:Key="TealDark400">#64D2FF</Color>

    <!-- Semantic status — Green (Success) -->
    <Color x:Key="Green500">#34C759</Color>
    <Color x:Key="GreenDark500">#30D158</Color>
    <Color x:Key="Green50">#E8F8ED</Color>
    <Color x:Key="GreenDark50">#1A3D24</Color>

    <!-- ChatGPT-inspired Green Accent -->
    <Color x:Key="Green400">#10A37F</Color>
    <Color x:Key="GreenDark400">#1DB88E</Color>
    <Color x:Key="Green100">#E6F4EF</Color>
    <Color x:Key="GreenDark100">#0D2E23</Color>

    <!-- Semantic status — Amber (Warning) -->
    <Color x:Key="Amber500">#FF9F0A</Color>
    <Color x:Key="AmberDark500">#FFD60A</Color>
    <Color x:Key="Amber50">#FFF4E0</Color>
    <Color x:Key="AmberDark50">#3D2E00</Color>

    <!-- Semantic status — Red (Error / Destructive) -->
    <Color x:Key="Red500">#FF3B30</Color>
    <Color x:Key="RedDark500">#FF453A</Color>
    <Color x:Key="Red50">#FFECEB</Color>
    <Color x:Key="RedDark50">#3D1210</Color>

    <!-- Semantic status — Indigo (Info) -->
    <Color x:Key="Indigo500">#5856D6</Color>
    <Color x:Key="IndigoDark500">#5E5CE6</Color>
    <Color x:Key="Indigo50">#EEEEFF</Color>
    <Color x:Key="IndigoDark50">#1E1D3D</Color>

    <!-- ═══════════════════════════════════════════════════════════════
         SEMANTIC TOKENS — Light / Dark pairs.
         Use AppThemeBinding INLINE at the point of use to select the
         correct variant for the current app theme.
         Example: Value="{AppThemeBinding Light={StaticResource ColorBackgroundLight},
                                          Dark={StaticResource ColorBackgroundDark}}"
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Page & scaffold backgrounds -->
    <Color x:Key="ColorBackgroundLight">#FFFFFF</Color>
    <Color x:Key="ColorBackgroundDark">#0D0D0D</Color>
    <Color x:Key="ColorBackgroundSecondaryLight">#F7F7F8</Color>
    <Color x:Key="ColorBackgroundSecondaryDark">#1A1A1A</Color>

    <!-- Card / sheet surfaces -->
    <Color x:Key="ColorSurfaceLight">#FFFFFF</Color>
    <Color x:Key="ColorSurfaceDark">#1A1A1A</Color>
    <Color x:Key="ColorSurfaceSecondaryLight">#F0F0F0</Color>
    <Color x:Key="ColorSurfaceSecondaryDark">#2A2A2A</Color>
    <Color x:Key="ColorSurfaceTertiaryLight">#E5E5E5</Color>
    <Color x:Key="ColorSurfaceTertiaryDark">#2A2A2A</Color>

    <!-- Text on background -->
    <Color x:Key="ColorOnBackgroundLight">#0D0D0D</Color>
    <Color x:Key="ColorOnBackgroundDark">#FFFFFF</Color>
    <Color x:Key="ColorOnBackgroundSecondaryLight">#6E6E80</Color>
    <Color x:Key="ColorOnBackgroundSecondaryDark">#8E8EA0</Color>
    <Color x:Key="ColorOnBackgroundTertiaryLight">#ACACBE</Color>
    <Color x:Key="ColorOnBackgroundTertiaryDark">#565869</Color>

    <!-- Text on surface -->
    <Color x:Key="ColorOnSurfaceLight">#0D0D0D</Color>
    <Color x:Key="ColorOnSurfaceDark">#FFFFFF</Color>
    <Color x:Key="ColorOnSurfaceSecondaryLight">#6E6E80</Color>
    <Color x:Key="ColorOnSurfaceSecondaryDark">#8E8EA0</Color>
    <Color x:Key="ColorOnSurfaceTertiaryLight">#ACACBE</Color>
    <Color x:Key="ColorOnSurfaceTertiaryDark">#565869</Color>

    <!-- Accent / Primary interactive -->
    <Color x:Key="ColorPrimaryLight">#10A37F</Color>
    <Color x:Key="ColorPrimaryDark">#1DB88E</Color>
    <Color x:Key="ColorPrimaryContainerLight">#E6F4EF</Color>
    <Color x:Key="ColorPrimaryContainerDark">#0D2E23</Color>
    <Color x:Key="ColorOnPrimaryLight">#FFFFFF</Color>
    <Color x:Key="ColorOnPrimaryDark">#FFFFFF</Color>
    <Color x:Key="ColorOnPrimaryContainerLight">#0D8F6F</Color>
    <Color x:Key="ColorOnPrimaryContainerDark">#1DB88E</Color>

    <!-- Secondary interactive -->
    <Color x:Key="ColorSecondaryLight">#32ADE6</Color>
    <Color x:Key="ColorSecondaryDark">#64D2FF</Color>
    <Color x:Key="ColorOnSecondaryLight">#FFFFFF</Color>
    <Color x:Key="ColorOnSecondaryDark">#000000</Color>

    <!-- Tertiary (muted / supporting) -->
    <Color x:Key="ColorTertiaryLight">#64748B</Color>
    <Color x:Key="ColorTertiaryDark">#94A3B8</Color>
    <Color x:Key="ColorOnTertiaryLight">#FFFFFF</Color>
    <Color x:Key="ColorOnTertiaryDark">#000000</Color>

    <!-- Borders, separators, outlines -->
    <Color x:Key="ColorOutlineLight">#E5E5E5</Color>
    <Color x:Key="ColorOutlineDark">#2A2A2A</Color>
    <Color x:Key="ColorOutlineVariantLight">#E5E5E5</Color>
    <Color x:Key="ColorOutlineVariantDark">#3A3A3A</Color>
    <Color x:Key="ColorSeparatorLight">#E5E5E5</Color>
    <Color x:Key="ColorSeparatorDark">#2A2A2A</Color>

    <!-- Disabled states -->
    <Color x:Key="ColorDisabledLight">#ACACBE</Color>
    <Color x:Key="ColorDisabledDark">#565869</Color>
    <Color x:Key="ColorOnDisabledLight">#FFFFFF</Color>
    <Color x:Key="ColorOnDisabledDark">#1C1C1E</Color>
    <Color x:Key="ColorDisabledSurfaceLight">#F0F0F0</Color>
    <Color x:Key="ColorDisabledSurfaceDark">#2A2A2A</Color>

    <!-- Semantic status — Error / Destructive -->
    <Color x:Key="ColorErrorLight">#FF3B30</Color>
    <Color x:Key="ColorErrorDark">#FF453A</Color>
    <Color x:Key="ColorErrorContainerLight">#FFECEB</Color>
    <Color x:Key="ColorErrorContainerDark">#3D1210</Color>
    <Color x:Key="ColorOnErrorLight">#FFFFFF</Color>
    <Color x:Key="ColorOnErrorDark">#FFFFFF</Color>
    <Color x:Key="ColorOnErrorContainerLight">#FF3B30</Color>
    <Color x:Key="ColorOnErrorContainerDark">#FF453A</Color>

    <!-- Semantic status — Success -->
    <Color x:Key="ColorSuccessLight">#34C759</Color>
    <Color x:Key="ColorSuccessDark">#30D158</Color>
    <Color x:Key="ColorSuccessContainerLight">#E8F8ED</Color>
    <Color x:Key="ColorSuccessContainerDark">#1A3D24</Color>
    <Color x:Key="ColorOnSuccessLight">#FFFFFF</Color>
    <Color x:Key="ColorOnSuccessDark">#FFFFFF</Color>
    <Color x:Key="ColorOnSuccessContainerLight">#34C759</Color>
    <Color x:Key="ColorOnSuccessContainerDark">#30D158</Color>

    <!-- Semantic status — Warning -->
    <Color x:Key="ColorWarningLight">#FF9F0A</Color>
    <Color x:Key="ColorWarningDark">#FFD60A</Color>
    <Color x:Key="ColorWarningContainerLight">#FFF4E0</Color>
    <Color x:Key="ColorWarningContainerDark">#3D2E00</Color>
    <Color x:Key="ColorOnWarningLight">#FFFFFF</Color>
    <Color x:Key="ColorOnWarningDark">#000000</Color>
    <Color x:Key="ColorOnWarningContainerLight">#FF9F0A</Color>
    <Color x:Key="ColorOnWarningContainerDark">#FFD60A</Color>

    <!-- Semantic status — Info -->
    <Color x:Key="ColorInfoLight">#5856D6</Color>
    <Color x:Key="ColorInfoDark">#5E5CE6</Color>
    <Color x:Key="ColorInfoContainerLight">#EEEEFF</Color>
    <Color x:Key="ColorInfoContainerDark">#1E1D3D</Color>
    <Color x:Key="ColorOnInfoLight">#FFFFFF</Color>
    <Color x:Key="ColorOnInfoDark">#FFFFFF</Color>
    <Color x:Key="ColorOnInfoContainerLight">#5856D6</Color>
    <Color x:Key="ColorOnInfoContainerDark">#5E5CE6</Color>

    <!-- Shell / navigation chrome -->
    <Color x:Key="ColorNavigationBarLight">#FFFFFF</Color>
    <Color x:Key="ColorNavigationBarDark">#0D0D0D</Color>
    <Color x:Key="ColorTabBarLight">#FFFFFF</Color>
    <Color x:Key="ColorTabBarDark">#0D0D0D</Color>
    <Color x:Key="ColorTabBarSelectedLight">#10A37F</Color>
    <Color x:Key="ColorTabBarSelectedDark">#1DB88E</Color>
    <Color x:Key="ColorTabBarUnselectedLight">#ACACBE</Color>
    <Color x:Key="ColorTabBarUnselectedDark">#565869</Color>

    <!-- Scrim / overlay (for modals, bottom sheets) -->
    <Color x:Key="ColorScrimLight">#80000000</Color>
    <Color x:Key="ColorScrimDark">#99000000</Color>

    <!-- Inverse (for snackbars, toasts on dark surfaces) -->
    <Color x:Key="ColorInverseSurfaceLight">#0D0D0D</Color>
    <Color x:Key="ColorInverseSurfaceDark">#FFFFFF</Color>
    <Color x:Key="ColorInverseOnSurfaceLight">#FFFFFF</Color>
    <Color x:Key="ColorInverseOnSurfaceDark">#0D0D0D</Color>

    <!-- ═══════════════════════════════════════════════════════════════
         CHAT-SPECIFIC TOKENS
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Chat bubble backgrounds -->
    <Color x:Key="ColorBubbleSentLight">#10A37F</Color>
    <Color x:Key="ColorBubbleSentDark">#1DB88E</Color>
    <Color x:Key="ColorBubbleReceivedLight">#FFFFFF</Color>
    <Color x:Key="ColorBubbleReceivedDark">#1A1A1A</Color>

    <!-- Chat bubble text -->
    <Color x:Key="ColorOnBubbleSentLight">#FFFFFF</Color>
    <Color x:Key="ColorOnBubbleSentDark">#FFFFFF</Color>
    <Color x:Key="ColorOnBubbleSentSecondaryLight">#FFFFFFB3</Color>
    <Color x:Key="ColorOnBubbleSentSecondaryDark">#FFFFFFB3</Color>
    <Color x:Key="ColorOnBubbleReceivedLight">#0D0D0D</Color>
    <Color x:Key="ColorOnBubbleReceivedDark">#FFFFFF</Color>

    <!-- Input bar -->
    <Color x:Key="ColorInputBarBackgroundLight">#FFFFFF</Color>
    <Color x:Key="ColorInputBarBackgroundDark">#1A1A1A</Color>
    <Color x:Key="ColorInputFieldBackgroundLight">#F0F0F0</Color>
    <Color x:Key="ColorInputFieldBackgroundDark">#2A2A2A</Color>

    <!-- Chat sizing tokens (theme-independent) -->
    <x:Double x:Key="SizeBubbleMaxWidth">0.80</x:Double>
    <x:Double x:Key="SizeAvatarSmall">28</x:Double>
    <x:Double x:Key="SizeFlyoutWidth">0.80</x:Double>
    <x:Double x:Key="SizeFlyoutMaxWidth">320</x:Double>

</ResourceDictionary>
