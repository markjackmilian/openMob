<?xml version="1.0" encoding="utf-8" ?>
<uxd:PopupPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:uxd="clr-namespace:UXDivers.Popups.Maui;assembly=UXDivers.Popups.Maui"
               xmlns:vm="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
               xmlns:models="clr-namespace:openMob.Core.Models;assembly=openMob.Core"
               xmlns:helpers="clr-namespace:openMob.Helpers"
               x:Class="openMob.Views.Popups.MessageComposerSheet"
               x:DataType="vm:MessageComposerViewModel"
               BackgroundColor="{DynamicResource PopupBackdropColor}"
               CloseWhenBackgroundIsClicked="True"
               AppearingAnimation="{uxd:MoveInPopupAnimation MoveDirection=Bottom, Duration=300, Easing=CubicOut}"
               DisappearingAnimation="{uxd:MoveOutPopupAnimation MoveDirection=Bottom, Duration=250, Easing=CubicIn}">

  <!-- Bottom-sheet panel: anchored to bottom, rounded top corners, solid background -->
  <Border VerticalOptions="End"
          HorizontalOptions="Fill"
          StrokeThickness="0"
          Padding="0"
          BackgroundColor="{AppThemeBinding Light={StaticResource ColorBackgroundLight},
                                            Dark={StaticResource ColorBackgroundDark}}">
    <Border.StrokeShape>
      <RoundRectangle CornerRadius="20,20,0,0" />
    </Border.StrokeShape>
    <Border.Shadow>
      <Shadow Brush="Black" Opacity="0.15" Offset="0,-2" Radius="16" />
    </Border.Shadow>

    <VerticalStackLayout Spacing="0" Padding="0">

      <!-- Handle bar -->
      <BoxView Style="{StaticResource SheetHandleBar}"
               Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                        Dark={StaticResource ColorOnBackgroundTertiaryDark}}" />

      <!-- Header -->
      <Grid ColumnDefinitions="*,Auto"
            Padding="16,0"
            HeightRequest="{StaticResource MinTouchTarget}">
        <Label Grid.Column="0"
               Text="Compose Message"
               Style="{StaticResource Title3Label}"
               VerticalOptions="Center" />
        <ImageButton Grid.Column="1"
                     Clicked="OnCloseButtonTapped"
                     HeightRequest="40"
                     WidthRequest="40"
                     BackgroundColor="Transparent"
                     AutomationId="ComposerCloseButton"
                     SemanticProperties.Description="Close message composer">
          <ImageButton.Source>
            <FontImageSource FontFamily="TablerIcons"
                             Glyph="{x:Static helpers:IconKeys.X}"
                             Size="20"
                             Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight},
                                                      Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
          </ImageButton.Source>
        </ImageButton>
      </Grid>

      <!-- Divider -->
      <BoxView HeightRequest="0.5"
               Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight},
                                        Dark={StaticResource ColorSeparatorDark}}" />

      <!-- Session chips row — horizontal scroll for small screens -->
      <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Padding="0">
      <HorizontalStackLayout Spacing="8" Padding="16,10">

        <!-- Agent chip -->
        <Border StrokeThickness="1"
                Stroke="{AppThemeBinding Light={StaticResource ColorOutlineLight}, Dark={StaticResource ColorOutlineDark}}"
                BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight}, Dark={StaticResource ColorSurfaceSecondaryDark}}"
                Padding="10,5" HeightRequest="32">
          <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
          <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding SelectAgentCommand}" /></Border.GestureRecognizers>
          <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
            <Label Text="{x:Static helpers:IconKeys.Robot}" FontFamily="TablerIcons" FontSize="14"
                   TextColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" VerticalOptions="Center" />
            <Label Text="Agent:" FontFamily="InterRegular" FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" VerticalOptions="Center" />
            <Label Text="{Binding SessionAgentDisplayName, FallbackValue='Default'}" FontFamily="InterSemiBold" FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" VerticalOptions="Center"
                   LineBreakMode="TailTruncation" MaximumWidthRequest="80" />
          </HorizontalStackLayout>
        </Border>

        <!-- Model chip -->
        <Border StrokeThickness="1"
                Stroke="{AppThemeBinding Light={StaticResource ColorOutlineLight}, Dark={StaticResource ColorOutlineDark}}"
                BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight}, Dark={StaticResource ColorSurfaceSecondaryDark}}"
                Padding="10,5" HeightRequest="32">
          <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
          <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding SelectModelCommand}" /></Border.GestureRecognizers>
          <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
            <Label Text="{x:Static helpers:IconKeys.Cpu}" FontFamily="TablerIcons" FontSize="14"
                   TextColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" VerticalOptions="Center" />
            <Label Text="Model:" FontFamily="InterRegular" FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" VerticalOptions="Center" />
            <Label Text="{Binding SessionModelDisplayName, FallbackValue='No model'}" FontFamily="InterSemiBold" FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" VerticalOptions="Center"
                   LineBreakMode="TailTruncation" MaximumWidthRequest="120" />
          </HorizontalStackLayout>
        </Border>

        <!-- Think level chip -->
        <Border StrokeThickness="1"
                Stroke="{AppThemeBinding Light={StaticResource ColorOutlineLight}, Dark={StaticResource ColorOutlineDark}}"
                BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight}, Dark={StaticResource ColorSurfaceSecondaryDark}}"
                Padding="10,5" HeightRequest="32">
          <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
          <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding ToggleThinkLevelExpandedCommand}" /></Border.GestureRecognizers>
          <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
            <Label Text="{x:Static helpers:IconKeys.Brain}" FontFamily="TablerIcons" FontSize="14"
                   TextColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" VerticalOptions="Center" />
            <Label Text="Think:" FontFamily="InterRegular" FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" VerticalOptions="Center" />
            <Label Text="{Binding SessionThinkingLevel, FallbackValue='Medium'}" FontFamily="InterSemiBold" FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" VerticalOptions="Center" />
            <Label Text="{x:Static helpers:IconKeys.ChevronDown}" FontFamily="TablerIcons" FontSize="11"
                   TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" VerticalOptions="Center"
                   IsVisible="{Binding IsThinkLevelExpanded, Converter={StaticResource InvertedBoolConverter}}" />
            <Label Text="{x:Static helpers:IconKeys.ChevronUp}" FontFamily="TablerIcons" FontSize="11"
                   TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" VerticalOptions="Center"
                   IsVisible="{Binding IsThinkLevelExpanded}" />
          </HorizontalStackLayout>
        </Border>

        <!-- Auto-accept chip — uses Button to avoid ScrollView gesture conflict -->
        <Button Command="{Binding ToggleAutoAcceptCommand}"
                Text="&#x2728; Auto"
                FontFamily="InterMedium"
                FontSize="12"
                HeightRequest="32"
                MinimumWidthRequest="0"
                Padding="10,0"
                CornerRadius="16"
                BorderWidth="1"
                BorderColor="{AppThemeBinding Light={StaticResource ColorOutlineLight}, Dark={StaticResource ColorOutlineDark}}"
                BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight}, Dark={StaticResource ColorSurfaceSecondaryDark}}"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}">
          <Button.Triggers>
            <DataTrigger TargetType="Button" Binding="{Binding SessionAutoAccept}" Value="True">
              <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
              <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight}, Dark={StaticResource ColorOnPrimaryDark}}" />
            </DataTrigger>
          </Button.Triggers>
        </Button>

      </HorizontalStackLayout>
      </ScrollView>

      <!-- Think level segmented (conditional) -->
      <HorizontalStackLayout Spacing="4" Padding="16,0,16,8" IsVisible="{Binding IsThinkLevelExpanded}">
        <Button Text="Low" FontFamily="InterMedium" FontSize="12" Padding="12,6" MinimumHeightRequest="28" MinimumWidthRequest="0" CornerRadius="6"
                Command="{Binding SetThinkingLevelCommand}" CommandParameter="{x:Static models:ThinkingLevel.Low}"
                BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight}, Dark={StaticResource ColorSurfaceSecondaryDark}}"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}">
          <Button.Triggers>
            <DataTrigger TargetType="Button" Binding="{Binding SessionThinkingLevel}" Value="{x:Static models:ThinkingLevel.Low}">
              <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
              <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight}, Dark={StaticResource ColorOnPrimaryDark}}" />
            </DataTrigger>
          </Button.Triggers>
        </Button>
        <Button Text="Medium" FontFamily="InterMedium" FontSize="12" Padding="12,6" MinimumHeightRequest="28" MinimumWidthRequest="0" CornerRadius="6"
                Command="{Binding SetThinkingLevelCommand}" CommandParameter="{x:Static models:ThinkingLevel.Medium}"
                BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight}, Dark={StaticResource ColorSurfaceSecondaryDark}}"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}">
          <Button.Triggers>
            <DataTrigger TargetType="Button" Binding="{Binding SessionThinkingLevel}" Value="{x:Static models:ThinkingLevel.Medium}">
              <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
              <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight}, Dark={StaticResource ColorOnPrimaryDark}}" />
            </DataTrigger>
          </Button.Triggers>
        </Button>
        <Button Text="High" FontFamily="InterMedium" FontSize="12" Padding="12,6" MinimumHeightRequest="28" MinimumWidthRequest="0" CornerRadius="6"
                Command="{Binding SetThinkingLevelCommand}" CommandParameter="{x:Static models:ThinkingLevel.High}"
                BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceSecondaryLight}, Dark={StaticResource ColorSurfaceSecondaryDark}}"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}">
          <Button.Triggers>
            <DataTrigger TargetType="Button" Binding="{Binding SessionThinkingLevel}" Value="{x:Static models:ThinkingLevel.High}">
              <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}" />
              <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorOnPrimaryLight}, Dark={StaticResource ColorOnPrimaryDark}}" />
            </DataTrigger>
          </Button.Triggers>
        </Button>
      </HorizontalStackLayout>

      <!-- Editor — clean, no background box, just text on the sheet surface -->
      <Editor Text="{Binding MessageText, Mode=TwoWay}"
              Placeholder="Scrivi un messaggio..."
              PlaceholderColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight},
                                                  Dark={StaticResource ColorOnBackgroundTertiaryDark}}"
              AutoSize="TextChanges"
              MinimumHeightRequest="120"
              MaximumHeightRequest="240"
              Margin="16,4,16,4"
              FontFamily="InterRegular"
              FontSize="{StaticResource FontSizeBody}"
              TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight},
                                           Dark={StaticResource ColorOnBackgroundDark}}"
              BackgroundColor="Transparent"
              AutomationId="ComposerEditor"
              SemanticProperties.Hint="Type your message here" />

      <!-- Divider above toolbar -->
      <BoxView HeightRequest="0.5"
               Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight},
                                        Dark={StaticResource ColorSeparatorDark}}" />

      <!-- Toolbar: picker buttons + send — single row, vertically centered -->
      <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto"
            Padding="12,8,16,8"
            ColumnSpacing="4"
            HeightRequest="44">

        <!-- @ Subagent -->
        <HorizontalStackLayout Grid.Column="0" Spacing="3" Padding="8,0" VerticalOptions="Center">
          <HorizontalStackLayout.GestureRecognizers><TapGestureRecognizer Command="{Binding InsertSubagentCommand}" /></HorizontalStackLayout.GestureRecognizers>
          <Label Text="{x:Static helpers:IconKeys.At}" FontFamily="TablerIcons" FontSize="18" VerticalOptions="Center"
                 TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
          <Label Text="@" FontFamily="InterMedium" FontSize="13" VerticalOptions="Center"
                 TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
        </HorizontalStackLayout>

        <!-- / Command -->
        <HorizontalStackLayout Grid.Column="1" Spacing="3" Padding="8,0" VerticalOptions="Center">
          <HorizontalStackLayout.GestureRecognizers><TapGestureRecognizer Command="{Binding InsertCommandCommand}" /></HorizontalStackLayout.GestureRecognizers>
          <Label Text="{x:Static helpers:IconKeys.Terminal}" FontFamily="TablerIcons" FontSize="18" VerticalOptions="Center"
                 TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
          <Label Text="/" FontFamily="InterMedium" FontSize="13" VerticalOptions="Center"
                 TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
        </HorizontalStackLayout>

        <!-- # File -->
        <HorizontalStackLayout Grid.Column="2" Spacing="3" Padding="8,0" VerticalOptions="Center">
          <HorizontalStackLayout.GestureRecognizers><TapGestureRecognizer Command="{Binding InsertFileCommand}" /></HorizontalStackLayout.GestureRecognizers>
          <Label Text="{x:Static helpers:IconKeys.File}" FontFamily="TablerIcons" FontSize="18" VerticalOptions="Center"
                 TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
          <Label Text="#" FontFamily="InterMedium" FontSize="13" VerticalOptions="Center"
                 TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
        </HorizontalStackLayout>

        <!-- Spacer -->
        <BoxView Grid.Column="3" Color="Transparent" />

        <!-- Send button — right-aligned -->
        <Button Grid.Column="4"
                Text="{Binding SendButtonText, FallbackValue='Invia'}"
                Command="{Binding SendCommand}"
                Style="{StaticResource PrimaryButton}"
                FontFamily="InterSemiBold"
                FontSize="15"
                MinimumWidthRequest="72"
                HeightRequest="38"
                Padding="16,0"
                VerticalOptions="Center"
                AutomationId="ComposerSendButton"
                SemanticProperties.Description="Send message" />
      </Grid>

      <!-- Bottom safe area for Android gesture nav -->
      <BoxView HeightRequest="56" Color="Transparent" />

    </VerticalStackLayout>
  </Border>

</uxd:PopupPage>
