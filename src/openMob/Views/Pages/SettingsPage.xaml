<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
              xmlns:helpers="clr-namespace:openMob.Helpers"
              xmlns:loc="clr-namespace:openMob.Localization"
              xmlns:vm="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
             x:Class="openMob.Views.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel"
               Title="{loc:Translate SettingsTitle}">

  <Shell.BackButtonBehavior>
    <BackButtonBehavior IsVisible="False" IsEnabled="False" />
  </Shell.BackButtonBehavior>

  <Shell.TitleView>
    <Grid ColumnDefinitions="Auto,*" Padding="{StaticResource SpacingXs}">
      <ImageButton
          Grid.Column="0"
          Clicked="OnBackButtonTapped"
          MinimumHeightRequest="{StaticResource MinTouchTarget}"
          MinimumWidthRequest="{StaticResource MinTouchTarget}"
          BackgroundColor="Transparent"
          AutomationId="SettingsBackButton"
          SemanticProperties.Description="{loc:Translate GoBack}">
        <ImageButton.Source>
          <FontImageSource
              FontFamily="TablerIcons"
              Glyph="{x:Static helpers:IconKeys.ArrowLeft}"
              Size="{StaticResource FontSizeIconXl}"
              Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" />
        </ImageButton.Source>
      </ImageButton>
      <Label
          Grid.Column="1"
          Text="{loc:Translate SettingsTitle}"
          Style="{StaticResource Title2Label}"
          VerticalOptions="Center" />
    </Grid>
  </Shell.TitleView>

  <ScrollView>
    <VerticalStackLayout
        Padding="{StaticResource SpacingLg}"
        Spacing="0">

      <!-- Section: General -->
      <Label
          Text="{loc:Translate GeneralSection}"
          Style="{StaticResource CaptionLabel}"
          FontFamily="InterMedium"
          Margin="0,8,0,8" />

      <Border Style="{StaticResource CardBorder}">
        <VerticalStackLayout Spacing="0">

          <!-- Appearance -->
          <Grid
              ColumnDefinitions="Auto,*,Auto"
              Padding="12,10"
              ColumnSpacing="{StaticResource SpacingMd}">
            <Grid.GestureRecognizers>
              <TapGestureRecognizer Tapped="OnAppearanceTapped" />
            </Grid.GestureRecognizers>
            <Image Grid.Column="0" VerticalOptions="Center" WidthRequest="20" HeightRequest="20">
              <Image.Source>
                <FontImageSource FontFamily="TablerIcons" Glyph="{x:Static helpers:IconKeys.Settings}" Size="20"
                    Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
              </Image.Source>
            </Image>
            <Label
                Grid.Column="1"
                Text="{loc:Translate Appearance}"
                FontFamily="InterRegular"
                VerticalOptions="Center" />
            <Label
                Grid.Column="2"
                Text="{Binding SelectedThemeLabel}"
                FontFamily="InterRegular"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                VerticalOptions="Center" />
          </Grid>

          <BoxView
              HeightRequest="0.5"
              Margin="44,0,0,0"
              Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight}, Dark={StaticResource ColorSeparatorDark}}" />

          <!-- Language -->
          <Grid
              ColumnDefinitions="Auto,*,Auto"
              Padding="12,10"
              ColumnSpacing="{StaticResource SpacingMd}">
            <Image Grid.Column="0" VerticalOptions="Center" WidthRequest="20" HeightRequest="20">
              <Image.Source>
                <FontImageSource FontFamily="TablerIcons" Glyph="{x:Static helpers:IconKeys.Globe}" Size="20"
                    Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
              </Image.Source>
            </Image>
            <Label
                Grid.Column="1"
                Text="{loc:Translate Language}"
                FontFamily="InterRegular"
                VerticalOptions="Center" />
            <Picker
                Grid.Column="2"
                ItemsSource="{Binding LanguageOptions}"
                ItemDisplayBinding="{Binding DisplayName}"
                SelectedItem="{Binding SelectedLanguageOption, Mode=TwoWay}"
                HorizontalOptions="End"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
          </Grid>

          <BoxView
              HeightRequest="0.5"
              Margin="44,0,0,0"
              Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight}, Dark={StaticResource ColorSeparatorDark}}" />

          <!-- Server Connection -->
          <Grid
              ColumnDefinitions="Auto,*,Auto"
              Padding="12,10"
              ColumnSpacing="{StaticResource SpacingMd}">
            <Grid.GestureRecognizers>
              <TapGestureRecognizer Command="{Binding NavigateToServerManagementCommand}" />
            </Grid.GestureRecognizers>
            <Image Grid.Column="0" VerticalOptions="Center" WidthRequest="20" HeightRequest="20">
              <Image.Source>
                <FontImageSource FontFamily="TablerIcons" Glyph="{x:Static helpers:IconKeys.Link}" Size="20"
                    Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
              </Image.Source>
            </Image>
            <Label
                Grid.Column="1"
                Text="{loc:Translate ServerConnection}"
                FontFamily="InterRegular"
                VerticalOptions="Center" />
            <Image Grid.Column="2" VerticalOptions="Center" WidthRequest="16" HeightRequest="16">
              <Image.Source>
                <FontImageSource FontFamily="TablerIcons" Glyph="{x:Static helpers:IconKeys.ChevronRight}" Size="16"
                    Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" />
              </Image.Source>
            </Image>
          </Grid>

          <BoxView
              HeightRequest="0.5"
              Margin="44,0,0,0"
              Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight}, Dark={StaticResource ColorSeparatorDark}}" />

          <!-- Notifications -->
          <Grid
              ColumnDefinitions="Auto,*,Auto"
              Padding="12,10"
              ColumnSpacing="{StaticResource SpacingMd}">
            <Image Grid.Column="0" VerticalOptions="Center" WidthRequest="20" HeightRequest="20">
              <Image.Source>
                <FontImageSource FontFamily="TablerIcons" Glyph="{x:Static helpers:IconKeys.Bell}" Size="20"
                    Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
              </Image.Source>
            </Image>
            <Label
                Grid.Column="1"
                Text="{loc:Translate Notifications}"
                FontFamily="InterRegular"
                VerticalOptions="Center" />
            <Image Grid.Column="2" VerticalOptions="Center" WidthRequest="16" HeightRequest="16">
              <Image.Source>
                <FontImageSource FontFamily="TablerIcons" Glyph="{x:Static helpers:IconKeys.ChevronRight}" Size="16"
                    Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" />
              </Image.Source>
            </Image>
          </Grid>

        </VerticalStackLayout>
      </Border>

      <!-- Section: AI Providers -->
      <Label
          Text="{loc:Translate AIProviders}"
          Style="{StaticResource CaptionLabel}"
          FontFamily="InterMedium"
          Margin="0,20,0,8" />

      <Border Style="{StaticResource CardBorder}">
        <VerticalStackLayout Spacing="0">

          <!-- Manage Providers -->
          <Grid
              ColumnDefinitions="Auto,*,Auto"
              Padding="12,10"
              ColumnSpacing="{StaticResource SpacingMd}">
            <Image Grid.Column="0" VerticalOptions="Center" WidthRequest="20" HeightRequest="20">
              <Image.Source>
                <FontImageSource FontFamily="TablerIcons" Glyph="{x:Static helpers:IconKeys.Robot}" Size="20"
                    Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
              </Image.Source>
            </Image>
            <Label
                Grid.Column="1"
                Text="{loc:Translate ManageProviders}"
                FontFamily="InterRegular"
                VerticalOptions="Center" />
            <Image Grid.Column="2" VerticalOptions="Center" WidthRequest="16" HeightRequest="16">
              <Image.Source>
                <FontImageSource FontFamily="TablerIcons" Glyph="{x:Static helpers:IconKeys.ChevronRight}" Size="16"
                    Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" />
              </Image.Source>
            </Image>
          </Grid>

          <BoxView
              HeightRequest="0.5"
              Margin="44,0,0,0"
              Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight}, Dark={StaticResource ColorSeparatorDark}}" />

          <!-- API Keys -->
          <Grid
              ColumnDefinitions="Auto,*,Auto"
              Padding="12,10"
              ColumnSpacing="{StaticResource SpacingMd}">
            <Image Grid.Column="0" VerticalOptions="Center" WidthRequest="20" HeightRequest="20">
              <Image.Source>
                <FontImageSource FontFamily="TablerIcons" Glyph="{x:Static helpers:IconKeys.Key}" Size="20"
                    Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
              </Image.Source>
            </Image>
            <Label
                Grid.Column="1"
                Text="{loc:Translate APIKeys}"
                FontFamily="InterRegular"
                VerticalOptions="Center" />
            <Image Grid.Column="2" VerticalOptions="Center" WidthRequest="16" HeightRequest="16">
              <Image.Source>
                <FontImageSource FontFamily="TablerIcons" Glyph="{x:Static helpers:IconKeys.ChevronRight}" Size="16"
                    Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" />
              </Image.Source>
            </Image>
          </Grid>

        </VerticalStackLayout>
      </Border>

      <!-- Section: About -->
      <Label
          Text="{loc:Translate About}"
          Style="{StaticResource CaptionLabel}"
          FontFamily="InterMedium"
          Margin="0,20,0,8" />

      <Border Style="{StaticResource CardBorder}">
        <VerticalStackLayout Spacing="0">

          <!-- Version -->
          <Grid
              ColumnDefinitions="Auto,*,Auto"
              Padding="12,10"
              ColumnSpacing="{StaticResource SpacingMd}">
            <Image Grid.Column="0" VerticalOptions="Center" WidthRequest="20" HeightRequest="20">
              <Image.Source>
                <FontImageSource FontFamily="TablerIcons" Glyph="{x:Static helpers:IconKeys.InfoCircle}" Size="20"
                    Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}" />
              </Image.Source>
            </Image>
            <Label
                Grid.Column="1"
                Text="{loc:Translate Version}"
                FontFamily="InterRegular"
                VerticalOptions="Center" />
            <Label
                Grid.Column="2"
                Text="1.0.0"
                FontFamily="InterRegular"
                TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                VerticalOptions="Center" />
          </Grid>

        </VerticalStackLayout>
      </Border>

    </VerticalStackLayout>
  </ScrollView>

</ContentPage>
