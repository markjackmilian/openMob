<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
             xmlns:helpers="clr-namespace:openMob.Helpers"
             x:Class="openMob.Views.Controls.OnboardingCompletionView"
             x:DataType="vm:OnboardingViewModel">

  <VerticalStackLayout
      Spacing="{StaticResource SpacingLg}"
      VerticalOptions="Center"
      Padding="{StaticResource SpacingXl}">

    <!-- Success icon -->
    <Label
        FontFamily="{StaticResource TablerIconsFont}"
        Text="{x:Static helpers:IconKeys.CircleCheck}"
        FontSize="{StaticResource FontSizeIconHero}"
        TextColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}"
        HorizontalOptions="Center" />

    <!-- Title -->
    <Label
        Text="All set!"
        Style="{StaticResource Title1Label}"
        FontFamily="InterBold"
        HorizontalTextAlignment="Center" />

    <!-- Subtitle -->
    <Label
        Text="Start chatting with your AI agent. You can always adjust settings later."
        Style="{StaticResource SubtitleLabel}"
        FontFamily="InterRegular"
        HorizontalTextAlignment="Center"
        Margin="0,0,0,16" />

  </VerticalStackLayout>

</ContentView>
