<?xml version="1.0" encoding="utf-8" ?>
<uxd:PopupPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:uxd="clr-namespace:UXDivers.Popups.Maui;assembly=UXDivers.Popups.Maui"
               xmlns:vm="clr-namespace:openMob.Core.ViewModels;assembly=openMob.Core"
               xmlns:models="clr-namespace:openMob.Core.Models;assembly=openMob.Core"
               xmlns:helpers="clr-namespace:openMob.Helpers"
               x:Class="openMob.Views.Popups.ProjectSwitcherSheet"
               x:DataType="vm:ProjectSwitcherViewModel"
               BackgroundColor="{DynamicResource PopupBackdropColor}"
               CloseWhenBackgroundIsClicked="True"
               AppearingAnimation="{uxd:FadeInPopupAnimation Duration=300}"
               DisappearingAnimation="{uxd:FadeOutPopupAnimation Duration=300}">

  <VerticalStackLayout Spacing="0">

    <!-- Handle bar -->
    <BoxView
        Style="{StaticResource SheetHandleBar}"
        Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundTertiaryLight}, Dark={StaticResource ColorOnBackgroundTertiaryDark}}" />

    <!-- Header with title and close button -->
    <Grid ColumnDefinitions="*,Auto"
          Padding="16,0,16,16">
      <Label
          Grid.Column="0"
          Text="Switch Project"
          Style="{StaticResource Title3Label}"
          VerticalOptions="Center" />
      <ImageButton
          Grid.Column="1"
          Clicked="OnCloseButtonTapped"
          MinimumHeightRequest="{StaticResource MinTouchTarget}"
          MinimumWidthRequest="{StaticResource MinTouchTarget}"
          BackgroundColor="Transparent"
          AutomationId="ProjectSwitcherCloseButton"
          SemanticProperties.Description="Close project switcher">
        <ImageButton.Source>
          <FontImageSource FontFamily="TablerIcons"
                           Glyph="{x:Static helpers:IconKeys.X}"
                           Size="{StaticResource FontSizeIconXl}"
                           Color="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight},
                                                    Dark={StaticResource ColorOnBackgroundDark}}" />
        </ImageButton.Source>
      </ImageButton>
    </Grid>

    <!-- Loading indicator -->
    <ActivityIndicator
        IsRunning="{Binding IsLoading}"
        IsVisible="{Binding IsLoading}"
        HorizontalOptions="Center"
        Margin="0,16" />

    <!-- Project list -->
    <CollectionView
        ItemsSource="{Binding Projects}"
        SelectionMode="None"
        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
      <CollectionView.ItemTemplate>
        <DataTemplate x:DataType="models:ProjectItem">
          <VerticalStackLayout Spacing="0" Padding="16,0">
            <Grid
                ColumnDefinitions="Auto,*,Auto"
                Padding="0,14"
                ColumnSpacing="{StaticResource SpacingMd}"
                MinimumHeightRequest="{StaticResource MinTouchTarget}">
              <Grid.GestureRecognizers>
                <TapGestureRecognizer
                    Command="{Binding SelectProjectCommand, Source={RelativeSource AncestorType={x:Type vm:ProjectSwitcherViewModel}}}"
                    CommandParameter="{Binding Id}" />
              </Grid.GestureRecognizers>

              <!-- Project folder icon -->
              <Label
                  Grid.Column="0"
                  FontFamily="TablerIcons"
                  Text="{x:Static helpers:IconKeys.Folder}"
                  FontSize="{StaticResource FontSizeIconXl}"
                  TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                  VerticalOptions="Center"
                  SemanticProperties.Description="Project folder icon" />

              <VerticalStackLayout
                  Grid.Column="1"
                  Spacing="{StaticResource SpacingXxs}"
                  VerticalOptions="Center">
                <Label
                    Text="{Binding Name, FallbackValue='Untitled'}"
                    FontFamily="InterMedium"
                    FontSize="{StaticResource FontSizeBody}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundLight}, Dark={StaticResource ColorOnBackgroundDark}}" />
                <Label
                    Text="{Binding Path, FallbackValue='', TargetNullValue=''}"
                    FontFamily="InterRegular"
                    FontSize="{StaticResource FontSizeCaption1}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
                    LineBreakMode="MiddleTruncation" />
              </VerticalStackLayout>

              <!-- Checkmark for active project -->
              <Label
                  Grid.Column="2"
                  FontFamily="TablerIcons"
                  Text="{x:Static helpers:IconKeys.Check}"
                  FontSize="{StaticResource FontSizeIconXl}"
                  TextColor="{AppThemeBinding Light={StaticResource ColorPrimaryLight}, Dark={StaticResource ColorPrimaryDark}}"
                  IsVisible="{Binding IsActive}"
                  VerticalOptions="Center"
                  SemanticProperties.Description="Active project" />
            </Grid>

            <BoxView
                HeightRequest="0.5"
                Color="{AppThemeBinding Light={StaticResource ColorSeparatorLight}, Dark={StaticResource ColorSeparatorDark}}" />
          </VerticalStackLayout>
        </DataTemplate>
      </CollectionView.ItemTemplate>
      <CollectionView.EmptyView>
        <Label
            Text="No projects available"
            FontFamily="InterRegular"
            FontSize="{StaticResource FontSizeCallout}"
            TextColor="{AppThemeBinding Light={StaticResource ColorOnBackgroundSecondaryLight}, Dark={StaticResource ColorOnBackgroundSecondaryDark}}"
            HorizontalTextAlignment="Center"
            Margin="0,16" />
      </CollectionView.EmptyView>
    </CollectionView>

    <!-- Manage projects link -->
    <Button
        Text="Manage Projects"
        Command="{Binding ManageProjectsCommand}"
        Style="{StaticResource TertiaryButton}"
        FontFamily="InterMedium"
        HorizontalOptions="Center"
        Margin="0,8,0,16"
        AutomationId="ProjectSwitcherManageButton" />

  </VerticalStackLayout>

</uxd:PopupPage>
